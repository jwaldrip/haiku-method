      "id": "editorial",
      "name": "Editorial",
      "description": "Magazine-inspired layouts with serif headings, generous whitespace, and refined typography. Elegant, content-first design with subtle warm accents.",
      "tokens": {
        "color_primary": "#1a1a1a",
