tyle=\"color:#e0e0e0;\">52%</span></span>\n    <span>node-02: <span style=\"color:#e0e0e0;\">41%</span></span>\n    <span>node-03: <span style=\"color:#e0e0e0;\">48%</span></span>\n  </div>\n</div>\n\n<!-- Second card -->\n<div style=\"margin:8px 16px;padding:12px;border:1px solid #333;border-radius:3px;background:#252525;\">\n  <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;\">\n    <span style=\"font-size:11px;text-transform:uppercase;letter-spacing:1px;color:#4fc3f7;\">memory</span>\n    <span style=\"font-size:11px;color:#888;\">12.4 / 32 GB</span>\n  </div>\n  <div style=\"background:#333;border-radius:2px;height:6px;\"><div style=\"background:#4fc3f7;border-radius:2px;height:6px;width:39%;\"></div></div>\n</div>\n\n<!-- Form -->\n<div style=\"margin:16px;\">\n  <label style=\"display:block;font-size:10px;text-transform:uppercase;letter-spacing:1px;color:#888;margin-bottom:4px;\">Filter</label>\n  <input type=\"text\" placeholder=\"query...\" style=\"width:200px;padding:6px 8px;border:1px solid #333;border-radius:3px;font-family:inherit;font-size:12px;background:#252525;color:#e0e0e0;outline:none;\" />\n  <button style=\"margin-left:6px;padding:6px 12px;background:#333;color:#e0e0e0;border:1px solid #444;border-radius:3px;font-family:inherit;font-size:11px;cursor:pointer;\">Run</button>\n</div>\n\n</body>\n</html>"
