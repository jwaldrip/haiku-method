function findActiveIntents() {
  try {
    const root = findHaikuRoot();
    const intentsDir = join6(root, "intents");
    if (!existsSync4(intentsDir)) return [];
    const results = [];
    for (const d of readdirSync2(intentsDir, { withFileTypes: true })) {
      if (!d.isDirectory()) continue;
      const file = join6(intentsDir, d.name, "intent.md");
      if (!existsSync4(file)) continue;
      const { data, body } = parseFrontmatter(readFileSync3(file, "utf8"));
      if (data.status === "active") {
        results.push({ slug: d.name, data, body });
      }
    }
    return results;
  } catch {
    return [];
  }
}
