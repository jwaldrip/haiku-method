import { readFile, readdir } from "node:fs/promises";
import { join, basename } from "node:path";
function normalizeFrontmatter(data) {
  const result = { ...data };
  for (const key in result) {
    const val = result[key];
    if (val instanceof Date) {
      result[key] = val.toISOString().split("T")[0];
    }
  }
  return result;
}
function extractTitle(body) {
  const match = body.match(/^# (.+)$/m);
  return match ? match[1].trim() : "";
}
function stripTitle(body) {
  return body.replace(/^# .+$/m, "").trim();
}
async function parseIntent(intentDir3) {
  try {
    const filePath = join(intentDir3, "intent.md");
    const raw = await readFile(filePath, "utf-8");
    const { data, content } = (0, import_gray_matter.default)(raw);
    const frontmatter = normalizeFrontmatter(data);
    const title = extractTitle(content);
    const bodyWithoutTitle = stripTitle(content);
    const sections = extractSections(bodyWithoutTitle);
    const slug = basename(intentDir3);
    return {
      slug,
      frontmatter,
      title,
      sections,
      rawContent: raw
    };
  } catch (err) {
    const filePath = join(intentDir3, "intent.md");
    if (err.code !== "ENOENT") {
      console.warn(`[haiku/shared] Failed to parse ${filePath}:`, err);
    }
    return null;
  }
}
async function parseUnit(filePath) {
  try {
    const raw = await readFile(filePath, "utf-8");
    const { data, content } = (0, import_gray_matter.default)(raw);
    const frontmatter = normalizeFrontmatter(data);
    const title = extractTitle(content);
    const bodyWithoutTitle = stripTitle(content);
    const sections = extractSections(bodyWithoutTitle);
    const filename = basename(filePath, ".md");
    const numberMatch = filename.match(/^unit-(\d+)/);
    const number3 = numberMatch ? parseInt(numberMatch[1], 10) : 0;
    return {
      slug: filename,
      number: number3,
      frontmatter,
      title,
      sections,
      rawContent: raw
    };
  } catch (err) {
    if (err.code !== "ENOENT") {
      console.warn(`[haiku/shared] Failed to parse ${filePath}:`, err);
    }
    return null;
  }
}
