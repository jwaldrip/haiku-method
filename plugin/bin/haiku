// src/hooks/quality-gate.ts
import { execSync as execSync2 } from "node:child_process";
function getJsonField(json, field) {
  try {
    const obj = JSON.parse(json);
    return String(obj[field] ?? "");
  } catch {
    return "";
  }
}
async function qualityGate(input, _pluginRoot) {
  if (input.stop_hook_active === true || input.stop_hook_active === "true") {
    return;
  }
  const intentDir2 = findActiveIntent2();
  if (!intentDir2) return;
  const iterationJson = stateLoad(intentDir2, "iteration.json");
  if (!iterationJson) return;
  if (!isValidJson(iterationJson)) return;
  const hat = getJsonField(iterationJson, "hat");
  const status = getJsonField(iterationJson, "status");
  const currentUnit = getJsonField(iterationJson, "currentUnit");
  if (!["builder", "implementer", "refactorer"].includes(hat)) return;
  if (status === "completed" || status === "blocked") return;
  const intentGates = readFrontmatterArray(`${intentDir2}/intent.md`, "quality_gates");
  let unitGates = [];
  if (currentUnit) {
    const unitFile = `${intentDir2}/${currentUnit}.md`;
    unitGates = readFrontmatterArray(unitFile, "quality_gates");
  }
  const allGates = [...intentGates, ...unitGates];
  if (allGates.length === 0) return;
  const repoRoot = getRepoRoot();
  const failures = [];
  let allPassed = true;
  for (let i = 0; i < allGates.length; i++) {
    const gate = allGates[i];
    const gateName = gate.name ?? `gate-${i}`;
    const gateCmd = gate.command ?? "";
    if (!gateCmd) continue;
    let gateOutput = "";
    let gateExit = 0;
    try {
      gateOutput = execSync2(gateCmd, {
        cwd: repoRoot,
        encoding: "utf8",
        timeout: 3e4,
        stdio: ["pipe", "pipe", "pipe"]
      });
    } catch (err) {
      const execErr = err;
      gateExit = execErr.status ?? 1;
      gateOutput = (execErr.stdout ?? "") + (execErr.stderr ?? "");
    }
    if (gateExit !== 0) {
      allPassed = false;
      const truncatedOutput = gateOutput.slice(0, 500);
      failures.push({
        name: gateName,
        command: gateCmd,
        exit_code: gateExit,
        output: truncatedOutput
      });
    }
  }
  if (allPassed) return;
  let reason = "Quality gate(s) failed:";
  for (const f of failures) {
    reason += `
- ${f.name}: command '${f.command}' exited ${f.exit_code}`;
    if (f.output) {
      reason += `, output: ${f.output}`;
    }
  }
  const response = { decision: "block", reason };
  process.stdout.write(JSON.stringify(response));
}
var init_quality_gate = __esm({
  "src/hooks/quality-gate.ts"() {
    "use strict";
    init_utils();
  }
});

// src/hooks/subagent-context.ts
import { existsSync as existsSync6, readFileSync as readFileSync5 } from "node:fs";
import { join as join9, basename as basename4 } from "node:path";
import { execSync as execSync3 } from "node:child_process";
function out2(s) {
  process.stdout.write(s + "\n");
}
function readHatInstructions(hatName, stageName, studioName, pluginRoot) {
  const projectHatFile = join9(process.cwd(), ".haiku", "studios", studioName, "stages", stageName, "hats", `${hatName}.md`);
  const pluginHatFile = join9(pluginRoot, "studios", studioName, "stages", stageName, "hats", `${hatName}.md`);
  let hatFile = "";
  if (existsSync6(projectHatFile)) {
    hatFile = projectHatFile;
  } else if (existsSync6(pluginHatFile)) {
    hatFile = pluginHatFile;
  }
  if (!hatFile) return "";
  const content = readFileSync5(hatFile, "utf8");
  const parts = content.split("---");
  if (parts.length >= 3) {
    return parts.slice(2).join("---").trim();
  }
  return content;
}
function readHatMetadata(hatName, stageName, studioName, pluginRoot) {
  const projectHatFile = join9(process.cwd(), ".haiku", "studios", studioName, "stages", stageName, "hats", `${hatName}.md`);
  const pluginHatFile = join9(pluginRoot, "studios", studioName, "stages", stageName, "hats", `${hatName}.md`);
  let hatFile = "";
  if (existsSync6(projectHatFile)) hatFile = projectHatFile;
  else if (existsSync6(pluginHatFile)) hatFile = pluginHatFile;
  if (!hatFile) return { name: "", description: "" };
  return {
    name: readFrontmatterField(hatFile, "name"),
    description: readFrontmatterField(hatFile, "description")
  };
}
function getHatSequence(stageName, studioName, pluginRoot) {
  const stageFile = join9(pluginRoot, "studios", studioName, "stages", stageName, "STAGE.md");
  const projectStageFile = join9(process.cwd(), ".haiku", "studios", studioName, "stages", stageName, "STAGE.md");
  let targetFile = "";
  if (existsSync6(projectStageFile)) targetFile = projectStageFile;
  else if (existsSync6(stageFile)) targetFile = stageFile;
  if (!targetFile) return "planner \u2192 builder \u2192 reviewer";
  const content = readFileSync5(targetFile, "utf8");
  const fmMatch = content.match(/^---\n([\s\S]*?)\n---/);
  if (!fmMatch) return "planner \u2192 builder \u2192 reviewer";
  const fm = fmMatch[1];
  const hats = [];
  let inHats = false;
  for (const line of fm.split("\n")) {
    if (line.match(/^hats:/)) {
      inHats = true;
      continue;
    }
    if (inHats) {
      if (!line.startsWith(" ") && !line.startsWith("	") && line.trim() !== "") break;
      const m2 = line.match(/^\s+-\s+(.+)/);
      if (m2) hats.push(m2[1].trim().replace(/^["']|["']$/g, ""));
    }
  }
  return hats.length > 0 ? hats.join(" \u2192 ") : "planner \u2192 builder \u2192 reviewer";
}
function getRepoRootFromWorktree() {
  try {
    const output = execSync3("git worktree list --porcelain", { encoding: "utf8" });
    const first = output.split("\n")[0];
    return first.replace(/^worktree /, "");
  } catch {
    try {
      return execSync3("git rev-parse --show-toplevel", { encoding: "utf8" }).trim();
    } catch {
      return process.cwd();
    }
  }
}
async function generateSubagentContext(_input, pluginRoot) {
  const currentBranch = getCurrentBranch();
  const intentDir2 = findActiveIntent2();
  if (!intentDir2) return;
  const intentSlug = basename4(intentDir2);
  const iterationJson = stateLoad(intentDir2, "iteration.json");
  if (!iterationJson) return;
  if (!isValidJson(iterationJson)) return;
  const state = JSON.parse(iterationJson);
  const iteration = Number(state.iteration ?? 1);
  const hat = state.hat ?? "";
  const status = state.status ?? "active";
  if (status === "completed" || !hat) return;
  const intentFile = join9(intentDir2, "intent.md");
  let activeStage = readFrontmatterField(intentFile, "active_stage") || "development";
  let studio = readFrontmatterField(intentFile, "studio") || "software";
  const activePass = readFrontmatterField(intentFile, "active_pass");
  const stageHatsStr = getHatSequence(activeStage, studio, pluginRoot);
  let contextScope;
  switch (hat) {
    case "reviewer":
    case "red-team":
    case "blue-team":
      contextScope = "review";
      break;
    case "builder":
    case "implementer":
    case "refactorer":
      contextScope = "build";
      break;
    case "planner":
      contextScope = "plan";
      break;
    default:
      contextScope = "full";
      break;
  }
  out2("## H\xB7AI\xB7K\xB7U Subagent Context");
  out2("");
  let statusLine = `**Iteration:** ${iteration} | **Role:** ${hat} | **Stage:** ${activeStage} (${stageHatsStr})`;
  if (activePass) {
    statusLine += ` | **Pass:** ${activePass}`;
  }
  out2(statusLine);
  out2("");
  if (existsSync6(intentFile)) {
    const intentContent = readFileSync5(intentFile, "utf8");
    out2("### Intent");
    out2("");
    out2(intentContent);
    out2("");
  }
  const criteriaFile = join9(intentDir2, "completion-criteria.md");
  if (existsSync6(criteriaFile)) {
    const criteria = readFileSync5(criteriaFile, "utf8");
    out2("### Completion Criteria");
    out2("");
    out2(criteria);
    out2("");
  }
  const discoveryFile = join9(intentDir2, "discovery.md");
  if (existsSync6(discoveryFile)) {
    const discoveryContent = readFileSync5(discoveryFile, "utf8");
    const headers = discoveryContent.split("\n").filter((l) => l.startsWith("## "));
    if (headers.length > 0) {
      out2("### Discovery Log");
      out2("");
      out2(`Elaboration findings available in \`.haiku/intents/${intentSlug}/discovery.md\`:`);
      out2("");
      for (const h of headers) out2(h);
      out2("");
      out2("*Read the full file for detailed findings.*");
      out2("");
    }
  }
  const unitFiles = findUnitFiles(intentDir2);
  if (unitFiles.length > 0) {
    out2("### Unit Status");
    out2("");
    out2("| Unit | Status | Discipline |");
    out2("|------|--------|------------|");
    for (const uf of unitFiles) {
      const name = basename4(uf, ".md");
      const unitStatus = readFrontmatterField(uf, "status") || "pending";
      const discipline = readFrontmatterField(uf, "discipline") || "-";
      out2(`| ${name} | ${unitStatus} | ${discipline} |`);
    }
    out2("");
  }
  if (!process.env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS) {
    const instructions = readHatInstructions(hat, activeStage, studio, pluginRoot);
    const hatMeta = readHatMetadata(hat, activeStage, studio, pluginRoot);
    out2(`### Current Role: ${hat}`);
    out2("");
    if (instructions) {
      out2(`**${hatMeta.name || hat}**`);
      out2("");
      out2(instructions);
      out2("");
    } else {
      out2(`**${hat}** orchestrates work by spawning discipline-specific agents based on unit requirements.`);
      out2("");
    }
  }
  out2("---");
  out2("");
  out2("## H\xB7AI\xB7K\xB7U Workflow Rules");
  out2("");
  const repoRoot = getRepoRootFromWorktree();
  if (contextScope !== "review") {
    out2("### Branch References");
    out2("");
    out2(`- **Intent branch:** \`haiku/${intentSlug}/main\``);
    out2(`- **Intent worktree:** \`${repoRoot}/.haiku/worktrees/${intentSlug}/\``);
    out2("");
    out2("To access intent-level state from a unit branch:");
    out2("```bash");
