function out3(s) {
  process.stdout.write(s + "\n");
}
function getHatSequence2(stageName, studioName, pluginRoot) {
  const stageFile = join11(pluginRoot, "studios", studioName, "stages", stageName, "STAGE.md");
  const projectStageFile = join11(process.cwd(), ".haiku", "studios", studioName, "stages", stageName, "STAGE.md");
  let targetFile = "";
  if (existsSync8(projectStageFile)) targetFile = projectStageFile;
  else if (existsSync8(stageFile)) targetFile = stageFile;
  if (!targetFile) return "planner \u2192 builder \u2192 reviewer";
  const content = readFileSync7(targetFile, "utf8");
  const fmMatch = content.match(/^---\n([\s\S]*?)\n---/);
  if (!fmMatch) return "planner \u2192 builder \u2192 reviewer";
  const fm = fmMatch[1];
  const hats = [];
  let inHats = false;
  for (const line of fm.split("\n")) {
    if (line.match(/^hats:/)) {
      inHats = true;
      continue;
    }
    if (inHats) {
      if (!line.startsWith(" ") && !line.startsWith("	") && line.trim() !== "") break;
      const m2 = line.match(/^\s+-\s+(.+)/);
      if (m2) hats.push(m2[1].trim().replace(/^["']|["']$/g, ""));
    }
  }
  return hats.length > 0 ? hats.join(" \u2192 ") : "planner \u2192 builder \u2192 reviewer";
}
function readHatInstructions2(hatName, stageName, studioName, pluginRoot) {
  const projectHatFile = join11(process.cwd(), ".haiku", "studios", studioName, "stages", stageName, "hats", `${hatName}.md`);
  const pluginHatFile = join11(pluginRoot, "studios", studioName, "stages", stageName, "hats", `${hatName}.md`);
  let hatFile = "";
  if (existsSync8(projectHatFile)) hatFile = projectHatFile;
  else if (existsSync8(pluginHatFile)) hatFile = pluginHatFile;
  if (!hatFile) return "";
  const content = readFileSync7(hatFile, "utf8");
  const parts = content.split("---");
  if (parts.length >= 3) {
    return parts.slice(2).join("---").trim();
  }
  return content;
}
function readHatMetadata2(hatName, stageName, studioName, pluginRoot) {
  const projectHatFile = join11(process.cwd(), ".haiku", "studios", studioName, "stages", stageName, "hats", `${hatName}.md`);
  const pluginHatFile = join11(pluginRoot, "studios", studioName, "stages", stageName, "hats", `${hatName}.md`);
  let hatFile = "";
  if (existsSync8(projectHatFile)) hatFile = projectHatFile;
  else if (existsSync8(pluginHatFile)) hatFile = pluginHatFile;
  if (!hatFile) return { name: "", description: "" };
  return {
    name: readFrontmatterField(hatFile, "name"),
    description: readFrontmatterField(hatFile, "description")
  };
}
