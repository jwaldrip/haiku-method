              const { data } = parseFrontmatter(readFileSync6(join9(intentsDir, d.name, "intent.md"), "utf8"));
              return data.status === "active";
            }).map((d) => d.name);
          }
        } catch {
        }
        const studios = listStudios2();
        const studioSummary = studios.map(
          (s) => `- **${s.name}**: ${s.data.description || ""} (stages: ${JSON.stringify(s.data.stages)}, category: ${s.data.category || "general"})`
        ).join("\n");
        const contextParts = [];
