    registerPrompt({
      name: "haiku:capacity",
      title: "Capacity",
      description: "Historical throughput \u2014 bolt counts, stage durations, patterns",
      arguments: [
        {
          name: "studio",
          description: "Filter by studio name",
          required: false,
          completer: completeStudio
        }
      ],
      handler: async (args2) => {
        const studioFilter = args2.studio || "";
        let root;
        try {
          root = findHaikuRoot();
        } catch {
          return singleMessage("No .haiku/ directory found. Run /haiku:setup to initialize.");
        }
        const intentsDir = join11(root, "intents");
        if (!existsSync9(intentsDir)) {
          return singleMessage("No intents found. Complete an intent to see capacity data.");
        }
        const slugs = readdirSync7(intentsDir, { withFileTypes: true }).filter((d) => d.isDirectory() && existsSync9(join11(intentsDir, d.name, "intent.md"))).map((d) => d.name);
        if (slugs.length === 0) {
          return singleMessage("No intents found. Complete an intent to see capacity data.");
        }
        const byStudio = /* @__PURE__ */ new Map();
        for (const slug of slugs) {
          const raw = readFileSync8(join11(intentsDir, slug, "intent.md"), "utf8");
          const { data } = parseFrontmatter(raw);
          const studio = data.studio || "unknown";
          if (studioFilter && studio !== studioFilter) continue;
          if (!byStudio.has(studio)) byStudio.set(studio, []);
          byStudio.get(studio).push({ slug, data });
        }
        if (byStudio.size === 0) {
          return singleMessage(
            studioFilter ? `Studio '${studioFilter}' not found or has no intents.` : "No intents found."
          );
        }
        const lines = ["# Capacity Report\n"];
        for (const [studio, intents] of byStudio) {
          const completed = intents.filter((i) => i.data.status === "completed");
          const active = intents.filter((i) => i.data.status === "active");
          lines.push(`## ${studio} Studio`);
          lines.push(`**Completed:** ${completed.length} intents | **Active:** ${active.length} intents
`);
          const stageMetrics = /* @__PURE__ */ new Map();
          for (const intent of intents) {
            const stagesDir = join11(intentsDir, intent.slug, "stages");
            if (!existsSync9(stagesDir)) continue;
            const stages = readdirSync7(stagesDir, { withFileTypes: true }).filter((d) => d.isDirectory()).map((d) => d.name);
            for (const stage of stages) {
              if (!stageMetrics.has(stage)) stageMetrics.set(stage, { bolts: [], durations: [] });
              const metrics = stageMetrics.get(stage);
              const state = readJson2(join11(stagesDir, stage, "state.json"));
              if (state.started_at && state.completed_at) {
                const start = new Date(state.started_at).getTime();
                const end = new Date(state.completed_at).getTime();
                if (!isNaN(start) && !isNaN(end)) {
                  metrics.durations.push(end - start);
                }
              }
              const unitsDir = join11(stagesDir, stage, "units");
              if (existsSync9(unitsDir)) {
                const unitFiles = readdirSync7(unitsDir).filter((f) => f.endsWith(".md"));
                for (const uf of unitFiles) {
                  const uRaw = readFileSync8(join11(unitsDir, uf), "utf8");
                  const { data: uData } = parseFrontmatter(uRaw);
                  const bolt = typeof uData.bolt === "number" ? uData.bolt : 0;
                  if (bolt > 0) metrics.bolts.push(bolt);
                }
              }
            }
          }
          if (stageMetrics.size > 0) {
            lines.push("| Stage | Median Bolts/Unit | Completed Stages |");
            lines.push("|-------|-------------------|------------------|");
            for (const [stage, metrics] of stageMetrics) {
              const medianBolt = metrics.bolts.length > 0 ? median(metrics.bolts) : "\u2014";
              lines.push(`| ${stage} | ${medianBolt} | ${metrics.durations.length} |`);
            }
          }
          lines.push("");
        }
        return singleMessage(lines.join("\n"));
      }
    });
    registerPrompt({
      name: "haiku:release-notes",
      title: "Release Notes",
      description: "Show the project changelog / release notes",
      arguments: [
        {
          name: "version",
          description: "Specific version to show (e.g. 1.82.13), or omit for recent releases",
          required: false
        }
      ],
      handler: async (args2) => {
        const version2 = args2.version || "";
        let dir = process.cwd();
        let changelogPath = "";
        for (let i = 0; i < 20; i++) {
          const candidate = join11(dir, "CHANGELOG.md");
          if (existsSync9(candidate)) {
            changelogPath = candidate;
            break;
          }
          const parent = join11(dir, "..");
          if (parent === dir) break;
          dir = parent;
        }
        if (!changelogPath) {
          return singleMessage("No CHANGELOG.md found in the repository root.");
        }
        const content = readFileSync8(changelogPath, "utf8");
        if (version2) {
          const escaped = version2.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
          const versionPattern = version2.startsWith("v") ? escaped : `v?${escaped}`;
          const regex = new RegExp(`^## \\[?${versionPattern}\\]?.*$`, "m");
          const match = content.match(regex);
          if (!match || match.index === void 0) {
            return singleMessage(`Version ${version2} not found in CHANGELOG.md.`);
          }
          const startIdx = match.index;
          const nextHeading = content.indexOf("\n## ", startIdx + 1);
          const section = nextHeading === -1 ? content.slice(startIdx) : content.slice(startIdx, nextHeading);
          return singleMessage(section.trim());
        }
        const headingRegex = /^## /gm;
        const headings = [];
        let m2;
        while ((m2 = headingRegex.exec(content)) !== null) {
          headings.push(m2.index);
        }
        const count = Math.min(5, headings.length);
        if (count === 0) {
          return singleMessage("CHANGELOG.md exists but contains no version entries.");
        }
        const endIdx = headings.length > count ? headings[count] : content.length;
        const recent = content.slice(headings[0], endIdx).trim();
        const totalReleases = headings.length;
        return singleMessage(
          `${recent}

---
Total releases: ${totalReleases}
Full changelog: CHANGELOG.md
RSS: https://haikumethod.ai/changelog/feed.xml`
        );
      }
    });
