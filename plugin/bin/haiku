// src/orchestrator.ts
import { existsSync as existsSync2, readFileSync as readFileSync2, readdirSync as readdirSync2 } from "node:fs";
import { join as join4 } from "node:path";
function findHaikuRoot2() {
  let dir = process.cwd();
  for (let i = 0; i < 20; i++) {
    if (existsSync2(join4(dir, ".haiku"))) return join4(dir, ".haiku");
    const parent = join4(dir, "..");
    if (parent === dir) break;
    dir = parent;
  }
  throw new Error("No .haiku/ directory found");
}
function readFrontmatter(filePath) {
  if (!existsSync2(filePath)) return {};
  const raw = readFileSync2(filePath, "utf8");
  const match = raw.match(/^---\n([\s\S]*?)\n---/);
  if (!match) return {};
  const data = {};
  for (const line of match[1].split("\n")) {
    const kv = line.match(/^([\w][\w-]*):\s*(.*)$/);
    if (kv) {
      const [, k2, v2] = kv;
      if (v2 === "null") data[k2] = null;
      else if (v2 === "true") data[k2] = true;
      else if (v2 === "false") data[k2] = false;
      else if (/^-?\d+$/.test(v2)) data[k2] = parseInt(v2, 10);
      else if (v2.startsWith("[") && v2.endsWith("]")) {
        data[k2] = v2.slice(1, -1).split(",").map((s) => s.trim().replace(/^["']|["']$/g, "")).filter(Boolean);
      } else data[k2] = v2.replace(/^["']|["']$/g, "");
    }
  }
  return data;
}
function readJson2(path) {
  if (!existsSync2(path)) return {};
  return JSON.parse(readFileSync2(path, "utf8"));
}
function resolveStudioStages(studio) {
  const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT || "";
  for (const base of [join4(process.cwd(), ".haiku", "studios"), join4(pluginRoot, "studios")]) {
    const studioFile = join4(base, studio, "STUDIO.md");
    if (existsSync2(studioFile)) {
      const fm = readFrontmatter(studioFile);
      return fm.stages || [];
    }
  }
  return [];
}
function resolveStageHats(studio, stage) {
  const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT || "";
  for (const base of [join4(process.cwd(), ".haiku", "studios"), join4(pluginRoot, "studios")]) {
    const stageFile = join4(base, studio, "stages", stage, "STAGE.md");
    if (existsSync2(stageFile)) {
      const fm = readFrontmatter(stageFile);
      return fm.hats || [];
    }
  }
  return [];
}
function resolveStageReview(studio, stage) {
  const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT || "";
  for (const base of [join4(process.cwd(), ".haiku", "studios"), join4(pluginRoot, "studios")]) {
    const stageFile = join4(base, studio, "stages", stage, "STAGE.md");
    if (existsSync2(stageFile)) {
      const fm = readFrontmatter(stageFile);
      const review = fm.review;
      if (Array.isArray(review)) return review[0];
      return review || "auto";
    }
  }
  return "auto";
}
function runNext(slug) {
  const root = findHaikuRoot2();
  const intentDir2 = join4(root, "intents", slug);
  const intentFile = join4(intentDir2, "intent.md");
  if (!existsSync2(intentFile)) {
    return { action: "error", message: `Intent '${slug}' not found` };
  }
  const intent = readFrontmatter(intentFile);
  const studio = intent.studio || "ideation";
  const mode = intent.mode || "continuous";
  const status = intent.status || "active";
  const activeStage = intent.active_stage || "";
  if (status === "completed") {
    return { action: "complete", message: `Intent '${slug}' is already completed` };
  }
  if (status === "archived") {
    return { action: "error", message: `Intent '${slug}' is archived` };
  }
  if (intent.composite) {
    return runNextComposite(slug, intent, intentDir2);
  }
  const studioStages = resolveStudioStages(studio);
  if (studioStages.length === 0) {
    return { action: "error", message: `Studio '${studio}' has no stages` };
  }
  let currentStage = activeStage;
  if (!currentStage) {
    currentStage = studioStages[0];
  }
  const stageState = readJson2(join4(intentDir2, "stages", currentStage, "state.json"));
  const phase = stageState.phase || "";
  const stageStatus = stageState.status || "pending";
  if (!phase || stageStatus === "pending") {
    const hats = resolveStageHats(studio, currentStage);
    return {
      action: "start_stage",
      intent: slug,
      studio,
      stage: currentStage,
      hats,
      phase: "decompose",
      message: `Start stage '${currentStage}' \u2014 decompose the work into units`
    };
  }
  if (phase === "decompose") {
    const unitsDir = join4(intentDir2, "stages", currentStage, "units");
    const hasUnits = existsSync2(unitsDir) && readdirSync2(unitsDir).filter((f) => f.endsWith(".md")).length > 0;
    if (!hasUnits) {
      return {
        action: "decompose",
        intent: slug,
        studio,
        stage: currentStage,
        message: `Decompose stage '${currentStage}' into units with completion criteria`
      };
    }
    return {
      action: "advance_phase",
      intent: slug,
      stage: currentStage,
      from_phase: "decompose",
      to_phase: "execute",
      message: `Units ready \u2014 begin execution of stage '${currentStage}'`
    };
  }
  if (phase === "execute") {
    const units = listUnits(intentDir2, currentStage);
    const readyUnits = units.filter((u3) => u3.status === "pending" && u3.depsComplete);
    const activeUnits = units.filter((u3) => u3.status === "active");
    const allComplete = units.every((u3) => u3.status === "completed");
    if (allComplete) {
      return {
        action: "advance_phase",
        intent: slug,
        stage: currentStage,
        from_phase: "execute",
        to_phase: "review",
        message: `All units complete \u2014 begin adversarial review of stage '${currentStage}'`
      };
    }
    if (activeUnits.length > 0) {
      const unit = activeUnits[0];
      const hats = resolveStageHats(studio, currentStage);
      return {
        action: "continue_unit",
        intent: slug,
        stage: currentStage,
        unit: unit.name,
        hat: unit.hat,
        bolt: unit.bolt,
        hats,
        message: `Continue unit '${unit.name}' \u2014 hat: ${unit.hat}, bolt: ${unit.bolt}`
      };
    }
    if (readyUnits.length > 0) {
      const unit = readyUnits[0];
      const hats = resolveStageHats(studio, currentStage);
      return {
        action: "start_unit",
        intent: slug,
        studio,
        stage: currentStage,
        unit: unit.name,
        first_hat: hats[0] || "",
        hats,
        message: `Start unit '${unit.name}' with hat '${hats[0] || ""}' in stage '${currentStage}'`
      };
    }
    const blockedUnits = units.filter((u3) => u3.status !== "completed");
    return {
      action: "blocked",
      intent: slug,
      stage: currentStage,
      blocked_units: blockedUnits.map((u3) => u3.name),
      message: `${blockedUnits.length} unit(s) blocked \u2014 dependencies not met or manual intervention needed`
    };
  }
  if (phase === "review") {
    return {
      action: "review",
      intent: slug,
      studio,
      stage: currentStage,
      message: `Run adversarial review agents for stage '${currentStage}'`
    };
  }
  if (phase === "persist") {
    return {
      action: "persist",
      intent: slug,
      stage: currentStage,
      message: `Persist stage outputs for '${currentStage}'`
    };
  }
  if (phase === "gate") {
    const reviewType = resolveStageReview(studio, currentStage);
    const stageIdx = studioStages.indexOf(currentStage);
    const nextStage = stageIdx < studioStages.length - 1 ? studioStages[stageIdx + 1] : null;
    const isLastStage = !nextStage;
    if (reviewType === "auto") {
      if (isLastStage) {
        return { action: "intent_complete", intent: slug, studio, message: `All stages complete for intent '${slug}'` };
      }
      if (mode === "continuous") {
        return { action: "advance_stage", intent: slug, stage: currentStage, next_stage: nextStage, gate_outcome: "advanced", message: `Gate auto-passed \u2014 advancing to '${nextStage}'` };
      }
      return { action: "stage_complete_discrete", intent: slug, stage: currentStage, next_stage: nextStage, message: `Stage '${currentStage}' complete. Run /haiku:run to start '${nextStage}'.` };
    }
    if (reviewType === "ask") {
      return { action: "gate_ask", intent: slug, stage: currentStage, next_stage: nextStage, message: `Stage '${currentStage}' complete \u2014 awaiting your approval to advance` };
    }
    if (reviewType === "external") {
      return { action: "gate_external", intent: slug, stage: currentStage, next_stage: nextStage, message: `Stage '${currentStage}' complete \u2014 push for external review` };
    }
    if (reviewType === "await") {
      return { action: "gate_await", intent: slug, stage: currentStage, next_stage: nextStage, message: `Stage '${currentStage}' complete \u2014 awaiting external event before advancing` };
    }
    return { action: "advance_stage", intent: slug, stage: currentStage, next_stage: nextStage, gate_outcome: "advanced", message: `Advancing to '${nextStage}'` };
  }
  if (stageStatus === "completed") {
    const stageIdx = studioStages.indexOf(currentStage);
    const nextStage = stageIdx < studioStages.length - 1 ? studioStages[stageIdx + 1] : null;
    if (!nextStage) {
      return { action: "intent_complete", intent: slug, studio, message: `All stages complete for intent '${slug}'` };
    }
    const hats = resolveStageHats(studio, nextStage);
    return { action: "start_stage", intent: slug, studio, stage: nextStage, hats, phase: "decompose", message: `Start stage '${nextStage}'` };
  }
  return { action: "error", message: `Unknown state for stage '${currentStage}' \u2014 phase: ${phase}, status: ${stageStatus}` };
}
function runNextComposite(slug, intent, intentDir2) {
  const composite = intent.composite;
  const compositeState = intent.composite_state || {};
  const syncRules = intent.sync || [];
  for (const entry of composite) {
    const current = compositeState[entry.studio] || entry.stages[0];
    if (current === "complete") continue;
    if (!entry.stages.includes(current)) continue;
    let blocked = false;
    for (const rule of syncRules) {
      for (const thenStage of rule.then) {
        if (thenStage === `${entry.studio}:${current}`) {
          for (const waitStage of rule.wait) {
            const [ws, wst] = waitStage.split(":");
            const wsState = compositeState[ws] || "";
            const wsStages = composite.find((c) => c.studio === ws)?.stages || [];
            const wsIdx = wsStages.indexOf(wst);
            const currentIdx = wsStages.indexOf(wsState);
            if (currentIdx <= wsIdx) {
              blocked = true;
              break;
            }
          }
          if (blocked) break;
        }
      }
      if (blocked) break;
    }
    if (!blocked) {
      return {
        action: "composite_run_stage",
        intent: slug,
        studio: entry.studio,
        stage: current,
        hats: resolveStageHats(entry.studio, current),
        message: `Composite: run '${entry.studio}:${current}'`
      };
    }
  }
  const allComplete = composite.every((e) => compositeState[e.studio] === "complete");
  if (allComplete) {
    return { action: "intent_complete", intent: slug, message: `All composite studios complete for '${slug}'` };
  }
  return { action: "blocked", intent: slug, message: "All runnable stages are sync-blocked \u2014 waiting for dependencies" };
}
function listUnits(intentDir2, stage) {
  const unitsDir = join4(intentDir2, "stages", stage, "units");
  if (!existsSync2(unitsDir)) return [];
  const files = readdirSync2(unitsDir).filter((f) => f.endsWith(".md"));
  const units = files.map((f) => {
    const fm = readFrontmatter(join4(unitsDir, f));
    return {
      name: f.replace(".md", ""),
      status: fm.status || "pending",
      hat: fm.hat || "",
      bolt: fm.bolt || 0,
      dependsOn: fm.depends_on || [],
      depsComplete: false
    };
  });
  const statusMap = new Map(units.map((u3) => [u3.name, u3.status]));
  for (const unit of units) {
    unit.depsComplete = unit.dependsOn.every((dep) => statusMap.get(dep) === "completed");
  }
  return units;
}
function handleOrchestratorTool(name, args2) {
  const text = (s) => ({ content: [{ type: "text", text: s }] });
  if (name === "haiku_run_next") {
    const result = runNext(args2.intent);
    emitTelemetry("haiku.orchestrator.action", { intent: args2.intent, action: result.action });
    return text(JSON.stringify(result, null, 2));
  }
  if (name === "haiku_gate_approve") {
    const root = findHaikuRoot2();
    const intentDir2 = join4(root, "intents", args2.intent);
    const intentFm = readFrontmatter(join4(intentDir2, "intent.md"));
    const studio = intentFm.studio || "ideation";
    const stages = resolveStudioStages(studio);
    const currentIdx = stages.indexOf(args2.stage);
    const nextStage = currentIdx < stages.length - 1 ? stages[currentIdx + 1] : null;
    emitTelemetry("haiku.gate.resolved", { intent: args2.intent, stage: args2.stage, gate_type: "ask", outcome: "advanced" });
    if (nextStage) {
      return text(JSON.stringify({ action: "advance_stage", intent: args2.intent, stage: args2.stage, next_stage: nextStage, gate_outcome: "advanced" }));
    }
    return text(JSON.stringify({ action: "intent_complete", intent: args2.intent }));
  }
  return text(`Unknown orchestrator tool: ${name}`);
}
