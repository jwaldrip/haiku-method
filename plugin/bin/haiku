// src/hooks/context-monitor.ts
import { existsSync as existsSync11, readFileSync as readFileSync9, appendFileSync as appendFileSync2 } from "node:fs";
import { join as join14 } from "node:path";
async function contextMonitor(input, _pluginRoot) {
  const totalTokens = Number(input.total_tokens ?? 0);
  const maxTokens = Number(input.max_tokens ?? 0);
  if (totalTokens === 0 || maxTokens === 0) return;
  const remaining = Math.floor((maxTokens - totalTokens) * 100 / maxTokens);
  const sessionId = process.env.CLAUDE_SESSION_ID ?? "unknown";
  const debounceFile = join14("/tmp", `context-monitor-${sessionId}`);
  let debounceContent = "";
  if (existsSync11(debounceFile)) {
    debounceContent = readFileSync9(debounceFile, "utf8");
  }
  if (remaining <= 25) {
    if (!debounceContent.includes("25")) {
      appendFileSync2(debounceFile, "25\n");
      process.stderr.write(
        `\u26A0\uFE0F CONTEXT CRITICAL (\u226425% remaining)

**You MUST:**
1. Commit all working changes NOW
2. Save state to \`.haiku/intents/{intent-slug}/state/\`
3. Complete current task or signal handoff
4. Do NOT start new tasks

Quality degrades severely at low context. Wrap up.
`
      );
      process.exit(2);
    }
  } else if (remaining <= 35) {
    if (!debounceContent.includes("35")) {
      appendFileSync2(debounceFile, "35\n");
      process.stderr.write(
        `\u26A0\uFE0F CONTEXT WARNING (\u226435% remaining)

**Recommended:**
- Finish current task, avoid starting new ones
- Commit working changes frequently
- Consider saving state for session handoff
- Keep responses concise
`
      );
      process.exit(2);
    }
  }
}
var init_context_monitor = __esm({
  "src/hooks/context-monitor.ts"() {
    "use strict";
  }
});

// src/hooks/utils.ts
import { existsSync as existsSync12, readFileSync as readFileSync10, readdirSync as readdirSync9, statSync as statSync2, writeFileSync as writeFileSync5, mkdirSync as mkdirSync5 } from "node:fs";
import { join as join15, dirname as dirname3 } from "node:path";
import { execSync } from "node:child_process";
function readFrontmatterField(filePath, field) {
  if (!existsSync12(filePath)) return "";
  const content = readFileSync10(filePath, "utf8");
  const match = content.match(new RegExp(`^${field}:\\s*(.+)$`, "m"));
  return match ? match[1].trim().replace(/^["']|["']$/g, "") : "";
}
function readJson3(filePath) {
  if (!existsSync12(filePath)) return {};
  try {
    return JSON.parse(readFileSync10(filePath, "utf8"));
  } catch {
    return {};
  }
}
function findActiveIntent2() {
  let repoRoot;
  try {
    repoRoot = execSync("git rev-parse --show-toplevel", { encoding: "utf8" }).trim();
  } catch {
    repoRoot = process.cwd();
  }
  const intentsDir = join15(repoRoot, ".haiku", "intents");
  if (!existsSync12(intentsDir)) return null;
  const dirs = readdirSync9(intentsDir);
  for (const d of dirs) {
    const intentFile = join15(intentsDir, d, "intent.md");
    if (!existsSync12(intentFile)) continue;
    const status = readFrontmatterField(intentFile, "status");
    if (status === "active") {
      return join15(intentsDir, d);
    }
  }
  return null;
}
function isUnitBranch(branch) {
  if (!branch) return false;
  const parts = branch.split("/");
  return parts.length >= 3 && parts[0] === "haiku" && parts[2] !== "main";
}
function getCurrentBranch2() {
  try {
    return execSync("git branch --show-current", { encoding: "utf8" }).trim();
  } catch {
    return "";
  }
}
function getRepoRoot() {
  try {
    return execSync("git rev-parse --show-toplevel", { encoding: "utf8" }).trim();
  } catch {
    return process.cwd();
  }
}
function findUnitFiles(intentDir3) {
  const results = [];
  const stagesDir = join15(intentDir3, "stages");
  if (!existsSync12(stagesDir)) return results;
  for (const stage of readdirSync9(stagesDir)) {
    const unitsDir = join15(stagesDir, stage, "units");
    if (!existsSync12(unitsDir) || !statSync2(unitsDir).isDirectory()) continue;
    for (const file of readdirSync9(unitsDir)) {
      if (file.startsWith("unit-") && file.endsWith(".md")) {
        results.push(join15(unitsDir, file));
      }
    }
  }
  return results;
}
function readFrontmatterArray(filePath, field) {
  if (!existsSync12(filePath)) return [];
  const content = readFileSync10(filePath, "utf8");
  const fmMatch = content.match(/^---\n([\s\S]*?)\n---/);
  if (!fmMatch) return [];
  const frontmatter = fmMatch[1];
  const lines = frontmatter.split("\n");
  let inField = false;
  let currentItem = {};
  const items = [];
  for (const line of lines) {
    if (line.match(new RegExp(`^${field}:`))) {
      if (line.match(/\[\s*\]/)) return [];
      inField = true;
      continue;
    }
    if (inField) {
      if (!line.startsWith(" ") && !line.startsWith("	") && line.trim() !== "") {
        break;
      }
      const itemStart = line.match(/^\s+-\s+(.*)/);
      if (itemStart) {
        if (Object.keys(currentItem).length > 0) {
          items.push(currentItem);
        }
        currentItem = {};
        const kv = itemStart[1].match(/^(\w+):\s*(.+)/);
        if (kv) {
          currentItem[kv[1]] = kv[2].replace(/^["']|["']$/g, "");
        }
      } else {
        const kv = line.match(/^\s+(\w+):\s*(.+)/);
        if (kv) {
          currentItem[kv[1]] = kv[2].replace(/^["']|["']$/g, "");
        }
      }
    }
  }
  if (Object.keys(currentItem).length > 0) {
    items.push(currentItem);
  }
  return items;
}
function setFrontmatterField2(filePath, field, value) {
  if (!existsSync12(filePath)) return;
  let content = readFileSync10(filePath, "utf8");
  const regex = new RegExp(`^(${field}:)\\s*.+$`, "m");
  if (regex.test(content)) {
    content = content.replace(regex, `$1 ${value}`);
  } else {
    content = content.replace(/^---$/m, `${field}: ${value}
---`);
  }
  writeFileSync5(filePath, content);
}
function checkAllCriteria(filePath, section) {
  if (!existsSync12(filePath)) return;
  let content = readFileSync10(filePath, "utf8");
  if (!section) {
    content = content.replace(/- \[ \]/g, "- [x]");
  } else {
    const lines = content.split("\n");
    let inSection = false;
    for (let i = 0; i < lines.length; i++) {
      if (lines[i].startsWith("## ")) {
        inSection = lines[i].includes(section);
      }
      if (inSection) {
        lines[i] = lines[i].replace(/- \[ \]/g, "- [x]");
      }
    }
    content = lines.join("\n");
  }
  writeFileSync5(filePath, content);
}
function checkIntentCriteria(intentDir3) {
  const intentFile = join15(intentDir3, "intent.md");
  if (existsSync12(intentFile)) {
    const content = readFileSync10(intentFile, "utf8");
    if (content.includes("## Success Criteria")) {
      checkAllCriteria(intentFile, "Success Criteria");
    } else if (content.includes("## Completion Criteria")) {
      checkAllCriteria(intentFile, "Completion Criteria");
    }
  }
  for (const f of [join15(intentDir3, "completion-criteria.md"), join15(intentDir3, "state", "completion-criteria.md")]) {
    if (existsSync12(f)) checkAllCriteria(f);
  }
}
var init_utils = __esm({
  "src/hooks/utils.ts"() {
    "use strict";
  }
});

// src/hooks/enforce-iteration.ts
import { basename as basename3, join as join16 } from "node:path";
function out(s) {
  process.stdout.write(s + "\n");
}
async function enforceIteration(_input, _pluginRoot) {
  const currentBranch = getCurrentBranch2();
  const onUnitBranch = isUnitBranch(currentBranch);
  const intentDir3 = findActiveIntent2();
  if (onUnitBranch) {
    out("## H\xB7AI\xB7K\xB7U: Unit Session Ending");
    out("");
    out("Ensure you committed changes and saved progress.");
    return;
  }
  if (!intentDir3) {
    return;
  }
  const intentFile = `${intentDir3}/intent.md`;
  const intentStatus = readFrontmatterField(intentFile, "status");
  const activeStage2 = readFrontmatterField(intentFile, "active_stage");
  if (!activeStage2) return;
  const stageState = readJson3(join16(intentDir3, "stages", activeStage2, "state.json"));
  const stageStatus = stageState.status ?? "";
  const unitFiles = findUnitFiles(intentDir3);
  let hat = "";
  let bolt = 1;
  let activeUnitName = "";
  for (const uf of unitFiles) {
    const uStatus = readFrontmatterField(uf, "status");
    if (uStatus === "active") {
      hat = readFrontmatterField(uf, "hat") || "builder";
      bolt = Number(readFrontmatterField(uf, "bolt") || "1");
      activeUnitName = basename3(uf, ".md");
      break;
    }
  }
  if (!hat) hat = "builder";
  if (intentStatus === "completed" || stageStatus === "completed") {
    return;
  }
  const intentSlug = basename3(intentDir3);
  let readyCount = 0;
  let inProgressCount = 0;
  let allComplete = false;
  {
    let pending = 0;
    let completed = 0;
    let blocked = 0;
    for (const uf of unitFiles) {
      const unitStatus = readFrontmatterField(uf, "status") || "pending";
      switch (unitStatus) {
        case "completed":
          completed++;
          break;
        case "active":
        case "in_progress":
          inProgressCount++;
          break;
        case "blocked":
          blocked++;
          break;
        case "pending": {
          pending++;
          readyCount++;
          break;
        }
        default:
          pending++;
          break;
      }
    }
    if (readyCount === 0 && inProgressCount === 0 && pending === 0 && blocked === 0 && unitFiles.length > 0) {
      allComplete = true;
    }
    if (completed > 0 && completed === unitFiles.length) {
      allComplete = true;
    }
  }
  out("");
  out("---");
  out("");
  if (allComplete) {
    if (intentStatus === "active") {
      setFrontmatterField2(intentFile, "status", "completed");
      checkIntentCriteria(intentDir3);
    }
    out("## H\xB7AI\xB7K\xB7U: All Units Complete");
    out("");
    out("All units have been completed. Intent has been marked as completed.");
    out("");
  } else if (readyCount > 0 || inProgressCount > 0) {
    out("## H\xB7AI\xB7K\xB7U: Session Exhausted - Continue Execution");
    out("");
    out(`**Bolt:** ${bolt} | **Hat:** ${hat} | **Stage:** ${activeStage2}`);
    out(`**Ready units:** ${readyCount} | **In progress:** ${inProgressCount}`);
    out("");
    out("### ACTION REQUIRED");
    out("");
    if (activeUnitName) {
      out(`Call \`/haiku:execute ${intentSlug} ${activeUnitName}\` to continue targeted execution.`);
    } else {
      out("Call `/haiku:execute` to continue the autonomous loop.");
    }
    out("");
    out("**Note:** Subagents have clean context. No `/clear` needed.");
    out("");
  } else {
    out("## H\xB7AI\xB7K\xB7U: BLOCKED - Human Intervention Required");
    out("");
    out(`**Bolt:** ${bolt} | **Hat:** ${hat} | **Stage:** ${activeStage2}`);
    out("");
    out("No units are ready to work on. All remaining units are blocked.");
    out("");
    out("**User action required:**");
    out(`1. Review blockers: read \`.haiku/intents/${intentSlug}/state/blockers.md\``);
    out("2. Unblock units or resolve dependencies");
    out("3. Run `/haiku:execute` to resume");
    out("");
  }
  out(`Progress preserved in \`.haiku/intents/${intentSlug}/\`.`);
}
var init_enforce_iteration = __esm({
  "src/hooks/enforce-iteration.ts"() {
    "use strict";
    init_utils();
  }
});

