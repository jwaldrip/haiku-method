// src/git-worktree.ts
import { execFileSync } from "node:child_process";
import { existsSync as existsSync2, mkdirSync as mkdirSync2, rmSync } from "node:fs";
import { join as join4 } from "node:path";
function run(args2, cwd) {
  return execFileSync(args2[0], args2.slice(1), { encoding: "utf8", stdio: "pipe", cwd }).trim();
}
function tryRun(args2, cwd) {
  try {
    return run(args2, cwd);
  } catch {
    return "";
  }
}
function getCurrentBranch() {
  return tryRun(["git", "rev-parse", "--abbrev-ref", "HEAD"]);
}
function isOnIntentBranch(slug) {
  return getCurrentBranch() === `haiku/${slug}/main`;
}
function createIntentBranch(slug) {
  const branch = `haiku/${slug}/main`;
  try {
    tryRun(["git", "rev-parse", "--verify", branch]);
    if (getCurrentBranch() !== branch) {
      run(["git", "checkout", branch]);
    }
  } catch {
    try {
      run(["git", "checkout", "-b", branch]);
    } catch {
    }
  }
  return branch;
}
function createUnitWorktree(slug, unit) {
  const intentBranch = `haiku/${slug}/main`;
  const unitBranch = `haiku/${slug}/${unit}`;
  const worktreeBase = join4(process.cwd(), ".haiku", "worktrees", slug);
  const worktreePath = join4(worktreeBase, unit);
  try {
    if (existsSync2(worktreePath)) {
      return worktreePath;
    }
    mkdirSync2(worktreeBase, { recursive: true });
    tryRun(["git", "branch", unitBranch, intentBranch]);
    run(["git", "worktree", "add", worktreePath, unitBranch]);
    return worktreePath;
  } catch {
    return null;
  }
}
function mergeUnitWorktree(slug, unit) {
  const intentBranch = `haiku/${slug}/main`;
  const unitBranch = `haiku/${slug}/${unit}`;
  const worktreePath = join4(process.cwd(), ".haiku", "worktrees", slug, unit);
  try {
    if (!existsSync2(worktreePath)) {
      return { success: true, message: "no worktree" };
    }
    tryRun(["git", "-C", worktreePath, "add", "-A"]);
    tryRun(["git", "-C", worktreePath, "commit", "-m", `haiku: complete ${unit}`, "--allow-empty"]);
    if (getCurrentBranch() !== intentBranch) {
      run(["git", "checkout", intentBranch]);
    }
    run(["git", "merge", unitBranch, "--no-edit", "-m", `haiku: merge ${unit}`]);
    tryRun(["git", "worktree", "remove", worktreePath, "--force"]);
    tryRun(["git", "branch", "-d", unitBranch]);
    return { success: true, message: `merged ${unitBranch}` };
  } catch (err) {
    return { success: false, message: err instanceof Error ? err.message : String(err) };
  }
}
var init_git_worktree = __esm({
  "src/git-worktree.ts"() {
    "use strict";
  }
});

// src/state-tools.ts
import { execFileSync as execFileSync2 } from "node:child_process";
import { existsSync as existsSync3, mkdirSync as mkdirSync3, readFileSync as readFileSync2, readdirSync, writeFileSync as writeFileSync2 } from "node:fs";
import { join as join5, resolve as resolve2 } from "node:path";
function findHaikuRoot() {
  let dir = process.cwd();
  for (let i = 0; i < 20; i++) {
    if (existsSync3(join5(dir, ".haiku"))) return join5(dir, ".haiku");
    const parent = join5(dir, "..");
    if (parent === dir) break;
    dir = parent;
  }
  throw new Error("No .haiku/ directory found");
}
function intentDir(slug) {
  return join5(findHaikuRoot(), "intents", slug);
}
function stageDir(slug, stage) {
  return join5(intentDir(slug), "stages", stage);
}
function unitPath(slug, stage, unit) {
  const name = unit.endsWith(".md") ? unit : `${unit}.md`;
  return join5(stageDir(slug, stage), "units", name);
}
function stageStatePath(slug, stage) {
  return join5(stageDir(slug, stage), "state.json");
}
function normalizeDates(data) {
  const result = { ...data };
  for (const key in result) {
    if (result[key] instanceof Date) {
      result[key] = result[key].toISOString().split("T")[0];
    }
  }
  return result;
}
function parseFrontmatter(raw) {
  const { data, content } = (0, import_gray_matter2.default)(raw);
  return { data: normalizeDates(data), body: content.trim() };
}
function setFrontmatterField(filePath, field, value) {
  const raw = readFileSync2(filePath, "utf8");
  const parsed = (0, import_gray_matter2.default)(raw);
  parsed.data[field] = value;
  writeFileSync2(filePath, import_gray_matter2.default.stringify(parsed.content, normalizeDates(parsed.data)));
}
function parseYaml(raw) {
  const { data } = (0, import_gray_matter2.default)(`---
${raw}
---
`);
  return normalizeDates(data);
}
function getNestedField(obj, path) {
  const parts = path.split(".");
  let current = obj;
  for (const part of parts) {
    if (current == null || typeof current !== "object") return void 0;
    current = current[part];
  }
  return current;
}
function readJson(path) {
  if (!existsSync3(path)) return {};
  return JSON.parse(readFileSync2(path, "utf8"));
}
function writeJson(path, data) {
  mkdirSync3(join5(path, ".."), { recursive: true });
  writeFileSync2(path, JSON.stringify(data, null, 2) + "\n");
}
function timestamp() {
  return (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
}
function gitCommitState(message) {
  try {
    const haikuRoot = findHaikuRoot();
    execFileSync2("git", ["add", haikuRoot], { encoding: "utf8", stdio: "pipe" });
    execFileSync2("git", ["commit", "-m", message, "--allow-empty"], { encoding: "utf8", stdio: "pipe" });
  } catch {
  }
}
function resolveStageHats(intent, stage) {
  try {
    const root = findHaikuRoot();
    const intentFile = join5(root, "intents", intent, "intent.md");
    if (!existsSync3(intentFile)) return [];
    const { data } = parseFrontmatter(readFileSync2(intentFile, "utf8"));
    const studio = data.studio || "";
    if (!studio) return [];
    const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT || "";
    for (const base of [join5(process.cwd(), ".haiku", "studios"), join5(pluginRoot, "studios")]) {
      const stageFile = join5(base, studio, "stages", stage, "STAGE.md");
      if (!existsSync3(stageFile)) continue;
      const { data: stageFm } = parseFrontmatter(readFileSync2(stageFile, "utf8"));
      return stageFm.hats || [];
    }
  } catch {
  }
  return [];
}
function resolveAllowedUnitTypes(intent, stage) {
  try {
    const root = findHaikuRoot();
    const intentFile = join5(root, "intents", intent, "intent.md");
    if (!existsSync3(intentFile)) return [];
    const { data } = parseFrontmatter(readFileSync2(intentFile, "utf8"));
    const studio = data.studio || "";
    if (!studio) return [];
    const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT || "";
    for (const base of [join5(process.cwd(), ".haiku", "studios"), join5(pluginRoot, "studios")]) {
      const stageFile = join5(base, studio, "stages", stage, "STAGE.md");
      if (!existsSync3(stageFile)) continue;
      const { data: stageFm } = parseFrontmatter(readFileSync2(stageFile, "utf8"));
      return stageFm.unit_types || [];
    }
  } catch {
  }
  return [];
}
function resolveStageScope(intent, stage) {
  try {
    const root = findHaikuRoot();
    const intentFile = join5(root, "intents", intent, "intent.md");
    if (!existsSync3(intentFile)) return "";
    const { data } = parseFrontmatter(readFileSync2(intentFile, "utf8"));
    const studio = data.studio || "";
    if (!studio) return "";
    const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT || "";
    for (const base of [join5(process.cwd(), ".haiku", "studios"), join5(pluginRoot, "studios")]) {
      const stageFile = join5(base, studio, "stages", stage, "STAGE.md");
      if (!existsSync3(stageFile)) continue;
      const raw = readFileSync2(stageFile, "utf8");
      const fm = parseFrontmatter(raw);
      const { content } = (0, import_gray_matter2.default)(raw);
      const desc = fm.data.description || stage;
      const unitTypes = fm.data.unit_types || [];
      return `[stage_scope] ${stage}: ${desc}` + (unitTypes.length > 0 ? ` | unit_types: ${unitTypes.join(", ")}` : "") + ` | ${content.trim().slice(0, 500)}`;
    }
  } catch {
  }
  return "";
}
function syncSessionMetadata(intent, stateFile) {
  if (!stateFile) return;
  try {
    const root = findHaikuRoot();
    const intentFile = join5(root, "intents", intent, "intent.md");
    if (!existsSync3(intentFile)) return;
    const { data: intentData } = parseFrontmatter(readFileSync2(intentFile, "utf8"));
    const studio = intentData.studio || "";
    const activeStage2 = intentData.active_stage || "";
    let phase = "";
    if (activeStage2) {
      const sf = stageStatePath(intent, activeStage2);
      const stageState = readJson(sf);
      phase = stageState.phase || "";
    }
    let activeUnit = null;
    let hat = null;
    let bolt = null;
    if (activeStage2) {
      const unitsDir = join5(stageDir(intent, activeStage2), "units");
      if (existsSync3(unitsDir)) {
        for (const f of readdirSync(unitsDir).filter((f2) => f2.endsWith(".md"))) {
          const { data: unitData } = parseFrontmatter(readFileSync2(join5(unitsDir, f), "utf8"));
          if (unitData.status === "active") {
            activeUnit = f.replace(".md", "");
            hat = unitData.hat || null;
            bolt = unitData.bolt || null;
            break;
          }
        }
      }
    }
    let stageDescription = activeStage2;
    let stageUnitTypes = [];
    if (studio && activeStage2) {
      const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT || "";
      for (const base of [join5(process.cwd(), ".haiku", "studios"), join5(pluginRoot, "studios")]) {
        const sf = join5(base, studio, "stages", activeStage2, "STAGE.md");
        if (!existsSync3(sf)) continue;
        const { data: stageFm } = parseFrontmatter(readFileSync2(sf, "utf8"));
        stageDescription = stageFm.description || activeStage2;
        stageUnitTypes = stageFm.unit_types || [];
        break;
      }
    }
    writeHaikuMetadata(stateFile, {
      intent,
      studio,
      active_stage: activeStage2,
      phase,
      active_unit: activeUnit,
      hat,
      bolt,
      stage_description: stageDescription,
      stage_unit_types: stageUnitTypes,
      updated_at: (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z")
    });
  } catch {
  }
}
function handleStateTool(name, args2) {
  const text = (s) => ({ content: [{ type: "text", text: s }] });
  switch (name) {
    // ── Intent ──
    case "haiku_intent_get": {
      const file = join5(intentDir(args2.slug), "intent.md");
      if (!existsSync3(file)) return text("");
      const { data } = parseFrontmatter(readFileSync2(file, "utf8"));
      const val = data[args2.field];
      return text(val == null ? "" : typeof val === "object" ? JSON.stringify(val) : String(val));
    }
    case "haiku_intent_list": {
      const root = findHaikuRoot();
      const intentsDir = join5(root, "intents");
      if (!existsSync3(intentsDir)) return text("[]");
      const slugs = readdirSync(intentsDir).filter((d) => existsSync3(join5(intentsDir, d, "intent.md")));
      const intents = slugs.map((slug) => {
        const { data } = parseFrontmatter(readFileSync2(join5(intentsDir, slug, "intent.md"), "utf8"));
        return { slug, studio: data.studio, status: data.status, active_stage: data.active_stage };
      });
      return text(JSON.stringify(intents, null, 2));
    }
    // ── Stage ──
    case "haiku_stage_get": {
      const path = stageStatePath(args2.intent, args2.stage);
      const data = readJson(path);
      const val = data[args2.field];
      return text(val == null ? "" : String(val));
    }
    // ── Unit ──
    case "haiku_unit_get": {
      const path = unitPath(args2.intent, args2.stage, args2.unit);
      if (!existsSync3(path)) return text("");
      const { data } = parseFrontmatter(readFileSync2(path, "utf8"));
      const val = data[args2.field];
      return text(val == null ? "" : typeof val === "object" ? JSON.stringify(val) : String(val));
    }
    case "haiku_unit_set": {
      const path = unitPath(args2.intent, args2.stage, args2.unit);
      setFrontmatterField(path, args2.field, args2.value);
      return text("ok");
    }
    case "haiku_unit_list": {
      const dir = join5(stageDir(args2.intent, args2.stage), "units");
      if (!existsSync3(dir)) return text("[]");
      const files = readdirSync(dir).filter((f) => f.endsWith(".md"));
      const units = files.map((f) => {
        const { data } = parseFrontmatter(readFileSync2(join5(dir, f), "utf8"));
        return { name: f.replace(".md", ""), status: data.status, bolt: data.bolt, hat: data.hat };
      });
      return text(JSON.stringify(units, null, 2));
    }
    case "haiku_unit_start": {
      const uPath = unitPath(args2.intent, args2.stage, args2.unit);
      if (existsSync3(uPath)) {
        const { data: unitFm } = parseFrontmatter(readFileSync2(uPath, "utf8"));
        const unitType = unitFm.type || "";
        if (unitType) {
          const allowedTypes = resolveAllowedUnitTypes(args2.intent, args2.stage);
          if (allowedTypes.length > 0 && !allowedTypes.includes(unitType)) {
            return text(JSON.stringify({
              error: "unit_type_not_allowed",
              unit_type: unitType,
              allowed_types: allowedTypes,
              message: `Unit type '${unitType}' is not allowed in stage '${args2.stage}'. Allowed types: ${allowedTypes.join(", ")}. Convert to knowledge for downstream stages, then call haiku_run_next again.`
            }));
          }
        }
      }
      setFrontmatterField(uPath, "status", "active");
      setFrontmatterField(uPath, "bolt", 1);
      setFrontmatterField(uPath, "hat", args2.hat);
      setFrontmatterField(uPath, "started_at", timestamp());
      emitTelemetry("haiku.unit.started", { intent: args2.intent, stage: args2.stage, unit: args2.unit, hat: args2.hat });
      const sf = args2.state_file;
      if (sf) logSessionEvent(sf, { event: "unit_started", intent: args2.intent, stage: args2.stage, unit: args2.unit, hat: args2.hat });
      gitCommitState(`haiku: start unit ${args2.unit}`);
      syncSessionMetadata(args2.intent, args2.state_file);
      const scope = resolveStageScope(args2.intent, args2.stage);
      return text(scope ? `ok

${scope}` : "ok");
    }
    case "haiku_unit_complete": {
      const path = unitPath(args2.intent, args2.stage, args2.unit);
      const unitRaw = readFileSync2(path, "utf8");
      const { data: unitFm } = parseFrontmatter(unitRaw);
      const currentHat = unitFm.hat || "";
      const stageHats = resolveStageHats(args2.intent, args2.stage);
      if (stageHats.length > 0) {
        if (!currentHat) {
          return text(JSON.stringify({ error: "hat_sequence_incomplete", current_hat: "", remaining_hats: stageHats, message: `Cannot complete unit: hat sequence never started. Start with the first hat: "${stageHats[0]}".` }));
        }
        const hatIdx = stageHats.indexOf(currentHat);
        const isLastHat = hatIdx === stageHats.length - 1;
        if (!isLastHat) {
          const sf = args2.state_file;
          if (sf) logSessionEvent(sf, { event: "hat_sequence_incomplete", intent: args2.intent, stage: args2.stage, unit: args2.unit, current_hat: currentHat, expected_last: stageHats[stageHats.length - 1] });
          return text(JSON.stringify({ error: "hat_sequence_incomplete", current_hat: currentHat, remaining_hats: stageHats.slice(hatIdx + 1), message: `Cannot complete unit: hat sequence not finished. Current hat: "${currentHat}", remaining: ${stageHats.slice(hatIdx + 1).join(" \u2192 ")}. Advance through all hats before completing.` }));
        }
      }
      const unchecked = (unitRaw.match(/- \[ \]/g) || []).length;
      if (unchecked > 0) {
        const sf = args2.state_file;
        if (sf) logSessionEvent(sf, { event: "criteria_not_met", intent: args2.intent, stage: args2.stage, unit: args2.unit, unchecked });
        return text(JSON.stringify({ error: "criteria_not_met", unchecked, message: `Cannot complete unit: ${unchecked} completion criteria still unchecked. Address them, then call haiku_unit_complete again.` }));
      }
      const unitOutputs = unitFm.outputs || [];
      if (unitOutputs.length > 0) {
        const iDir = intentDir(args2.intent);
        const escaped = unitOutputs.filter((o) => {
          const resolved = resolve2(iDir, o);
          return !resolved.startsWith(resolve2(iDir) + "/");
        });
        if (escaped.length > 0) {
          return text(JSON.stringify({ error: "unit_outputs_escaped", escaped, message: `Cannot complete unit: ${escaped.length} output path(s) escape the intent directory: ${escaped.join(", ")}. Fix the outputs in the unit frontmatter.` }));
        }
        const missing = unitOutputs.filter((o) => {
          const resolved = resolve2(iDir, o);
          if (!resolved.startsWith(resolve2(iDir) + "/")) return false;
          return !existsSync3(resolved);
        });
        if (missing.length > 0) {
          const sf = args2.state_file;
          if (sf) logSessionEvent(sf, { event: "outputs_missing", intent: args2.intent, stage: args2.stage, unit: args2.unit, missing });
          return text(JSON.stringify({ error: "unit_outputs_missing", missing, message: `Cannot complete unit: ${missing.length} declared output(s) not found: ${missing.join(", ")}. Create them, then call haiku_unit_complete again.` }));
        }
      }
      setFrontmatterField(path, "status", "completed");
      setFrontmatterField(path, "completed_at", timestamp());
      emitTelemetry("haiku.unit.completed", { intent: args2.intent, stage: args2.stage, unit: args2.unit });
      {
        const sf = args2.state_file;
        if (sf) logSessionEvent(sf, { event: "unit_completed", intent: args2.intent, stage: args2.stage, unit: args2.unit });
      }
      gitCommitState(`haiku: complete unit ${args2.unit}`);
      const mergeResult = mergeUnitWorktree(args2.intent, args2.unit);
      if (!mergeResult.success) {
        return text(JSON.stringify({ status: "completed_merge_failed", message: mergeResult.message }));
      }
      syncSessionMetadata(args2.intent, args2.state_file);
      return text(mergeResult.message === "no worktree" ? "ok" : `ok (${mergeResult.message})`);
    }
    case "haiku_unit_advance_hat": {
      const advPath = unitPath(args2.intent, args2.stage, args2.unit);
      const nextHat = args2.hat;
      setFrontmatterField(advPath, "hat", nextHat);
      {
        const sf = args2.state_file;
        if (sf) logSessionEvent(sf, { event: "hat_advanced", intent: args2.intent, stage: args2.stage, unit: args2.unit, hat: nextHat });
      }
      emitTelemetry("haiku.hat.transition", { intent: args2.intent, stage: args2.stage, unit: args2.unit, hat: nextHat });
      gitCommitState(`haiku: advance hat to ${nextHat} on ${args2.unit}`);
      syncSessionMetadata(args2.intent, args2.state_file);
      const hatScope = resolveStageScope(args2.intent, args2.stage);
      return text(hatScope ? `advanced to ${nextHat}

${hatScope}` : `advanced to ${nextHat}`);
    }
    case "haiku_unit_fail": {
      const failPath = unitPath(args2.intent, args2.stage, args2.unit);
      const { data: failData } = parseFrontmatter(readFileSync2(failPath, "utf8"));
      const currentHat = failData.hat || "";
      const currentBolt = failData.bolt || 1;
      const MAX_BOLTS_FAIL = 5;
      if (currentBolt + 1 > MAX_BOLTS_FAIL) {
        return text(JSON.stringify({ error: "max_bolts_exceeded", bolt: currentBolt, max: MAX_BOLTS_FAIL, message: `Unit has exceeded ${MAX_BOLTS_FAIL} bolt iterations. Escalate to the user \u2014 this unit may need to be redesigned or split.` }));
      }
      const stageHats = resolveStageHats(args2.intent, args2.stage);
      const hatIdx = stageHats.indexOf(currentHat);
      const prevHat = hatIdx > 0 ? stageHats[hatIdx - 1] : stageHats[0];
      setFrontmatterField(failPath, "hat", prevHat);
      setFrontmatterField(failPath, "bolt", currentBolt + 1);
      {
        const sf = args2.state_file;
        if (sf) logSessionEvent(sf, { event: "unit_failed", intent: args2.intent, stage: args2.stage, unit: args2.unit, from_hat: currentHat, to_hat: prevHat, bolt: currentBolt + 1 });
      }
      emitTelemetry("haiku.unit.failed", { intent: args2.intent, stage: args2.stage, unit: args2.unit, hat: currentHat, prev_hat: prevHat, bolt: String(currentBolt + 1) });
      gitCommitState(`haiku: fail ${args2.unit} \u2014 back to ${prevHat}, bolt ${currentBolt + 1}`);
      syncSessionMetadata(args2.intent, args2.state_file);
      return text(`failed \u2014 back to ${prevHat}, bolt ${currentBolt + 1}`);
    }
    case "haiku_unit_increment_bolt": {
      const path = unitPath(args2.intent, args2.stage, args2.unit);
      const { data } = parseFrontmatter(readFileSync2(path, "utf8"));
      const current = data.bolt || 0;
      const MAX_BOLTS_INC = 5;
      if (current + 1 > MAX_BOLTS_INC) {
        return text(JSON.stringify({ error: "max_bolts_exceeded", bolt: current, max: MAX_BOLTS_INC, message: `Unit has exceeded ${MAX_BOLTS_INC} bolt iterations. Escalate to the user \u2014 this unit may need to be redesigned or split.` }));
      }
      setFrontmatterField(path, "bolt", current + 1);
      emitTelemetry("haiku.bolt.iteration", { intent: args2.intent, stage: args2.stage, unit: args2.unit, bolt: String(current + 1) });
      return text(String(current + 1));
    }
    // ── Knowledge ──
    case "haiku_knowledge_list": {
      const dir = join5(intentDir(args2.intent), "knowledge");
      if (!existsSync3(dir)) return text("[]");
      const files = readdirSync(dir).filter((f) => f.endsWith(".md"));
      return text(JSON.stringify(files));
    }
    case "haiku_knowledge_read": {
      const path = join5(intentDir(args2.intent), "knowledge", args2.name);
      if (!existsSync3(path)) return text("");
      return text(readFileSync2(path, "utf8"));
    }
    // ── Studio ──
    case "haiku_studio_list": {
      const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT || "";
      const studios = /* @__PURE__ */ new Map();
      const builtinDir = join5(pluginRoot, "studios");
      if (existsSync3(builtinDir)) {
        for (const name2 of readdirSync(builtinDir)) {
          const studioFile = join5(builtinDir, name2, "STUDIO.md");
          if (existsSync3(studioFile)) {
            const { data, body } = parseFrontmatter(readFileSync2(studioFile, "utf8"));
            studios.set(name2, { name: name2, ...data, body: body.slice(0, 200) });
          }
        }
      }
      try {
        const projectDir = join5(findHaikuRoot(), "studios");
        if (existsSync3(projectDir)) {
          for (const name2 of readdirSync(projectDir)) {
            const studioFile = join5(projectDir, name2, "STUDIO.md");
            if (existsSync3(studioFile)) {
              const { data, body } = parseFrontmatter(readFileSync2(studioFile, "utf8"));
              studios.set(name2, { name: name2, ...data, body: body.slice(0, 200), source: "project" });
            }
          }
        }
      } catch {
      }
      return text(JSON.stringify([...studios.values()], null, 2));
    }
    case "haiku_studio_get": {
      const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT || "";
      const studioName = args2.studio;
      let studioFile = "";
      try {
        studioFile = join5(findHaikuRoot(), "studios", studioName, "STUDIO.md");
      } catch {
      }
      if (!studioFile || !existsSync3(studioFile)) {
        studioFile = join5(pluginRoot, "studios", studioName, "STUDIO.md");
      }
      if (!existsSync3(studioFile)) return text("");
      const raw = readFileSync2(studioFile, "utf8");
      const { data, body } = parseFrontmatter(raw);
      return text(JSON.stringify({ ...data, body }, null, 2));
    }
    case "haiku_studio_stage_get": {
      const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT || "";
      const stName = args2.studio;
      const sgName = args2.stage;
      let stageFile = "";
      try {
        stageFile = join5(findHaikuRoot(), "studios", stName, "stages", sgName, "STAGE.md");
      } catch {
      }
      if (!stageFile || !existsSync3(stageFile)) {
        stageFile = join5(pluginRoot, "studios", stName, "stages", sgName, "STAGE.md");
      }
      if (!existsSync3(stageFile)) return text("");
      const raw = readFileSync2(stageFile, "utf8");
      const { data, body } = parseFrontmatter(raw);
      return text(JSON.stringify({ ...data, body }, null, 2));
    }
    // ── Settings ──
    case "haiku_settings_get": {
      const field = args2.field;
      let settingsPath = "";
      try {
        settingsPath = join5(findHaikuRoot(), "settings.yml");
      } catch {
      }
      if (!settingsPath || !existsSync3(settingsPath)) return text("");
      const raw = readFileSync2(settingsPath, "utf8");
      const settings = parseYaml(raw);
      const val = getNestedField(settings, field);
      if (val == null) return text("");
      return text(typeof val === "object" ? JSON.stringify(val) : String(val));
    }
    default:
      return text(`Unknown tool: ${name}`);
  }
}
