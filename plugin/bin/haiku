async function runMigrate(args2) {
  const dryRun = args2.includes("--dry-run");
  const cwd = process.cwd();
  const oldDir = join22(cwd, ".ai-dlc");
  const newDir = join22(cwd, ".haiku", "intents");
  if (!existsSync17(oldDir)) {
    console.log("No .ai-dlc/ directory found. Nothing to migrate.");
    return;
  }
  const entries = readdirSync13(oldDir).filter((d) => {
    const path = join22(oldDir, d);
    return existsSync17(join22(path, "intent.md"));
  });
  if (entries.length === 0) {
    console.log("No intents found in .ai-dlc/. Nothing to migrate.");
    return;
  }
  const passSuffixes = ["-dev", "-product", "-design", "-tests"];
  const mergeMap = /* @__PURE__ */ new Map();
  const mergedSlugs = /* @__PURE__ */ new Set();
  const followupSuffixes = ["-followup", "-v2", "-phase2"];
  const followsMap = /* @__PURE__ */ new Map();
  for (const slug of entries) {
    for (const suffix of passSuffixes) {
      if (slug.endsWith(suffix)) {
        const base = slug.slice(0, -suffix.length);
        if (entries.includes(base)) {
          if (!mergeMap.has(base)) mergeMap.set(base, []);
          mergeMap.get(base).push(slug);
          mergedSlugs.add(slug);
        }
      }
    }
  }
  for (const slug of entries) {
    if (mergedSlugs.has(slug)) continue;
    for (const suffix of followupSuffixes) {
      if (slug.endsWith(suffix)) {
        const parent = slug.slice(0, -suffix.length);
        if (entries.includes(parent)) {
          followsMap.set(slug, parent);
        }
      }
    }
  }
  if (mergeMap.size > 0) {
    console.log(`Detected ${mergeMap.size} multi-pass intent group(s):`);
    for (const [base, related] of mergeMap) {
      console.log(`  ${base} \u2190 [${related.join(", ")}]`);
    }
    console.log();
  }
  if (followsMap.size > 0) {
    console.log(`Detected ${followsMap.size} follow-up intent(s):`);
    for (const [slug, parent] of followsMap) {
      console.log(`  ${slug} follows ${parent}`);
    }
    console.log();
  }
  const primarySlugs = entries.filter((s) => !mergedSlugs.has(s));
  console.log(`Found ${entries.length} intent(s) to migrate (${primarySlugs.length} primary, ${mergedSlugs.size} merged).
`);
  let migrated = 0;
  let skipped = 0;
  for (const slug of primarySlugs) {
    const srcDir = join22(oldDir, slug);
    const destDir = join22(newDir, slug);
    const force = args2.includes("--force");
    if (existsSync17(destDir)) {
      const hasStages = existsSync17(join22(destDir, "stages"));
      if (hasStages && !force) {
        console.log(`  SKIP: ${slug} (already migrated with stages)`);
        skipped++;
        continue;
      }
      if (!hasStages) {
        console.log(`  RE-MIGRATE: ${slug} (missing stages \u2014 upgrading)`);
      }
    }
    const { data: intentFm, body: intentBody } = readFrontmatter2(join22(srcDir, "intent.md"));
    const status = intentFm.status || "active";
    const title = intentBody.match(/^# (.+)$/m)?.[1] || slug;
    const parentSlug = followsMap.get(slug) || "";
    const gitCreated = gitFirstCommitDate(join22(srcDir, "intent.md"));
    const gitLastModified = gitLastCommitDate(srcDir);
    const fmCreated = intentFm.created || "";
    const startedAt = gitCreated || (fmCreated ? `${fmCreated}T00:00:00Z` : timestamp2());
    const completedAt = status === "completed" || status === "complete" ? gitLastModified || startedAt : null;
    if (dryRun) {
      console.log(`  DRY RUN: ${slug} (status: ${status})`);
      migrated++;
      continue;
    }
    mkdirSync6(join22(destDir, "knowledge"), { recursive: true });
    const allStages = ["inception", "design", "product", "development", "operations", "security"];
    const passToStage = {
      design: "design",
      dev: "development",
      product: "product",
      ops: "operations",
      security: "security"
    };
    const sourceDirs = [
      { dir: srcDir, defaultStage: "" }
      // primary — uses pass: field
    ];
    const relatedSlugs = mergeMap.get(slug) || [];
    const suffixToStage = {
      "-dev": "development",
      "-product": "product",
      "-design": "design",
      "-tests": "development"
    };
    for (const related of relatedSlugs) {
      const relatedDir = join22(oldDir, related);
      const suffix = passSuffixes.find((s) => related.endsWith(s)) || "";
      sourceDirs.push({ dir: relatedDir, defaultStage: suffixToStage[suffix] || "development" });
    }
    const unitsByStage = /* @__PURE__ */ new Map();
    let totalUnitCount = 0;
    for (const { dir: sourceDir2, defaultStage } of sourceDirs) {
      const unitFiles = readdirSync13(sourceDir2).filter((f) => f.startsWith("unit-") && f.endsWith(".md"));
      for (const unitFile of unitFiles) {
        const { data: unitFm, body: unitBody } = readFrontmatter2(join22(sourceDir2, unitFile));
        const pass = unitFm.pass || "";
        const stage = pass ? passToStage[pass] || "development" : defaultStage || "development";
        if (!unitsByStage.has(stage)) unitsByStage.set(stage, []);
        unitsByStage.get(stage).push({ file: unitFile, fm: unitFm, body: unitBody });
        totalUnitCount++;
      }
      if (sourceDir2 !== srcDir) {
        if (existsSync17(join22(sourceDir2, "discovery.md"))) {
          const relSlug = basename6(sourceDir2);
          if (!dryRun) {
            cpSync(join22(sourceDir2, "discovery.md"), join22(destDir, "knowledge", `${relSlug}-discovery.md`));
          }
        }
        if (existsSync17(join22(sourceDir2, "mockups")) && !dryRun) {
          const artifactsDir = join22(destDir, "stages", "design", "artifacts");
          mkdirSync6(artifactsDir, { recursive: true });
          try {
            cpSync(join22(sourceDir2, "mockups"), artifactsDir, { recursive: true });
          } catch {
          }
        }
      }
    }
    const activePass = intentFm.active_pass || "";
    const mappedStage = activePass ? passToStage[activePass] || "" : "";
    const epic = intentFm.epic || "";
    if (status === "completed" || status === "complete") {
      writeFileSync6(
        join22(destDir, "intent.md"),
        `---
title: "${title}"
studio: software
stages: [inception, design, product, development, operations, security]
mode: continuous
active_stage: security
status: completed
started_at: ${startedAt}
completed_at: ${completedAt}${epic ? `
epic: ${epic}` : ""}${parentSlug ? `
follows: ${parentSlug}` : ""}
---

${intentBody}
`
      );
      for (const stage of allStages) {
        mkdirSync6(join22(destDir, "stages", stage, "units"), { recursive: true });
        writeFileSync6(
          join22(destDir, "stages", stage, "state.json"),
          JSON.stringify({ stage, status: "completed", phase: "gate", started_at: `${startedAt}`, completed_at: `${completedAt}`, gate_entered_at: null, gate_outcome: "advanced" }, null, 2) + "\n"
        );
      }
      for (const [stage, units] of unitsByStage) {
        mkdirSync6(join22(destDir, "stages", stage, "units"), { recursive: true });
        for (const { file, fm, body } of units) {
          const uStatus = fm.status || "pending";
          const uDeps = fm.depends_on || [];
          const uDiscipline = fm.discipline || "fullstack";
          const uUpdated = fm.last_updated || gitFirstCommitDate(join22(sourceDir, file)) || null;
          const uTicket = fm.ticket || "";
          const uBranch = fm.branch || "";
          writeFileSync6(
            join22(destDir, "stages", stage, "units", file),
            `---
name: ${basename6(file, ".md")}
type: ${uDiscipline}
status: ${uStatus}
depends_on: [${uDeps.join(", ")}]
bolt: 0
hat: ""${uTicket ? `
ticket: ${uTicket}` : ""}${uBranch ? `
branch: ${uBranch}` : ""}
started_at: ${uUpdated || "null"}
completed_at: ${uStatus === "completed" ? uUpdated || "null" : "null"}
---

${body}
`
          );
        }
      }
      const mergeNote = relatedSlugs.length > 0 ? ` [merged: ${relatedSlugs.join(", ")}]` : "";
      console.log(`  MIGRATED: ${slug} (completed, ${totalUnitCount} units across ${unitsByStage.size} stage(s))${mergeNote}`);
    } else {
      const skipStages = allStages.filter((s) => {
        if (!unitsByStage.has(s) && s !== activeStage) return false;
        return false;
      });
      const firstStageWithUnits = allStages.find((s) => unitsByStage.has(s)) || "";
      writeFileSync6(
        join22(destDir, "intent.md"),
        `---
title: "${title}"
studio: software
stages: [inception, design, product, development, operations, security]
mode: continuous
active_stage: ${firstStageWithUnits || '""'}
status: active
started_at: ${startedAt}
completed_at: null${epic ? `
epic: ${epic}` : ""}${parentSlug ? `
follows: ${parentSlug}` : ""}
---

${intentBody}
`
      );
      for (const stage of allStages) {
        mkdirSync6(join22(destDir, "stages", stage, "units"), { recursive: true });
        if (unitsByStage.has(stage)) {
          writeFileSync6(
            join22(destDir, "stages", stage, "state.json"),
            JSON.stringify({
              stage,
              status: stage === firstStageWithUnits ? "active" : "pending",
              phase: stage === firstStageWithUnits ? "execute" : "",
              started_at: startedAt,
              completed_at: null,
              gate_entered_at: null,
              gate_outcome: null
            }, null, 2) + "\n"
          );
        }
      }
      for (const [stage, units] of unitsByStage) {
        for (const { file, fm, body } of units) {
          const uStatus = fm.status || "pending";
          const uDeps = fm.depends_on || [];
          const uDiscipline = fm.discipline || "fullstack";
          const uUpdated = fm.last_updated || gitFirstCommitDate(join22(sourceDir, file)) || null;
          const uTicket = fm.ticket || "";
          const uBranch = fm.branch || "";
          writeFileSync6(
            join22(destDir, "stages", stage, "units", file),
            `---
name: ${basename6(file, ".md")}
type: ${uDiscipline}
status: ${uStatus}
depends_on: [${uDeps.join(", ")}]
bolt: 0
hat: ""${uTicket ? `
ticket: ${uTicket}` : ""}${uBranch ? `
branch: ${uBranch}` : ""}
started_at: ${uUpdated || "null"}
completed_at: ${uStatus === "completed" ? uUpdated || "null" : "null"}
---

${body}
`
          );
        }
      }
      const mergeNoteActive = relatedSlugs.length > 0 ? ` [merged: ${relatedSlugs.join(", ")}]` : "";
      console.log(`  MIGRATED: ${slug} (active, stage: ${activeStage || "inception"}, ${totalUnitCount} units across ${unitsByStage.size} stage(s))${mergeNoteActive}`);
    }
    if (existsSync17(join22(srcDir, "discovery.md"))) {
      cpSync(join22(srcDir, "discovery.md"), join22(destDir, "knowledge", "DISCOVERY.md"));
    }
    if (existsSync17(join22(srcDir, "knowledge"))) {
      try {
        cpSync(join22(srcDir, "knowledge"), join22(destDir, "knowledge"), { recursive: true });
      } catch {
      }
    }
    if (existsSync17(join22(srcDir, "mockups"))) {
      const artifactsDir = join22(destDir, "stages", "design", "artifacts");
      mkdirSync6(artifactsDir, { recursive: true });
      try {
        cpSync(join22(srcDir, "mockups"), artifactsDir, { recursive: true });
      } catch {
      }
    }
    migrated++;
  }
  console.log(`
Migration complete: ${migrated} migrated, ${skipped} skipped.`);
  if (dryRun) {
    console.log("(Dry run \u2014 no files were written. Run without --dry-run to migrate.)");
  } else {
    console.log("\nNext steps:");
    console.log("  git add .haiku/intents/ && git commit -m 'haiku: migrate intents from .ai-dlc/'");
    console.log("  For active intents: run /haiku:run to start from inception");
  }
}
var init_migrate = __esm({
  "src/migrate.ts"() {
    "use strict";
  }
});

// src/main.ts
var [cmd, ...args] = process.argv.slice(2);
if (cmd === "mcp") {
  Promise.resolve().then(() => init_server3());
} else if (cmd === "hook") {
  const hookName = args[0];
  if (!hookName) {
    console.error("Usage: haiku hook <name>");
    process.exit(1);
  }
  Promise.resolve().then(() => (init_hooks(), hooks_exports)).then((m2) => m2.runHook(hookName, args.slice(1))).catch((err) => {
    console.error(`haiku hook ${hookName}: ${err.message}`);
    process.exit(1);
  });
} else if (cmd === "migrate") {
  Promise.resolve().then(() => (init_migrate(), migrate_exports)).then((m2) => m2.runMigrate(args)).catch((err) => {
    console.error(`haiku migrate: ${err.message}`);
    process.exit(1);
  });
} else {
  console.error("Usage: haiku <mcp|hook|migrate> [args...]");
  process.exit(1);
}
