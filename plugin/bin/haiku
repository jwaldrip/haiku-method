import { existsSync as existsSync17, mkdirSync as mkdirSync6, readFileSync as readFileSync15, readdirSync as readdirSync13, writeFileSync as writeFileSync6, cpSync } from "node:fs";
import { join as join22, basename as basename6 } from "node:path";
function readFrontmatter2(filePath) {
  const raw = readFileSync15(filePath, "utf8");
  const match = raw.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);
  if (!match) return { data: {}, body: raw };
  const data = {};
  for (const line of match[1].split("\n")) {
    const kv = line.match(/^([\w][\w-]*):\s*(.*)$/);
    if (kv) {
      const [, k2, v2] = kv;
      if (v2 === "null") data[k2] = null;
      else if (v2 === "true") data[k2] = true;
      else if (v2 === "false") data[k2] = false;
      else if (/^-?\d+$/.test(v2)) data[k2] = parseInt(v2, 10);
      else if (v2.startsWith("[") && v2.endsWith("]")) {
        data[k2] = v2.slice(1, -1).split(",").map((s) => s.trim().replace(/^["']|["']$/g, "")).filter(Boolean);
      } else data[k2] = v2.replace(/^["']|["']$/g, "");
    }
  }
  return { data, body: match[2].trim() };
}
function timestamp2() {
  return (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
}
function gitFirstCommitDate(path) {
  try {
    const { execSync: execSync4 } = __require("node:child_process");
    const result = execSync4(`git log --diff-filter=A --follow --format=%aI -- "${path}" | tail -1`, {
      encoding: "utf8",
      timeout: 5e3,
      cwd: process.cwd()
    }).trim();
    return result || null;
  } catch {
    return null;
  }
}
function gitLastCommitDate(path) {
  try {
