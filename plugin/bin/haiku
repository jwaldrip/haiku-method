// src/prompts/core.ts
import { spawnSync } from "node:child_process";
import { existsSync as existsSync7, readFileSync as readFileSync6, readdirSync as readdirSync5 } from "node:fs";
import { join as join9, resolve as resolve3 } from "node:path";
function resolveIntent(args2) {
  if (args2.intent) {
    validateIdentifier(args2.intent, "intent slug");
    const dir = intentDir(args2.intent);
    if (!existsSync7(join9(dir, "intent.md"))) {
      throw new McpError(ErrorCode.InvalidParams, `Intent not found: ${args2.intent}`);
    }
    return { slug: args2.intent };
  }
  const active = findActiveIntents();
  if (active.length === 0) {
    return { error: singleMessage("No active intent found. Create one with /haiku:new") };
  }
  if (active.length > 1) {
    return { error: singleMessage(`Multiple active intents found: ${active.map((a) => a.slug).join(", ")}. Specify one with the intent argument.`) };
  }
  return { slug: active[0].slug };
}
function readStageDef(studio, stage) {
  validateIdentifier(studio, "studio");
  validateIdentifier(stage, "stage");
  for (const base of studioSearchPaths()) {
    const file = join9(base, studio, "stages", stage, "STAGE.md");
    if (existsSync7(file)) {
      return parseFrontmatter(readFileSync6(file, "utf8"));
    }
  }
  return null;
}
function readHatDefs(studio, stage) {
  validateIdentifier(studio, "studio");
  validateIdentifier(stage, "stage");
  const hats = {};
  const paths = studioSearchPaths();
  for (const base of [...paths].reverse()) {
    const hatsDir = join9(base, studio, "stages", stage, "hats");
    if (!existsSync7(hatsDir)) continue;
    for (const f of readdirSync5(hatsDir).filter((f2) => f2.endsWith(".md"))) {
      const raw = readFileSync6(join9(hatsDir, f), "utf8");
      const { data, body } = parseFrontmatter(raw);
      hats[f.replace(/\.md$/, "")] = {
        content: body,
        agent_type: data.agent_type || void 0,
        model: data.model || void 0,
        raw
      };
    }
  }
  return hats;
}
function readReviewAgentDefs(studio, stage) {
  validateIdentifier(studio, "studio");
  validateIdentifier(stage, "stage");
  const agents = {};
  const paths = studioSearchPaths();
  for (const base of [...paths].reverse()) {
    const agentsDir = join9(base, studio, "stages", stage, "review-agents");
    if (!existsSync7(agentsDir)) continue;
    for (const f of readdirSync5(agentsDir).filter((f2) => f2.endsWith(".md"))) {
      agents[f.replace(/\.md$/, "")] = readFileSync6(join9(agentsDir, f), "utf8");
    }
  }
  return agents;
}
function listStudios2() {
  const seen = /* @__PURE__ */ new Map();
  const paths = studioSearchPaths();
  for (const base of [...paths].reverse()) {
    if (!existsSync7(base)) continue;
    for (const d of readdirSync5(base, { withFileTypes: true })) {
      if (!d.isDirectory()) continue;
      const file = join9(base, d.name, "STUDIO.md");
      if (!existsSync7(file)) continue;
      const { data, body } = parseFrontmatter(readFileSync6(file, "utf8"));
      seen.set(d.name, { name: d.name, data, body });
    }
  }
  return Array.from(seen.values());
}
function buildRunInstructions(slug, studio, action, dir, intentBody) {
  const actionJson = JSON.stringify(action, null, 2);
  const sections = [];
  sections.push(`## Orchestrator Action

\`\`\`json
${actionJson}
\`\`\``);
  switch (action.action) {
    case "start_stage": {
      const stage = action.stage;
      const hats = action.hats || [];
      const stageDef = readStageDef(studio, stage);
      sections.push(`## Stage: ${stage}`);
      sections.push(`Hats: ${hats.join(" -> ")}`);
      if (stageDef) {
        sections.push(`### Stage Definition

${stageDef.body}`);
      }
      if (action.follows) {
        sections.push(
          `### Follow-up Context

This intent follows "${action.follows}". Load parent knowledge artifacts: ${JSON.stringify(action.parent_knowledge)}`
        );
      }
      sections.push(
        `### Instructions

Stage has been started by the orchestrator (status: active, phase: elaborate).

` + (action.follows ? `1. Load parent knowledge via \`haiku_knowledge_read\` for each file in parent_knowledge
2. Call \`haiku_run_next { intent: "${slug}" }\` to get the next action
` : `1. Call \`haiku_run_next { intent: "${slug}" }\` to get the next action
`)
      );
      break;
    }
    case "elaborate": {
      const stage = action.stage;
      const elaboration = action.elaboration || "collaborative";
      const stageDef = readStageDef(studio, stage);
      const unitTypes = stageDef?.data?.unit_types || [];
      sections.push(`## Elaborate: ${stage}`);
      if (stageDef) {
        sections.push(`${stageDef.body}`);
        if (unitTypes.length > 0) sections.push(`**Allowed unit types:** ${unitTypes.join(", ")}`);
        if (stageDef.data.inputs) sections.push(`**Inputs:** ${JSON.stringify(stageDef.data.inputs)}`);
      }
      for (const base of studioSearchPaths()) {
        const discoveryDir = join9(base, studio, "stages", stage, "discovery");
        if (!existsSync7(discoveryDir)) continue;
        for (const f of readdirSync5(discoveryDir).filter((f2) => f2.endsWith(".md"))) {
          sections.push(`### ${f}

${readFileSync6(join9(discoveryDir, f), "utf8")}`);
        }
        break;
      }
      const stageHats = stageDef?.data?.hats || [];
      const isDesignStage = stage.includes("design") || stageHats.some((h) => h.includes("designer") || h.includes("design")) || stageDef?.body && stageDef.body.includes("pick_design_direction");
      if (isDesignStage) {
        sections.push(
          `## Design Provider MCPs

If design provider MCPs are available (look for tools named \`mcp__pencil__*\`, \`mcp__openpencil__*\`, or \`mcp__figma__*\`), use them for wireframe generation instead of raw HTML. Check your available tools list.

These providers offer structured design primitives (components, layout, styling) that produce higher-fidelity wireframes than inline HTML snippets.`
        );
      }
      sections.push(
        `## Scope

All units MUST be within this stage's domain${unitTypes.length > 0 ? ` (${unitTypes.join(", ")})` : ""}. Work belonging to other stages goes in the discovery document, not in units.

## Mechanics

` + (elaboration === "collaborative" ? `Mode: **collaborative** \u2014 you MUST engage the user iteratively before finalizing.

**Use the right tool for the question type:**
- **Open-ended questions** ("tell me about...", clarifications) \u2192 conversation text
- **Multiple choice / A-B-C decisions** (scope, tradeoffs, priorities) \u2192 \`AskUserQuestion\` tool
- **Rich content with markdown** (specs, comparisons, detailed options) \u2192 \`ask_user_visual_question\` MCP tool
- **Design direction choices** (wireframe variants with previews) \u2192 \`pick_design_direction\` MCP tool

Do NOT present structured options as conversation text. Use the appropriate tool.

` : `Mode: **autonomous** \u2014 elaborate independently.

`) + `**Elaboration produces the PLAN, not the deliverables:**
1. Research the problem space and write discovery artifacts to \`knowledge/\`
2. Define units with scope, completion criteria, and dependencies \u2014 NOT the actual work product
   - A unit spec says WHAT will be produced and HOW to verify it
   - The execution phase produces the actual deliverables
   - Do NOT write full specs, schemas, or implementations during elaboration
3. Write unit files to \`.haiku/intents/${slug}/stages/${stage}/units/\`
4. Call \`haiku_run_next { intent: "${slug}" }\` \u2014 the orchestrator validates and opens the review gate`
      );
      try {
        const settingsPath = join9(process.cwd(), ".haiku", "settings.yml");
        if (existsSync7(settingsPath)) {
          const settingsRaw = readFileSync6(settingsPath, "utf8");
          if (settingsRaw.includes("ticketing")) {
            sections.push(
              `## Ticketing Integration

A ticketing provider is configured. During elaboration:
1. Create an epic for this intent (or link to existing one if \`epic:\` is set in intent.md)
2. For each unit created, create a ticket linked to the epic
3. Store ticket key in unit frontmatter: \`ticket: PROJ-123\`
4. Map unit \`depends_on\` to ticket blocked-by relationships
5. Include the H\xB7AI\xB7K\xB7U browse link in ticket descriptions

See ticketing provider instructions for details on content format and status mapping.`
            );
          }
        }
      } catch {
      }
      break;
    }
    case "start_unit":
    case "continue_unit": {
      const stage = action.stage;
      const unit = action.unit || "";
      const hat = action.hat || action.first_hat || "";
      const hats = action.hats || [];
      const bolt = action.bolt || 1;
      const stageDef = readStageDef(studio, stage);
      const unitTypes = stageDef?.data?.unit_types || [];
      const unitFile = join9(dir, "stages", stage, "units", unit.endsWith(".md") ? unit : `${unit}.md`);
      let unitContent = "";
      let unitRefs = [];
      if (existsSync7(unitFile)) {
        const { data, body } = parseFrontmatter(readFileSync6(unitFile, "utf8"));
        unitContent = body;
        unitRefs = data.refs || [];
      }
      const hatDefs = readHatDefs(studio, stage);
      const hatDef = hatDefs[hat];
      const hatContent = hatDef?.content || `No hat definition found for "${hat}"`;
      const hatAgentType = hatDef?.agent_type || "general-purpose";
      const hatModel = hatDef?.model;
      sections.push(`## ${unit} \u2014 hat: ${hat} (${hats.join(" \u2192 ")}) \u2014 bolt ${bolt}`);
      if (stageDef) {
        sections.push(
          `### Stage: ${stage}

${stageDef.body}

**Unit types:** ${unitTypes.length > 0 ? unitTypes.join(", ") : "per stage definition"}. Stay within this stage's scope \u2014 do not produce outputs belonging to other stages.`
        );
      }
      sections.push(`### Unit Spec

${unitContent}`);
      sections.push(`### Hat: ${hat}

${hatContent}`);
      if (unitRefs.length > 0) {
        sections.push(`### Refs`);
        const dirResolved = resolve3(dir);
        for (const ref of unitRefs) {
          const refResolved = resolve3(dir, ref);
          if (!refResolved.startsWith(dirResolved)) continue;
          if (existsSync7(join9(dir, ref))) {
            const content = readFileSync6(join9(dir, ref), "utf8");
            sections.push(`#### ${ref}

${content.slice(0, 2e3)}${content.length > 2e3 ? "\n...(truncated)" : ""}`);
          }
        }
      }
      const worktreePath = action.worktree || "";
      const hatIdx = hats.indexOf(hat);
      const nextHat = hatIdx < hats.length - 1 ? hats[hatIdx + 1] : null;
      const isLastHat = !nextHat;
      const singleUseTeams = ["true", "1"].includes(process.env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS || "");
      sections.push(
        `### Mechanics

**You are the orchestrator.** Spawn ${singleUseTeams ? "a teammate" : "a subagent"} for the "${hat}" hat.
` + (singleUseTeams ? `**Agent Teams enabled** \u2014 use team \`haiku-${slug}\`.
` : "") + `Agent type: \`${hatAgentType}\`${hatModel ? ` | Model: \`${hatModel}\`` : ""}
` + (worktreePath ? `Worktree: \`${worktreePath}\`
` : "") + `
**Subagent prompt must include:**
- The hat definition, unit spec, and refs above
- The stage scope constraint
` + (action.action === "start_unit" ? `- Instruction to call \`haiku_unit_start { intent: "${slug}", stage: "${stage}", unit: "${unit}", hat: "${hat}" }\` first
` : "") + `
**Subagent calls one of these when done:**
` + (isLastHat ? `- **Success:** \`haiku_unit_complete { intent: "${slug}", stage: "${stage}", unit: "${unit}" }\`
` : `- **Success:** \`haiku_unit_advance_hat { intent: "${slug}", stage: "${stage}", unit: "${unit}", hat: "${nextHat}" }\`
`) + `- **Failure:** \`haiku_unit_fail { intent: "${slug}", stage: "${stage}", unit: "${unit}" }\` \u2014 moves back one hat, increments bolt

**After subagent returns:** call \`haiku_run_next { intent: "${slug}" }\``
      );
      if (action.action === "start_unit") {
        try {
          const settingsPath = join9(process.cwd(), ".haiku", "settings.yml");
          if (existsSync7(settingsPath)) {
            const settingsRaw = readFileSync6(settingsPath, "utf8");
            if (settingsRaw.includes("ticketing")) {
              sections.push(
                `### Ticketing

A ticketing provider is configured. If this unit has a \`ticket:\` field in its frontmatter, transition the ticket to "In Progress" when the subagent starts work.

See ticketing provider instructions for status mapping details.`
              );
            }
          }
        } catch {
        }
      }
      break;
    }
    case "start_units": {
      const stage = action.stage;
      const units = action.units || [];
      const hats = action.hats || [];
      const firstHat = action.first_hat || hats[0] || "";
      const stageDef = readStageDef(studio, stage);
      sections.push(`## Parallel: ${units.length} units in ${stage}`);
      if (stageDef) {
        sections.push(`${stageDef.body}

Stay within this stage's scope \u2014 do not produce outputs belonging to other stages.`);
      }
      sections.push(`Hats: ${hats.join(" \u2192 ")}
Units: ${units.join(", ")}`);
      const worktrees = action.worktrees || {};
      const useTeams = ["true", "1"].includes(process.env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS || "");
      const wave = action.wave;
      const totalWaves = action.total_waves;
      sections.push(
        `### Mechanics

` + (wave !== void 0 ? `**Wave ${wave}/${totalWaves ?? "?"}** \u2014 ` : "") + `${units.length} units to run in parallel.
**You are the orchestrator.** Do NOT do unit work yourself.

` + (useTeams ? `**Agent Teams enabled.** Use \`TeamCreate({ team_name: "haiku-${slug}", description: "H\xB7AI\xB7K\xB7U: ${slug}" })\` if not already created. Then spawn teammates via the team for each unit. Each teammate runs the FIRST hat ("${firstHat}") only.

` : `Spawn one Agent subagent per unit. Each subagent runs the FIRST hat ("${firstHat}") only.

`) + `After all ${useTeams ? "teammates" : "subagents"} complete, call \`haiku_run_next\` \u2014 the orchestrator will advance hats or start the next wave.

**Each subagent prompt must include:**
- The hat definition for "${firstHat}"
- The unit spec and refs
- The stage scope constraint
- Instruction to call \`haiku_unit_start\` first

` + units.map((u3) => {
          const wt = worktrees[u3];
          return `- **${u3}**${wt ? ` (worktree: \`${wt}\`)` : ""}: \`haiku_unit_start { intent: "${slug}", stage: "${stage}", unit: "${u3}", hat: "${firstHat}" }\``;
        }).join("\n") + `

After all subagents complete: \`haiku_run_next { intent: "${slug}" }\``
      );
      break;
    }
    case "advance_phase": {
      const stage = action.stage;
      const toPhase = action.to_phase;
      sections.push(
        `## Advance Phase

Phase advanced to "${toPhase}" by the orchestrator.

**Call \`haiku_run_next { intent: "${slug}" }\` immediately.** Do NOT ask the user \u2014 the transition was already approved.`
      );
      break;
    }
    case "review": {
      const stage = action.stage;
      const agents = readReviewAgentDefs(studio, stage);
      sections.push(`## Adversarial Review: ${stage}`);
      if (Object.keys(agents).length > 0) {
        sections.push(`### Review Agents
`);
        for (const [name, content] of Object.entries(agents)) {
          sections.push(`#### ${name}

${content}`);
        }
      }
      sections.push(
        `### Instructions

1. Spawn one subagent per review agent (in parallel), each with the diff and stage outputs
2. Collect findings; if HIGH severity, fix and re-review (up to 3 cycles)
3. Call \`haiku_run_next { intent: "${slug}" }\` \u2014 the orchestrator advances to the gate phase automatically`
      );
      break;
    }
    case "gate_ask": {
      const stage = action.stage;
      const nextStage = action.next_stage;
      sections.push(
        `## Gate: Awaiting Approval

Stage "${stage}" is complete and awaiting your approval to advance` + (nextStage ? ` to "${nextStage}"` : "") + `.

### Instructions

1. Call \`haiku_run_next { intent: "${slug}" }\` \u2014 the orchestrator opens the review UI and blocks until the user responds
2. If approved: the FSM advances automatically
3. If changes_requested: analyze annotations and route to /haiku:refine for the appropriate upstream stage`
      );
      break;
    }
    case "gate_external": {
      const stage = action.stage;
      sections.push(
        `## Gate: External Review

Stage "${stage}" is complete. The gate has been entered by the orchestrator.

### Instructions

1. Push the branch and commit stage artifacts
2. Share the review URL with the reviewer
3. Report: "Awaiting external review. Run /haiku:run when review is complete."`
      );
      break;
    }
    case "gate_await": {
      const stage = action.stage;
      sections.push(
        `## Gate: Awaiting External Event

Stage "${stage}" is complete. The gate has been entered by the orchestrator.

### Instructions

1. Report what is being awaited
2. Stop. Run /haiku:run when the event occurs.`
      );
      break;
    }
    case "advance_stage": {
      const stage = action.stage;
      const nextStage = action.next_stage;
      sections.push(
        `## Advance Stage

Gate passed. The orchestrator has advanced from "${stage}" to "${nextStage}".

**Call \`haiku_run_next { intent: "${slug}" }\` immediately.** Do NOT ask the user for confirmation \u2014 the gate was already approved. Do NOT present summaries or ask "want me to continue?" \u2014 just call the tool.`
      );
      break;
    }
    case "stage_complete_discrete": {
      const stage = action.stage;
      const nextStage = action.next_stage;
      sections.push(
        `## Stage Complete (Discrete Mode)

Stage "${stage}" has been completed by the orchestrator.

### Instructions

Report: "Stage complete. Run /haiku:run to start '${nextStage}'."`
      );
      break;
    }
    case "intent_complete": {
      sections.push(
        `## Intent Complete

All stages are done for intent "${slug}". The orchestrator has marked it as completed.

### Instructions

Report completion summary. Suggest /haiku:review then PR creation.`
      );
      break;
    }
    case "blocked": {
      const blockedUnits = action.blocked_units || [];
      sections.push(
        `## Blocked

Units are blocked: ${blockedUnits.join(", ")}

### Instructions

Report which units are blocked and why. Ask the user for guidance.`
      );
      break;
    }
    case "composite_run_stage": {
      const stage = action.stage;
      const compositeStudio = action.studio;
      const hats = action.hats || [];
      sections.push(
        `## Composite: Run ${compositeStudio}:${stage}

Hats: ${hats.join(" -> ")}

Follow the same instructions as start_stage, but for this composite studio:stage pair.

Call \`haiku_run_next { intent: "${slug}" }\` to continue.`
      );
      break;
    }
    case "outputs_missing": {
      sections.push(`## Missing Required Outputs

${action.message}`);
      break;
    }
    case "elaboration_insufficient": {
      sections.push(`## Elaboration Insufficient

${action.message}`);
      break;
    }
    case "spec_validation_failed": {
      sections.push(`## Spec Validation Failed

${action.message}`);
      break;
    }
    case "review_elaboration": {
      const stage = action.stage;
      const agents = readReviewAgentDefs(studio, stage);
      sections.push(`## Review Elaboration Artifacts

`);
      sections.push(`Run adversarial review agents on the elaboration specs before the pre-execution gate opens.

`);
      if (Object.keys(agents).length > 0) {
        sections.push(`### Review Agents
`);
        for (const [name, content] of Object.entries(agents)) {
          sections.push(`#### ${name}

${content}`);
        }
      }
      sections.push(
        `### Mechanics

1. Spawn one subagent per review agent (in parallel)
2. Each reviews the elaboration specs (units, discovery, knowledge)
3. Fix any HIGH findings
4. Call \`haiku_run_next { intent: "${slug}", elaboration_reviewed: true }\``
      );
      break;
    }
    case "awaiting_external_review": {
      const externalUrl = action.external_review_url || "";
      sections.push(
        `## Awaiting External Review

` + (externalUrl ? `The stage is awaiting external review at: ${externalUrl}

` : `The stage is awaiting external review but no review URL has been recorded.

`) + `Ask the user for the status of the external review. If approved, call \`haiku_run_next { intent: "${slug}" }\` \u2014 the FSM will detect the approval and advance.

` + (externalUrl ? "" : `If the user provides a review URL, pass it: \`haiku_run_next { intent: "${slug}", external_review_url: "<url>" }\`
`)
      );
      break;
    }
    case "design_direction_required": {
      sections.push(
        `## Design Direction Required

This stage requires wireframe variants before proceeding.

1. Generate 2-3 distinct design approaches as HTML wireframe snippets
2. Call \`pick_design_direction\` with the variants
3. After the user selects a direction, call \`haiku_run_next { intent: "${slug}", design_direction_selected: true }\`

Check for design provider MCPs (\`mcp__pencil__*\`, \`mcp__openpencil__*\`) and use them if available.`
      );
      break;
    }
    case "discovery_missing": {
      sections.push(`## Missing Discovery Artifacts

${action.message}`);
      break;
    }
    case "dag_cycle_detected": {
      sections.push(`## Circular Dependency Detected

${action.message}`);
      break;
    }
    case "error": {
      sections.push(`## Error

${action.message}`);
      break;
    }
    case "complete": {
      sections.push(`## Already Complete

${action.message}`);
      break;
    }
    default: {
      sections.push(`## Unknown Action: ${action.action}

${JSON.stringify(action, null, 2)}`);
      break;
    }
  }
  return sections.join("\n\n");
}
