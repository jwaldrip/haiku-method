// src/hooks/prompt-guard.ts
async function promptGuard(input, _pluginRoot) {
  const toolName = input.tool_name;
  if (toolName !== "Write" && toolName !== "Edit") return;
  const toolInput = input.tool_input || {};
  const filePath = toolInput.file_path || "";
  if (!filePath.includes("/.haiku/")) return;
  const content = toolInput.content || toolInput.new_string || "";
  if (INJECTION_PATTERNS.test(content)) {
    process.stdout.write(
      `\u26A0\uFE0F PROMPT GUARD: Potential injection pattern detected in spec file write to ${filePath}
Review the content before proceeding.
`
    );
  }
}
var INJECTION_PATTERNS;
var init_prompt_guard = __esm({
  "src/hooks/prompt-guard.ts"() {
    "use strict";
    INJECTION_PATTERNS = /ignore previous|disregard|override instructions|you are now|system prompt|<system>|<\/system>/i;
  }
});

// src/hooks/workflow-guard.ts
import { existsSync as existsSync3, readdirSync as readdirSync3 } from "node:fs";
import { join as join6 } from "node:path";
function findActiveIntent() {
  const intentsDir = join6(process.cwd(), ".haiku", "intents");
  if (!existsSync3(intentsDir)) return null;
  const dirs = readdirSync3(intentsDir).filter(
    (d) => existsSync3(join6(intentsDir, d, "intent.md"))
  );
  return dirs.length === 1 ? join6(intentsDir, dirs[0]) : null;
}
async function workflowGuard(input, _pluginRoot) {
  const toolName = input.tool_name;
  if (toolName !== "Write" && toolName !== "Edit") return;
  const intentDir2 = findActiveIntent();
  if (!intentDir2) return;
  const toolInput = input.tool_input || {};
  const filePath = toolInput.file_path || "";
  if (filePath.includes("/.haiku/")) return;
  process.stdout.write(
    `\u26A0\uFE0F WORKFLOW GUARD: Editing ${filePath} \u2014 ensure this is within an active hat's scope.
`
  );
}
var init_workflow_guard = __esm({
  "src/hooks/workflow-guard.ts"() {
    "use strict";
  }
});

// src/hooks/redirect-plan-mode.ts
async function redirectPlanMode(input, _pluginRoot) {
  if (input.tool_name !== "EnterPlanMode") return;
  const response = {
    hookSpecificOutput: {
      hookEventName: "PreToolUse",
      permissionDecision: "deny",
      permissionDecisionReason: "H\xB7AI\xB7K\xB7U: Use /haiku:elaborate instead of plan mode.\n\nThe H\xB7AI\xB7K\xB7U plugin replaces Claude Code's built-in plan mode with a more comprehensive workflow:\n\n**`/haiku:elaborate`** - Structured mob elaboration that:\n- Defines intent and success criteria collaboratively\n- Decomposes work into independent units\n- Creates isolated worktrees for safe iteration\n- Sets up the execution loop with quality gates\n\n**To start:** Run `/haiku:elaborate` with a description of what you want to build."
    }
  };
  process.stdout.write(JSON.stringify(response));
}
var init_redirect_plan_mode = __esm({
  "src/hooks/redirect-plan-mode.ts"() {
    "use strict";
  }
