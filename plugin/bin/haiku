    registerPrompt({
      name: "haiku:seed",
      title: "Seed",
      description: "Plant, track, and surface forward-looking ideas at the right moment",
      arguments: [
        {
          name: "action",
          description: "Subcommand: plant, list, or check",
          required: false
        }
      ],
      handler: async (args2) => {
        const action = args2.action || "list";
