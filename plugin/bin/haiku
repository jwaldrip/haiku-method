        }
      }
      Object.assign(session, { stageStates, knowledgeFiles, stageArtifacts, outputArtifacts });
      session.html = renderReviewPage({ intent, units, criteria, reviewType, target: "", sessionId: session.session_id, mermaid, intentMockups: [], unitMockups: /* @__PURE__ */ new Map() });
      const port = await startHttpServer();
      const reviewUrl = `http://127.0.0.1:${port}/review/${session.session_id}`;
      function openBrowser() {
        try {
          const cmd2 = process.platform === "darwin" ? ["open", reviewUrl] : ["xdg-open", reviewUrl];
          spawn(cmd2[0], cmd2.slice(1), { stdio: "ignore", detached: true }).unref();
        } catch {
        }
      }
      openBrowser();
      for (let attempt = 0; attempt < 3; attempt++) {
        try {
          await waitForSession(session.session_id, 10 * 60 * 1e3);
        } catch {
          const check2 = getSession(session.session_id);
          if (check2 && check2.session_type === "review" && check2.status === "decided") {
            return { decision: check2.decision, feedback: check2.feedback, annotations: check2.annotations };
          }
          if (attempt < 2) {
            console.error(`[haiku] Review session timeout (attempt ${attempt + 1}/3) \u2014 reopening browser`);
            openBrowser();
            continue;
          }
        }
        const updated = getSession(session.session_id);
        if (updated && updated.session_type === "review" && updated.status === "decided") {
          return { decision: updated.decision, feedback: updated.feedback, annotations: updated.annotations };
        }
      }
      throw new Error("Review timeout after 3 attempts (30 min total)");
    });
    setElicitInputHandler(async (params) => {
      return server.elicitInput(params);
    });
    process.on("SIGINT", async () => {
      console.error("Shutting down...");
      await server.close();
      process.exit(0);
    });
    process.on("SIGTERM", async () => {
      console.error("Shutting down...");
      await server.close();
      process.exit(0);
    });
    main().catch((err) => {
      reportError(err, { context: "mcp-server-fatal" });
      console.error("Fatal error:", err);
      process.exit(1);
    });
  }
});

// src/hooks/prompt-guard.ts
async function promptGuard(input, _pluginRoot) {
  const toolName = input.tool_name;
  if (toolName !== "Write" && toolName !== "Edit") return;
  const toolInput = input.tool_input || {};
  const filePath = toolInput.file_path || "";
  if (!filePath.includes("/.haiku/")) return;
  const content = toolInput.content || toolInput.new_string || "";
  if (INJECTION_PATTERNS.test(content)) {
    process.stdout.write(
      `\u26A0\uFE0F PROMPT GUARD: Potential injection pattern detected in spec file write to ${filePath}
Review the content before proceeding.
`
    );
  }
}
var INJECTION_PATTERNS;
var init_prompt_guard = __esm({
  "src/hooks/prompt-guard.ts"() {
    "use strict";
    INJECTION_PATTERNS = /ignore previous|disregard|override instructions|you are now|system prompt|<system>|<\/system>/i;
  }
});

// src/hooks/workflow-guard.ts
import { existsSync as existsSync10, readdirSync as readdirSync8 } from "node:fs";
import { join as join13 } from "node:path";
function findActiveIntent() {
  const intentsDir = join13(process.cwd(), ".haiku", "intents");
  if (!existsSync10(intentsDir)) return null;
  const dirs = readdirSync8(intentsDir).filter(
    (d) => existsSync10(join13(intentsDir, d, "intent.md"))
  );
  return dirs.length === 1 ? join13(intentsDir, dirs[0]) : null;
}
async function workflowGuard(input, _pluginRoot) {
  const toolName = input.tool_name;
  if (toolName !== "Write" && toolName !== "Edit") return;
  const intentDir3 = findActiveIntent();
  if (!intentDir3) return;
  const toolInput = input.tool_input || {};
  const filePath = toolInput.file_path || "";
  if (filePath.includes("/.haiku/")) return;
  process.stdout.write(
    `\u26A0\uFE0F WORKFLOW GUARD: Editing ${filePath} \u2014 ensure this is within an active hat's scope.
`
  );
}
var init_workflow_guard = __esm({
  "src/hooks/workflow-guard.ts"() {
    "use strict";
  }
});

// src/hooks/redirect-plan-mode.ts
async function redirectPlanMode(input, _pluginRoot) {
  if (input.tool_name !== "EnterPlanMode") return;
  const response = {
    hookSpecificOutput: {
      hookEventName: "PreToolUse",
      permissionDecision: "deny",
      permissionDecisionReason: "H\xB7AI\xB7K\xB7U: Use /haiku:new instead of plan mode.\n\nThe H\xB7AI\xB7K\xB7U plugin replaces Claude Code's built-in plan mode with a more comprehensive workflow:\n\n**`/haiku:new`** - Start a new intent that:\n- Defines intent and success criteria collaboratively\n- Decomposes work into independent units\n- Creates isolated worktrees for safe iteration\n- Sets up the execution loop with quality gates\n\n**To start:** Run `/haiku:new` with a description of what you want to build."
    }
  };
  process.stdout.write(JSON.stringify(response));
}
