import { existsSync as existsSync7, mkdirSync as mkdirSync3, readFileSync as readFileSync6, readdirSync as readdirSync6, writeFileSync as writeFileSync4, cpSync } from "node:fs";
import { join as join10, basename as basename5 } from "node:path";
function readFrontmatter2(filePath) {
  const raw = readFileSync6(filePath, "utf8");
  const match = raw.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);
  if (!match) return { data: {}, body: raw };
  const data = {};
  for (const line of match[1].split("\n")) {
    const kv = line.match(/^([\w][\w-]*):\s*(.*)$/);
    if (kv) {
      const [, k2, v2] = kv;
      if (v2 === "null") data[k2] = null;
      else if (v2 === "true") data[k2] = true;
      else if (v2 === "false") data[k2] = false;
      else if (/^-?\d+$/.test(v2)) data[k2] = parseInt(v2, 10);
      else if (v2.startsWith("[") && v2.endsWith("]")) {
        data[k2] = v2.slice(1, -1).split(",").map((s) => s.trim().replace(/^["']|["']$/g, "")).filter(Boolean);
      } else data[k2] = v2.replace(/^["']|["']$/g, "");
    }
  }
  return { data, body: match[2].trim() };
}
function timestamp2() {
  return (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
}
async function runMigrate(args2) {
  const dryRun = args2.includes("--dry-run");
  const cwd = process.cwd();
  const oldDir = join10(cwd, ".ai-dlc");
  const newDir = join10(cwd, ".haiku", "intents");
  if (!existsSync7(oldDir)) {
    console.log("No .ai-dlc/ directory found. Nothing to migrate.");
    return;
  }
  const entries = readdirSync6(oldDir).filter((d) => {
    const path = join10(oldDir, d);
    return existsSync7(join10(path, "intent.md"));
  });
  if (entries.length === 0) {
    console.log("No intents found in .ai-dlc/. Nothing to migrate.");
    return;
  }
  console.log(`Found ${entries.length} intent(s) to migrate.
`);
  let migrated = 0;
  let skipped = 0;
  for (const slug of entries) {
    const srcDir = join10(oldDir, slug);
    const destDir = join10(newDir, slug);
    if (existsSync7(destDir)) {
      console.log(`  SKIP: ${slug} (already exists in .haiku/intents/)`);
      skipped++;
      continue;
    }
    const { data: intentFm, body: intentBody } = readFrontmatter2(join10(srcDir, "intent.md"));
    const status = intentFm.status || "active";
    const created = intentFm.created || timestamp2().split("T")[0];
    const title = intentBody.match(/^# (.+)$/m)?.[1] || slug;
    if (dryRun) {
      console.log(`  DRY RUN: ${slug} (status: ${status})`);
      migrated++;
      continue;
    }
    mkdirSync3(join10(destDir, "knowledge"), { recursive: true });
    if (status === "completed") {
      mkdirSync3(join10(destDir, "stages", "development", "units"), { recursive: true });
      writeFileSync4(
        join10(destDir, "intent.md"),
        `---
title: "${title}"
studio: software
mode: continuous
active_stage: development
status: completed
started_at: ${created}T00:00:00Z
completed_at: ${created}T23:59:59Z
---

${intentBody}
`
      );
      writeFileSync4(
        join10(destDir, "stages", "development", "state.json"),
        JSON.stringify({ stage: "development", status: "completed", phase: "gate", started_at: `${created}T00:00:00Z`, completed_at: `${created}T23:59:59Z`, gate_entered_at: null, gate_outcome: "advanced" }, null, 2) + "\n"
      );
      const unitFiles = readdirSync6(srcDir).filter((f) => f.startsWith("unit-") && f.endsWith(".md"));
      for (const unitFile of unitFiles) {
        const { data: unitFm, body: unitBody } = readFrontmatter2(join10(srcDir, unitFile));
        const uStatus = unitFm.status || "pending";
        const uDeps = unitFm.depends_on || [];
        const uDiscipline = unitFm.discipline || "fullstack";
        const uUpdated = unitFm.last_updated || null;
        writeFileSync4(
          join10(destDir, "stages", "development", "units", unitFile),
          `---
name: ${basename5(unitFile, ".md")}
type: ${uDiscipline}
status: ${uStatus}
depends_on: [${uDeps.join(", ")}]
bolt: 0
hat: ""
started_at: ${uUpdated || "null"}
completed_at: ${uStatus === "completed" ? uUpdated || "null" : "null"}
---

${unitBody}
`
        );
      }
      console.log(`  MIGRATED: ${slug} (completed, ${unitFiles.length} units)`);
    } else {
      writeFileSync4(
        join10(destDir, "intent.md"),
        `---
title: "${title}"
studio: software
mode: continuous
active_stage: ""
status: active
started_at: ${timestamp2()}
completed_at: null
---

${intentBody}
`
      );
      console.log(`  MIGRATED: ${slug} (active \u2014 reset for fresh start, run /haiku:run)`);
    }
    if (existsSync7(join10(srcDir, "discovery.md"))) {
      cpSync(join10(srcDir, "discovery.md"), join10(destDir, "knowledge", "discovery.md"));
    }
    if (existsSync7(join10(srcDir, "knowledge"))) {
      try {
        cpSync(join10(srcDir, "knowledge"), join10(destDir, "knowledge"), { recursive: true });
      } catch {
      }
    }
    migrated++;
  }
  console.log(`
Migration complete: ${migrated} migrated, ${skipped} skipped.`);
  if (dryRun) {
    console.log("(Dry run \u2014 no files were written. Run without --dry-run to migrate.)");
  } else {
    console.log("\nNext steps:");
    console.log("  git add .haiku/intents/ && git commit -m 'haiku: migrate intents from .ai-dlc/'");
    console.log("  For active intents: run /haiku:run to start from inception");
  }
}
