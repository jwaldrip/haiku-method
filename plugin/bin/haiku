Derive the slug from the description (lowercase, hyphens, max 50 chars).
` + (desc ? `
**Idea:** ${desc}
` : "\nAsk the user for the idea description.\n") + `After creating, confirm: "Added to backlog: {slug} (priority: medium)"`
            );
          }
          case "review": {
            if (!existsSync9(backlogDir)) {
              return singleMessage("Backlog is empty. Use /haiku:backlog add <idea> to add one.");
            }
            const items = readdirSync7(backlogDir).filter((f) => f.endsWith(".md"));
            if (items.length === 0) {
              return singleMessage("Backlog is empty. Use /haiku:backlog add <idea> to add one.");
            }
            const lines = ["## Backlog Review\n\nFor each item, present it and ask the user to:\n- **Keep** \u2014 leave as-is\n- **Reprioritize** \u2014 change priority\n- **Drop** \u2014 delete the item\n- **Promote** \u2014 promote to intent via /haiku:new\n- **Skip** \u2014 move to next\n\n### Items to review:\n"];
            for (const file of items) {
              const raw = readFileSync8(join11(backlogDir, file), "utf8");
              const { data, body } = parseFrontmatter(raw);
              lines.push(`#### ${data.id || file.replace(".md", "")}`);
              lines.push(`Priority: ${data.priority || "medium"} | Tags: ${Array.isArray(data.tags) ? data.tags.join(", ") : "\u2014"} | Created: ${data.created || "\u2014"}`);
              lines.push(body.slice(0, 200));
              lines.push("");
            }
            return singleMessage(lines.join("\n"));
          }
          case "promote": {
            const id = desc;
            return singleMessage(
              `## Promote Backlog Item

` + (id ? `Promote backlog item \`${id}\` to a full intent:

1. Read \`.haiku/backlog/${id}.md\`
2. Confirm with user
3. Run /haiku:new with the item's description
4. Delete the backlog file
5. Confirm: "Promoted ${id} to intent."` : "Specify the item ID to promote. Use /haiku:backlog list to see available items.")
            );
          }
          case "list":
          default: {
            if (!existsSync9(backlogDir)) {
              return singleMessage("Backlog is empty. Use /haiku:backlog add <idea> to add one.");
            }
            const items = readdirSync7(backlogDir).filter((f) => f.endsWith(".md"));
            if (items.length === 0) {
              return singleMessage("Backlog is empty. Use /haiku:backlog add <idea> to add one.");
            }
            const lines = ["## Backlog\n\n| ID | Priority | Tags | Created |\n|---|---|---|---|"];
            for (const file of items) {
              const raw = readFileSync8(join11(backlogDir, file), "utf8");
              const { data } = parseFrontmatter(raw);
              const id = data.id || file.replace(".md", "");
              const priority = data.priority || "medium";
              const tags = Array.isArray(data.tags) ? data.tags.join(", ") : "\u2014";
              const created = data.created || "\u2014";
              lines.push(`| ${id} | ${priority} | ${tags} | ${created} |`);
            }
            return singleMessage(lines.join("\n"));
          }
