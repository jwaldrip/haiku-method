async function handleQuestionImageGet(sessionId, index) {
  const session = getSession(sessionId);
  if (!session || session.session_type !== "question") {
    return new Response("Session not found", { status: 404 });
  }
  const imagePaths = session.imagePaths ?? [];
  if (index < 0 || index >= imagePaths.length) {
    return new Response("Image index out of range", { status: 404 });
  }
  const imagePath = imagePaths[index];
  if (!imagePath.startsWith("/")) {
    return new Response("Forbidden", { status: 403 });
  }
  const allowedBaseDir = session.imageBaseDirs?.[index];
  if (allowedBaseDir) {
    try {
      const realResolved = await realpath(imagePath).catch(() => null);
      const realBase = await realpath(allowedBaseDir).catch(() => resolve(allowedBaseDir));
      if (!realResolved || !realResolved.startsWith(realBase + "/") && realResolved !== realBase) {
        return new Response("Forbidden", { status: 403 });
      }
    } catch {
      return new Response("Forbidden", { status: 403 });
    }
  }
  try {
    const data = await readFile2(imagePath);
    const ext = extname(imagePath).toLowerCase();
    const contentType = MIME_TYPES[ext] ?? "application/octet-stream";
    return new Response(data, {
      headers: { "Content-Type": contentType }
    });
  } catch {
    return new Response("Not found", { status: 404 });
  }
}
function handleQuestionGet(sessionId) {
  const session = getSession(sessionId);
  if (!session || session.session_type !== "question") {
    return new Response("Session not found", { status: 404 });
  }
  return serveSpa();
}
async function handleQuestionAnswerPost(sessionId, req) {
  const session = getSession(sessionId);
  if (!session || session.session_type !== "question") {
    return new Response("Session not found", { status: 404 });
  }
  let body;
  try {
    const QuestionAnswerSchema = external_exports.object({
      answers: external_exports.array(
        external_exports.object({
          question: external_exports.string(),
          selectedOptions: external_exports.array(external_exports.string()),
          otherText: external_exports.string().optional()
        })
      ),
      feedback: external_exports.string().optional(),
      annotations: external_exports.object({
        comments: external_exports.array(
          external_exports.object({
            selectedText: external_exports.string(),
            comment: external_exports.string(),
            paragraph: external_exports.number()
          })
        ).optional()
      }).optional()
    });
    body = QuestionAnswerSchema.parse(await req.json());
  } catch {
    return new Response("Invalid request body", { status: 400 });
  }
  updateQuestionSession(sessionId, {
    status: "answered",
    answers: body.answers,
    feedback: body.feedback ?? "",
    annotations: body.annotations
  });
  return Response.json({ ok: true });
}
