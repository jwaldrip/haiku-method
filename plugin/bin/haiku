// src/telemetry.ts
function parseHeaders(raw) {
  const h = {};
  for (const pair of raw.split(",").filter(Boolean)) {
    const [k2, v2] = pair.split("=", 2);
    if (k2 && v2) h[k2] = v2;
  }
  return h;
}
function parseResourceAttrs(raw) {
  const attrs = [
    { key: "service.name", value: { stringValue: "haiku" } }
  ];
  for (const pair of raw.split(",").filter(Boolean)) {
    const [k2, v2] = pair.split("=", 2);
    if (k2 && v2) attrs.push({ key: k2, value: { stringValue: v2 } });
  }
  return attrs;
}
function emitTelemetry(eventName, attributes = {}) {
  if (!ENABLED) return;
  const timeNanos = `${Date.now()}000000`;
  const logAttrs = [
    { key: "event.name", value: { stringValue: eventName } },
    ...Object.entries(attributes).map(([k2, v2]) => ({
      key: k2,
      value: { stringValue: v2 }
    }))
  ];
  const payload = JSON.stringify({
    resourceLogs: [{
      resource: { attributes: RESOURCE_ATTRS },
      scopeLogs: [{
        scope: { name: "haiku" },
        logRecords: [{
          timeUnixNano: timeNanos,
          severityNumber: 9,
          severityText: "INFO",
          body: { stringValue: eventName },
          attributes: logAttrs
        }]
      }]
    }]
  });
  fetch(`${ENDPOINT}/v1/logs`, {
    method: "POST",
    headers: { "Content-Type": "application/json", ...HEADERS },
    body: payload,
    signal: AbortSignal.timeout(5e3)
  }).catch(() => {
  });
}
var ENABLED, ENDPOINT, HEADERS, RESOURCE_ATTRS;
var init_telemetry = __esm({
  "src/telemetry.ts"() {
    "use strict";
    ENABLED = process.env.CLAUDE_CODE_ENABLE_TELEMETRY === "1";
    ENDPOINT = (process.env.OTEL_EXPORTER_OTLP_ENDPOINT || "http://localhost:4317").replace(/\/$/, "");
    HEADERS = parseHeaders(process.env.OTEL_EXPORTER_OTLP_HEADERS || "");
    RESOURCE_ATTRS = parseResourceAttrs(process.env.OTEL_RESOURCE_ATTRIBUTES || "");
  }
});

// src/state-tools.ts
import { existsSync, mkdirSync, readFileSync, readdirSync, writeFileSync } from "node:fs";
import { join as join3 } from "node:path";
function findHaikuRoot() {
  let dir = process.cwd();
  for (let i = 0; i < 20; i++) {
    if (existsSync(join3(dir, ".haiku"))) return join3(dir, ".haiku");
    const parent = join3(dir, "..");
    if (parent === dir) break;
    dir = parent;
  }
  throw new Error("No .haiku/ directory found");
}
function intentDir(slug) {
  return join3(findHaikuRoot(), "intents", slug);
}
function stageDir(slug, stage) {
  return join3(intentDir(slug), "stages", stage);
}
function unitPath(slug, stage, unit) {
  const name = unit.endsWith(".md") ? unit : `${unit}.md`;
  return join3(stageDir(slug, stage), "units", name);
}
function stageStatePath(slug, stage) {
  return join3(stageDir(slug, stage), "state.json");
}
function parseFrontmatter(raw) {
  const match = raw.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);
  if (!match) return { data: {}, body: raw };
  const data = {};
  for (const line of match[1].split("\n")) {
    const kv = line.match(/^([\w][\w-]*):\s*(.*)$/);
    if (kv) {
      const [, k2, v2] = kv;
      if (v2 === "null") data[k2] = null;
      else if (v2 === "true") data[k2] = true;
      else if (v2 === "false") data[k2] = false;
      else if (/^-?\d+$/.test(v2)) data[k2] = parseInt(v2, 10);
      else if (v2.startsWith("[") && v2.endsWith("]")) {
        data[k2] = v2.slice(1, -1).split(",").map((s) => s.trim().replace(/^["']|["']$/g, "")).filter(Boolean);
      } else {
        data[k2] = v2.replace(/^["']|["']$/g, "");
      }
    }
  }
  return { data, body: match[2].trim() };
}
function setFrontmatterField(filePath, field, value) {
  const raw = readFileSync(filePath, "utf8");
  const { data, body } = parseFrontmatter(raw);
  data[field] = value;
  const lines = Object.entries(data).map(([k2, v2]) => {
    if (v2 === null) return `${k2}: null`;
    if (Array.isArray(v2)) return `${k2}: [${v2.join(", ")}]`;
    return `${k2}: ${v2}`;
  });
  writeFileSync(filePath, `---
${lines.join("\n")}
---
${body ? `
${body}` : ""}`);
}
function readJson(path) {
  if (!existsSync(path)) return {};
  return JSON.parse(readFileSync(path, "utf8"));
}
function writeJson(path, data) {
  mkdirSync(join3(path, ".."), { recursive: true });
  writeFileSync(path, JSON.stringify(data, null, 2) + "\n");
}
function timestamp() {
  return (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
}
function handleStateTool(name, args2) {
  const text = (s) => ({ content: [{ type: "text", text: s }] });
  switch (name) {
    // ── Intent ──
    case "haiku_intent_get": {
      const file = join3(intentDir(args2.slug), "intent.md");
      if (!existsSync(file)) return text("");
      const { data } = parseFrontmatter(readFileSync(file, "utf8"));
      const val = data[args2.field];
      return text(val == null ? "" : typeof val === "object" ? JSON.stringify(val) : String(val));
    }
    case "haiku_intent_set": {
      const file = join3(intentDir(args2.slug), "intent.md");
      setFrontmatterField(file, args2.field, args2.value);
      return text("ok");
    }
    case "haiku_intent_list": {
      const root = findHaikuRoot();
      const intentsDir = join3(root, "intents");
      if (!existsSync(intentsDir)) return text("[]");
      const slugs = readdirSync(intentsDir).filter((d) => existsSync(join3(intentsDir, d, "intent.md")));
      const intents = slugs.map((slug) => {
        const { data } = parseFrontmatter(readFileSync(join3(intentsDir, slug, "intent.md"), "utf8"));
        return { slug, studio: data.studio, status: data.status, active_stage: data.active_stage };
      });
      return text(JSON.stringify(intents, null, 2));
    }
    // ── Stage ──
    case "haiku_stage_get": {
      const path = stageStatePath(args2.intent, args2.stage);
      const data = readJson(path);
      const val = data[args2.field];
      return text(val == null ? "" : String(val));
    }
    case "haiku_stage_set": {
      const path = stageStatePath(args2.intent, args2.stage);
      const data = readJson(path);
      data[args2.field] = args2.value;
      writeJson(path, data);
      if (args2.field === "phase") {
        emitTelemetry("haiku.stage.phase", { intent: args2.intent, stage: args2.stage, phase: args2.value });
      } else if (args2.field === "gate_entered_at") {
        emitTelemetry("haiku.gate.entered", { intent: args2.intent, stage: args2.stage });
      }
      return text("ok");
    }
    case "haiku_stage_start": {
      const path = stageStatePath(args2.intent, args2.stage);
      const data = readJson(path);
      data.stage = args2.stage;
      data.status = "active";
      data.phase = "decompose";
      data.started_at = timestamp();
      data.completed_at = null;
      data.gate_entered_at = null;
      data.gate_outcome = null;
      writeJson(path, data);
      emitTelemetry("haiku.stage.started", { intent: args2.intent, stage: args2.stage });
      return text("ok");
    }
    case "haiku_stage_complete": {
      const path = stageStatePath(args2.intent, args2.stage);
      const data = readJson(path);
      data.status = "completed";
      data.completed_at = timestamp();
      data.gate_outcome = args2.gate_outcome || "advanced";
      writeJson(path, data);
      emitTelemetry("haiku.stage.completed", { intent: args2.intent, stage: args2.stage, gate_outcome: data.gate_outcome });
      return text("ok");
    }
    // ── Unit ──
    case "haiku_unit_get": {
      const path = unitPath(args2.intent, args2.stage, args2.unit);
      if (!existsSync(path)) return text("");
      const { data } = parseFrontmatter(readFileSync(path, "utf8"));
      const val = data[args2.field];
      return text(val == null ? "" : typeof val === "object" ? JSON.stringify(val) : String(val));
    }
    case "haiku_unit_set": {
      const path = unitPath(args2.intent, args2.stage, args2.unit);
      setFrontmatterField(path, args2.field, args2.value);
      return text("ok");
    }
    case "haiku_unit_list": {
      const dir = join3(stageDir(args2.intent, args2.stage), "units");
      if (!existsSync(dir)) return text("[]");
      const files = readdirSync(dir).filter((f) => f.endsWith(".md"));
      const units = files.map((f) => {
        const { data } = parseFrontmatter(readFileSync(join3(dir, f), "utf8"));
        return { name: f.replace(".md", ""), status: data.status, bolt: data.bolt, hat: data.hat };
      });
      return text(JSON.stringify(units, null, 2));
    }
    case "haiku_unit_start": {
      const path = unitPath(args2.intent, args2.stage, args2.unit);
      setFrontmatterField(path, "status", "active");
      setFrontmatterField(path, "bolt", 1);
      setFrontmatterField(path, "hat", args2.hat);
      setFrontmatterField(path, "started_at", timestamp());
      emitTelemetry("haiku.unit.started", { intent: args2.intent, stage: args2.stage, unit: args2.unit, hat: args2.hat });
      return text("ok");
    }
    case "haiku_unit_complete": {
      const path = unitPath(args2.intent, args2.stage, args2.unit);
      setFrontmatterField(path, "status", "completed");
      setFrontmatterField(path, "completed_at", timestamp());
      emitTelemetry("haiku.unit.completed", { intent: args2.intent, stage: args2.stage, unit: args2.unit });
      return text("ok");
    }
    case "haiku_unit_advance_hat": {
      const path = unitPath(args2.intent, args2.stage, args2.unit);
      setFrontmatterField(path, "hat", args2.hat);
      emitTelemetry("haiku.hat.transition", { intent: args2.intent, stage: args2.stage, unit: args2.unit, hat: args2.hat });
      return text("ok");
    }
    case "haiku_unit_increment_bolt": {
      const path = unitPath(args2.intent, args2.stage, args2.unit);
      const { data } = parseFrontmatter(readFileSync(path, "utf8"));
      const current = data.bolt || 0;
      setFrontmatterField(path, "bolt", current + 1);
      emitTelemetry("haiku.bolt.iteration", { intent: args2.intent, stage: args2.stage, unit: args2.unit, bolt: String(current + 1) });
      return text(String(current + 1));
    }
    // ── Knowledge ──
    case "haiku_knowledge_list": {
      const dir = join3(intentDir(args2.intent), "knowledge");
      if (!existsSync(dir)) return text("[]");
      const files = readdirSync(dir).filter((f) => f.endsWith(".md"));
      return text(JSON.stringify(files));
    }
    case "haiku_knowledge_read": {
      const path = join3(intentDir(args2.intent), "knowledge", args2.name);
      if (!existsSync(path)) return text("");
      return text(readFileSync(path, "utf8"));
    }
    default:
      return text(`Unknown tool: ${name}`);
  }
}
