      window.toggleTheme = function() {
        const stored = localStorage.getItem(KEY);
        const sysDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (!stored) localStorage.setItem(KEY, sysDark ? 'light' : 'dark');
