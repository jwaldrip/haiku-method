  }
  if (intentDir2 && existsSync8(join11(intentDir2, "discovery.md"))) {
    const discoveryContent = readFileSync7(join11(intentDir2, "discovery.md"), "utf8");
    const sectionCount = discoveryContent.split("\n").filter((l) => l.startsWith("## ")).length;
    if (sectionCount > 0) {
      out3("### Discovery Log");
      out3("");
      out3(`**${sectionCount} sections** of elaboration findings available in \`.haiku/intents/${intentSlug}/discovery.md\``);
      out3("");
    }
  }
  const plan = intentDir2 ? stateLoad(intentDir2, "current-plan.md") : "";
  const blockers = intentDir2 ? stateLoad(intentDir2, "blockers.md") : "";
  const scratchpad = intentDir2 ? stateLoad(intentDir2, "scratchpad.md") : "";
  const nextPrompt = intentDir2 ? stateLoad(intentDir2, "next-prompt.md") : "";
  if (plan) {
    out3("### Current Plan");
    out3("");
    out3(plan);
    out3("");
  }
  if (blockers) {
    out3("### Previous Blockers");
    out3("");
    out3(blockers);
    out3("");
  }
  if (scratchpad) {
    out3("### Learnings from Previous Iteration");
    out3("");
    out3(scratchpad);
    out3("");
  }
  if (nextPrompt) {
    out3("### Continue With");
    out3("");
    out3(nextPrompt);
    out3("");
  }
  if (intentDir2) {
    const unitFiles = findUnitFiles(intentDir2);
    if (unitFiles.length > 0) {
      out3("### Unit Status");
      out3("");
      out3("| Unit | Status |");
      out3("|------|--------|");
      let completed = 0;
      let inProgress = 0;
      let pending = 0;
      let blocked = 0;
      let ready = 0;
      for (const uf of unitFiles) {
        const name = basename6(uf, ".md");
        const unitStatus = readFrontmatterField(uf, "status") || "pending";
        out3(`| ${name} | ${unitStatus} |`);
        switch (unitStatus) {
          case "completed":
            completed++;
            break;
          case "in_progress":
            inProgress++;
            break;
          case "blocked":
            blocked++;
            break;
          case "pending":
          default:
            pending++;
            ready++;
            break;
        }
      }
      out3("");
      const total = completed + inProgress + pending + blocked;
      out3(`**Summary:** ${completed} completed, ${inProgress} in_progress, ${pending} pending (${blocked} blocked), ${ready} ready`);
      out3("");
    }
  }
  if (process.env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS && intentSlug) {
    const teamName = `haiku-${intentSlug}`;
    const configDir = process.env.CLAUDE_CONFIG_DIR ?? "";
    if (configDir) {
      const teamConfig = join11(configDir, "teams", teamName, "config.json");
      if (existsSync8(teamConfig)) {
        out3("### Agent Teams");
        out3("");
        out3(`**Team:** \`${teamName}\``);
        out3("**Mode:** Parallel execution enabled");
        out3("");
      }
    }
  }
  const instructions = readHatInstructions2(hat, activeStage, studio, pluginRoot);
  const hatMeta = readHatMetadata2(hat, activeStage, studio, pluginRoot);
  out3("### Current Hat Instructions");
  out3("");
  if (instructions) {
    if (hatMeta.description) {
      out3(`**${hatMeta.name || hat}** \u2014 ${hatMeta.description}`);
    } else {
      out3(`**${hatMeta.name || hat}**`);
    }
    out3("");
    out3(instructions);
  } else {
    out3(`**${hat}** (Custom hat - no instructions found)`);
    out3("");
    out3(`Create a hat definition at \`.haiku/hats/${hat}.md\` with:`);
    out3("");
    out3("```markdown");
    out3("---");
    out3('name: "Your Hat Name"');
    out3('description: "What this hat does"');
    out3("---");
    out3("");
    out3("# Hat Name");
    out3("");
    out3("Instructions for this hat...");
    out3("```");
  }
  out3("");
  out3("---");
  out3("");
  out3("## Iteration Management (Required for ALL Hats)");
  out3("");
  out3("### Branch Per Unit (MANDATORY)");
  out3("");
  out3("You MUST work on a dedicated branch for this unit:");
  out3("");
  out3("```bash");
  out3("# Create if not exists:");
  out3("git checkout -b haiku/{intent-slug}/{unit-number}-{unit-slug}");
  out3("# Or use worktrees for parallel work:");
  out3("git worktree add ../{unit-slug} haiku/{intent-slug}/{unit-number}-{unit-slug}");
  out3("```");
  out3("");
  out3("You MUST NOT work directly on main/master. This isolates work and prevents conflicts.");
  out3("");
  out3("### Before Stopping (MANDATORY)");
  out3("");
  out3("Before every stop, you MUST:");
  out3("");
  out3("1. **Commit working changes**: `git add -A && git commit`");
  out3("2. **Save scratchpad**: save to `.haiku/intents/{intent-slug}/state/scratchpad.md`");
  out3("3. **Write next prompt**: save to `.haiku/intents/{intent-slug}/state/next-prompt.md`");
  out3("");
  out3("The next-prompt.md should contain what to continue with in the next iteration.");
  out3("Without this, progress may be lost if the session ends.");
  out3("");
  out3("### Never Stop Arbitrarily");
  out3("");
  out3("- You MUST NOT stop mid-bolt without saving state");
  out3("- If you need user input, use `AskUserQuestion` tool");
  out3("- If blocked, document in `.haiku/intents/{intent-slug}/state/blockers.md`");
  out3("");
  if (currentBranch && currentBranch !== "main" && currentBranch !== "master") {
    if (!currentBranch.match(/^haiku\/[a-z0-9-]+\/(main|[0-9]+-[a-z0-9-]+)$/)) {
      out3(`> **WARNING:** Current branch \`${currentBranch}\` doesn't follow H\xB7AI\xB7K\xB7U convention.`);
      out3("> Expected: `haiku/{intent-slug}/main` or `haiku/{intent-slug}/{unit-number}-{unit-slug}`");
      out3("> Create correct branch before proceeding.");
      out3("");
    }
  } else {
    out3(`> **WARNING:** You are on \`${currentBranch || "main"}\`. Create a unit branch before working.`);
    out3("");
  }
  out3("---");
  out3("");
  out3("**Commands:** `/haiku:execute` (continue loop) | `/haiku:construct` (deprecated alias) | `/haiku:reset` (abandon task)");
  out3("");
  out3("> **No file changes?** If this hat's work is complete but no files were modified,");
  out3("> save findings to scratchpad and read `plugin/skills/execute/subskills/advance/SKILL.md` then execute it to continue.");
}
var init_inject_context = __esm({
  "src/hooks/inject-context.ts"() {
    "use strict";
    init_utils();
  }
});

// src/hooks/index.ts
var hooks_exports = {};
__export(hooks_exports, {
  runHook: () => runHook
});
import { readFileSync as readFileSync8 } from "node:fs";
function readStdin() {
  try {
    return readFileSync8(0, "utf8");
  } catch {
    return "";
  }
}
async function runHook(name, _args) {
  const input = readStdin();
  let parsed = {};
  try {
    if (input.trim()) parsed = JSON.parse(input);
  } catch {
  }
  const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT || "";
  switch (name) {
    case "prompt-guard":
      await promptGuard(parsed, pluginRoot);
      break;
    case "workflow-guard":
      await workflowGuard(parsed, pluginRoot);
      break;
    case "redirect-plan-mode":
      await redirectPlanMode(parsed, pluginRoot);
      break;
    case "context-monitor":
      await contextMonitor(parsed, pluginRoot);
      break;
    case "enforce-iteration":
      await enforceIteration(parsed, pluginRoot);
      break;
    case "ensure-deps":
      await ensureDeps(parsed, pluginRoot);
      break;
    case "quality-gate":
      await qualityGate(parsed, pluginRoot);
      break;
    case "subagent-hook":
      await subagentHook(parsed, pluginRoot);
      break;
    case "subagent-context":
      await generateSubagentContext(parsed, pluginRoot);
      break;
    case "inject-context":
      await injectContext(parsed, pluginRoot);
      break;
    default:
      console.error(`haiku: hook '${name}' not implemented in binary \u2014 use shell fallback`);
      process.exit(2);
  }
}
var init_hooks = __esm({
  "src/hooks/index.ts"() {
    "use strict";
    init_prompt_guard();
    init_workflow_guard();
    init_redirect_plan_mode();
    init_context_monitor();
    init_enforce_iteration();
    init_ensure_deps();
    init_quality_gate();
    init_subagent_hook();
    init_subagent_context();
    init_inject_context();
  }
});

// src/main.ts
var [cmd, ...args] = process.argv.slice(2);
if (cmd === "mcp") {
  Promise.resolve().then(() => init_server3());
} else if (cmd === "hook") {
  const hookName = args[0];
  if (!hookName) {
    console.error("Usage: haiku hook <name>");
    process.exit(1);
  }
  Promise.resolve().then(() => (init_hooks(), hooks_exports)).then((m2) => m2.runHook(hookName, args.slice(1))).catch((err) => {
    console.error(`haiku hook ${hookName}: ${err.message}`);
    process.exit(1);
  });
} else if (cmd === "migrate") {
  Promise.resolve().then(() => (init_migrate(), migrate_exports)).then((m2) => m2.runMigrate(args)).catch((err) => {
    console.error(`haiku migrate: ${err.message}`);
    process.exit(1);
  });
} else {
  console.error("Usage: haiku <mcp|hook|migrate> [args...]");
  process.exit(1);
}
