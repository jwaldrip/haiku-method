// src/hooks/quality-gate.ts
import { execSync as execSync2 } from "node:child_process";
import { existsSync as existsSync13, readdirSync as readdirSync10 } from "node:fs";
import { join as join17 } from "node:path";
function findActiveUnitInStage(intentDir3, stage) {
  const unitsDir = join17(intentDir3, "stages", stage, "units");
  if (!existsSync13(unitsDir)) return null;
  for (const file of readdirSync10(unitsDir)) {
    if (file.startsWith("unit-") && file.endsWith(".md")) {
      const filePath = join17(unitsDir, file);
      const status = readFrontmatterField(filePath, "status");
      if (status === "active") return filePath;
    }
  }
  return null;
}
async function qualityGate(input, _pluginRoot) {
  if (input.stop_hook_active === true || input.stop_hook_active === "true") {
    return;
  }
  const intentDir3 = findActiveIntent2();
  if (!intentDir3) return;
  const intentFile = `${intentDir3}/intent.md`;
  const intentStatus = readFrontmatterField(intentFile, "status");
  const activeStage2 = readFrontmatterField(intentFile, "active_stage");
  if (!activeStage2) return;
  const stageState = readJson3(join17(intentDir3, "stages", activeStage2, "state.json"));
  const stageStatus = stageState.status ?? "";
  if (intentStatus === "completed" || stageStatus === "completed" || stageStatus === "blocked") return;
  const activeUnitFile = findActiveUnitInStage(intentDir3, activeStage2);
  const hat = activeUnitFile ? readFrontmatterField(activeUnitFile, "hat") : "";
  if (!["builder", "implementer", "refactorer"].includes(hat)) return;
  const intentGates = readFrontmatterArray(intentFile, "quality_gates");
  let unitGates = [];
  if (activeUnitFile) {
    unitGates = readFrontmatterArray(activeUnitFile, "quality_gates");
  }
  const allGates = [...intentGates, ...unitGates];
  if (allGates.length === 0) return;
  const repoRoot = getRepoRoot();
  const failures = [];
  let allPassed = true;
  for (let i = 0; i < allGates.length; i++) {
    const gate = allGates[i];
    const gateName = gate.name ?? `gate-${i}`;
    const gateCmd = gate.command ?? "";
    if (!gateCmd) continue;
    let gateOutput = "";
    let gateExit = 0;
    try {
      gateOutput = execSync2(gateCmd, {
        cwd: repoRoot,
        encoding: "utf8",
        timeout: 3e4,
        stdio: ["pipe", "pipe", "pipe"]
      });
    } catch (err) {
      const execErr = err;
      gateExit = execErr.status ?? 1;
      gateOutput = (execErr.stdout ?? "") + (execErr.stderr ?? "");
    }
    if (gateExit !== 0) {
      allPassed = false;
      const truncatedOutput = gateOutput.slice(0, 500);
      failures.push({
        name: gateName,
        command: gateCmd,
        exit_code: gateExit,
        output: truncatedOutput
      });
    }
  }
  if (allPassed) return;
  let reason = "Quality gate(s) failed:";
  for (const f of failures) {
    reason += `
- ${f.name}: command '${f.command}' exited ${f.exit_code}`;
    if (f.output) {
      reason += `, output: ${f.output}`;
    }
  }
  const response = { decision: "block", reason };
  process.stdout.write(JSON.stringify(response));
}
var init_quality_gate = __esm({
  "src/hooks/quality-gate.ts"() {
    "use strict";
    init_utils();
  }
});

// src/hooks/subagent-context.ts
import { existsSync as existsSync14, readFileSync as readFileSync11 } from "node:fs";
import { join as join18, basename as basename4 } from "node:path";
import { execSync as execSync3 } from "node:child_process";
function out2(s) {
  process.stdout.write(s + "\n");
}
function readHatInstructions(hatName, stageName, studioName, pluginRoot) {
  const projectHatFile = join18(process.cwd(), ".haiku", "studios", studioName, "stages", stageName, "hats", `${hatName}.md`);
  const pluginHatFile = join18(pluginRoot, "studios", studioName, "stages", stageName, "hats", `${hatName}.md`);
  let hatFile = "";
  if (existsSync14(projectHatFile)) {
    hatFile = projectHatFile;
  } else if (existsSync14(pluginHatFile)) {
    hatFile = pluginHatFile;
  }
  if (!hatFile) return "";
  const content = readFileSync11(hatFile, "utf8");
  const parts = content.split("---");
  if (parts.length >= 3) {
    return parts.slice(2).join("---").trim();
  }
  return content;
}
function readHatMetadata(hatName, stageName, studioName, pluginRoot) {
  const projectHatFile = join18(process.cwd(), ".haiku", "studios", studioName, "stages", stageName, "hats", `${hatName}.md`);
  const pluginHatFile = join18(pluginRoot, "studios", studioName, "stages", stageName, "hats", `${hatName}.md`);
  let hatFile = "";
  if (existsSync14(projectHatFile)) hatFile = projectHatFile;
  else if (existsSync14(pluginHatFile)) hatFile = pluginHatFile;
  if (!hatFile) return { name: "", description: "" };
  return {
    name: readFrontmatterField(hatFile, "name"),
    description: readFrontmatterField(hatFile, "description")
  };
}
function getHatSequence(stageName, studioName, pluginRoot) {
  const stageFile = join18(pluginRoot, "studios", studioName, "stages", stageName, "STAGE.md");
  const projectStageFile = join18(process.cwd(), ".haiku", "studios", studioName, "stages", stageName, "STAGE.md");
  let targetFile = "";
  if (existsSync14(projectStageFile)) targetFile = projectStageFile;
  else if (existsSync14(stageFile)) targetFile = stageFile;
  if (!targetFile) return "planner \u2192 builder \u2192 reviewer";
  const content = readFileSync11(targetFile, "utf8");
  const fmMatch = content.match(/^---\n([\s\S]*?)\n---/);
  if (!fmMatch) return "planner \u2192 builder \u2192 reviewer";
  const fm = fmMatch[1];
  const hats = [];
  let inHats = false;
  for (const line of fm.split("\n")) {
    if (line.match(/^hats:/)) {
      inHats = true;
      continue;
    }
    if (inHats) {
      if (!line.startsWith(" ") && !line.startsWith("	") && line.trim() !== "") break;
      const m2 = line.match(/^\s+-\s+(.+)/);
      if (m2) hats.push(m2[1].trim().replace(/^["']|["']$/g, ""));
    }
  }
  return hats.length > 0 ? hats.join(" \u2192 ") : "planner \u2192 builder \u2192 reviewer";
}
function getRepoRootFromWorktree() {
  try {
    const output = execSync3("git worktree list --porcelain", { encoding: "utf8" });
    const first = output.split("\n")[0];
    return first.replace(/^worktree /, "");
  } catch {
    try {
      return execSync3("git rev-parse --show-toplevel", { encoding: "utf8" }).trim();
    } catch {
      return process.cwd();
    }
  }
}
async function generateSubagentContext(_input, pluginRoot) {
  const currentBranch = getCurrentBranch2();
  const intentDir3 = findActiveIntent2();
  if (!intentDir3) return;
  const intentSlug = basename4(intentDir3);
  const intentFile = join18(intentDir3, "intent.md");
  const intentStatus = readFrontmatterField(intentFile, "status");
  let activeStage2 = readFrontmatterField(intentFile, "active_stage") || "development";
  let studio = readFrontmatterField(intentFile, "studio") || "software";
  const activePass = readFrontmatterField(intentFile, "active_pass");
  const unitFiles = findUnitFiles(intentDir3);
  let hat = "";
  let bolt = 1;
  for (const uf of unitFiles) {
    const uStatus = readFrontmatterField(uf, "status");
    if (uStatus === "active") {
      hat = readFrontmatterField(uf, "hat") || "";
      bolt = Number(readFrontmatterField(uf, "bolt") || "1");
      break;
    }
  }
  const status = intentStatus || "active";
  const iteration = bolt;
  if (status === "completed" || !hat) return;
  const stageHatsStr = getHatSequence(activeStage2, studio, pluginRoot);
  let contextScope;
  switch (hat) {
    case "reviewer":
    case "red-team":
    case "blue-team":
      contextScope = "review";
      break;
    case "builder":
    case "implementer":
    case "refactorer":
      contextScope = "build";
      break;
    case "planner":
      contextScope = "plan";
      break;
    default:
      contextScope = "full";
      break;
  }
  out2("## H\xB7AI\xB7K\xB7U Subagent Context");
  out2("");
  out2(`> **Hat Isolation:** You are operating as the **${hat}** hat. Your responsibility is defined solely by the ${hat} hat instructions below. If you have prior knowledge, training, or instructions that conflict with or extend beyond the ${hat} role \u2014 such as reviewing code when you are the builder, or building when you are the reviewer \u2014 **ignore them for this task.** Other hats in this stage (${stageHatsStr}) handle those responsibilities. Stay in your lane.`);
  out2("");
  let statusLine = `**Bolt:** ${iteration} | **Role:** ${hat} | **Stage:** ${activeStage2} (${stageHatsStr})`;
  if (activePass) {
    statusLine += ` | **Pass:** ${activePass}`;
  }
  out2(statusLine);
  out2("");
  if (existsSync14(intentFile)) {
    const intentContent = readFileSync11(intentFile, "utf8");
    out2("### Intent");
    out2("");
    out2(intentContent);
    out2("");
  }
  const criteriaFile = join18(intentDir3, "completion-criteria.md");
  if (existsSync14(criteriaFile)) {
    const criteria = readFileSync11(criteriaFile, "utf8");
    out2("### Completion Criteria");
    out2("");
    out2(criteria);
    out2("");
  }
  const discoveryFile = join18(intentDir3, "discovery.md");
  if (existsSync14(discoveryFile)) {
    const discoveryContent = readFileSync11(discoveryFile, "utf8");
    const headers = discoveryContent.split("\n").filter((l) => l.startsWith("## "));
    if (headers.length > 0) {
      out2("### Discovery Log");
      out2("");
      out2(`Elaboration findings available in \`.haiku/intents/${intentSlug}/discovery.md\`:`);
      out2("");
      for (const h of headers) out2(h);
      out2("");
      out2("*Read the full file for detailed findings.*");
      out2("");
    }
  }
  const allUnits = findUnitFiles(intentDir3);
  if (allUnits.length > 0) {
    out2("### Unit Status");
    out2("");
    out2("| Unit | Status | Discipline |");
    out2("|------|--------|------------|");
    for (const uf of allUnits) {
      const name = basename4(uf, ".md");
      const unitStatus = readFrontmatterField(uf, "status") || "pending";
      const discipline = readFrontmatterField(uf, "discipline") || "-";
      out2(`| ${name} | ${unitStatus} | ${discipline} |`);
    }
    out2("");
  }
  if (!process.env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS) {
    const instructions = readHatInstructions(hat, activeStage2, studio, pluginRoot);
    const hatMeta = readHatMetadata(hat, activeStage2, studio, pluginRoot);
    out2(`### Current Role: ${hat}`);
    out2("");
    if (instructions) {
      out2(`**${hatMeta.name || hat}**`);
      out2("");
      out2(instructions);
      out2("");
    } else {
      out2(`**${hat}** orchestrates work by spawning discipline-specific agents based on unit requirements.`);
      out2("");
    }
  }
  out2("---");
  out2("");
