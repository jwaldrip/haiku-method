    "use strict";
    sessions = /* @__PURE__ */ new Map();
    MAX_SESSIONS = 100;
    SESSION_TTL_MS = 30 * 60 * 1e3;
    sessionCreatedAt = /* @__PURE__ */ new Map();
  }
