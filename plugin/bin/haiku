// src/prompts/completions.ts
import { existsSync as existsSync6, readdirSync as readdirSync4, readFileSync as readFileSync5, statSync } from "node:fs";
import { join as join8 } from "node:path";
function filterAndSort(candidates, value) {
  if (!value) return candidates.slice(0, 100);
  const lower = value.toLowerCase();
  const prefix = [];
  const substring = [];
  for (const c of candidates) {
    const cl = c.toLowerCase();
    if (cl.startsWith(lower)) prefix.push(c);
    else if (cl.includes(lower)) substring.push(c);
  }
  return [...prefix, ...substring].slice(0, 100);
}
async function completeIntentSlug(value) {
  try {
    const root = findHaikuRoot();
    const intentsDir = join8(root, "intents");
    if (!existsSync6(intentsDir)) return [];
    const slugs = readdirSync4(intentsDir, { withFileTypes: true }).filter((d) => d.isDirectory() && existsSync6(join8(intentsDir, d.name, "intent.md"))).map((d) => {
      const mtime = statSync(join8(intentsDir, d.name, "intent.md")).mtimeMs;
      return { name: d.name, mtime };
    }).sort((a, b2) => b2.mtime - a.mtime).map((d) => d.name);
    return filterAndSort(slugs, value);
  } catch {
    return [];
  }
}
async function completeStage(value, context) {
  try {
    const studio = resolveStudioFromContext(context);
    if (!studio) return [];
    const stages = resolveStudioStages2(studio);
    return filterAndSort(stages, value);
  } catch {
    return [];
  }
}
async function completeStudio(value) {
  try {
    const studios = listStudios();
    return filterAndSort(studios, value);
  } catch {
    return [];
  }
}
function resolveStudioFromContext(context) {
  if (context?.intent) {
    try {
      validateIdentifier(context.intent, "intent slug");
      const dir = intentDir(context.intent);
      const raw = readFileSync5(join8(dir, "intent.md"), "utf8");
      const { data } = parseFrontmatter(raw);
      if (typeof data.studio === "string") return data.studio;
    } catch {
    }
  }
  if (context?.studio) return context.studio;
  return null;
}
function resolveStudioStages2(studio) {
  validateIdentifier(studio, "studio");
  for (const base of studioSearchPaths()) {
    const studioDir = join8(base, studio);
    if (!existsSync6(join8(studioDir, "STUDIO.md"))) continue;
    const stagesDir = join8(studioDir, "stages");
    if (!existsSync6(stagesDir)) continue;
    const stages = readdirSync4(stagesDir, { withFileTypes: true }).filter((d) => d.isDirectory() && existsSync6(join8(stagesDir, d.name, "STAGE.md"))).map((d) => d.name);
    if (stages.length > 0) return stages;
  }
  return [];
}
function listStudios() {
  const seen = /* @__PURE__ */ new Set();
  for (const base of studioSearchPaths()) {
    if (!existsSync6(base)) continue;
    for (const d of readdirSync4(base, { withFileTypes: true })) {
      if (d.isDirectory() && existsSync6(join8(base, d.name, "STUDIO.md")) && !seen.has(d.name)) {
        seen.add(d.name);
      }
    }
  }
  return Array.from(seen);
}
