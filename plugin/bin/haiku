          const stagesDir = join10(pluginRoot, "studios", "software", "stages");
          if (existsSync8(stagesDir)) {
            for (const stage of readdirSync6(stagesDir, { withFileTypes: true })) {
              if (!stage.isDirectory()) continue;
              const hatFile = join10(stagesDir, stage.name, "hats", `${hatName}.md`);
              if (existsSync8(hatFile)) {
                hatContent = readFileSync7(hatFile, "utf8");
                break;
              }
            }
          }
          if (!hatContent) {
            try {
              const root = findHaikuRoot();
              const projStages = join10(root, "studios", "software", "stages");
              if (existsSync8(projStages)) {
                for (const stage of readdirSync6(projStages, { withFileTypes: true })) {
                  if (!stage.isDirectory()) continue;
                  const hatFile = join10(projStages, stage.name, "hats", `${hatName}.md`);
                  if (existsSync8(hatFile)) {
                    hatContent = readFileSync7(hatFile, "utf8");
                    break;
                  }
                }
              }
            } catch {
            }
          }
        }
        const availableHats = [];
        if (!hatName || !hatContent) {
          const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT || "";
          const stagesDir = join10(pluginRoot, "studios", "software", "stages");
          if (existsSync8(stagesDir)) {
            for (const stage of readdirSync6(stagesDir, { withFileTypes: true })) {
              if (!stage.isDirectory()) continue;
              const hatsDir = join10(stagesDir, stage.name, "hats");
              if (!existsSync8(hatsDir)) continue;
              for (const h of readdirSync6(hatsDir).filter((f) => f.endsWith(".md"))) {
                const name = h.replace(/\.md$/, "");
                if (!availableHats.includes(name)) availableHats.push(name);
              }
            }
          }
        }
        if (hatName && hatContent) {
          const active = loadActiveIntent();
          let unitContext = "";
          if (active) {
            const stage = active.data.active_stage || "development";
            const units = loadUnitContent(active.slug, stage);
            if (units.length > 0) {
              unitContext = `

Active intent "${active.slug}" has ${units.length} unit(s) in stage "${stage}" available for pressure testing context.`;
            }
          }
          return {
            messages: [
              textMsg("user", `Pressure-test the ${hatName} hat`),
              textMsg("assistant", [
                `Running Evaluation-Driven Development (RED-GREEN-REFACTOR) on the **${hatName}** hat.`,
                "",
                "Hat definition loaded. Applying TDD cycle:",
                "",
                "Step 1 -- Design Pressure Scenario:",
                "- Combine 3+ pressure types (time, sunk cost, authority, economic, exhaustion, social, pragmatic)",
                "- Target the hat's most important constraints",
                "- Present scenario to user for approval before proceeding",
                "",
                "Step 2 -- RED Phase (baseline without anti-rationalization table):",
                "- Run scenario with a subagent that has hat instructions minus anti-rationalization table",
                "- Document verbatim: decisions made, rationalizations used, sections violated",
                "",
                "Step 3 -- GREEN Phase (full hat definition):",
                "- Run same scenario with full hat definition including anti-rationalization table",
                "- Agent MUST cite specific hat sections, acknowledge temptations",
                "- PASS if correct decision citing hat sections; FAIL if rationalized past them",
                "",
                "Step 4 -- REFACTOR Phase:",
                "- If GREEN failed: capture rationalization, add to anti-rationalization table, re-run",
                "- If GREEN passed: document that hat held under pressure",
                "",
                "Step 5 -- Commit artifacts to .haiku/pressure-tests/",
                unitContext
              ].join("\n")),
              textMsg("user", "Begin pressure testing. Design a pressure scenario and present it for approval.")
            ]
          };
        }
        return {
          messages: [
            textMsg("user", `Pressure-test a hat${hatName ? ` (requested: ${hatName})` : ""}`),
            textMsg("assistant", [
              hatName ? `Hat "${hatName}" not found.` : "No hat specified.",
              "",
              "Available hats:",
              availableHats.map((h) => `- ${h}`).join("\n") || "(none found -- check CLAUDE_PLUGIN_ROOT)",
              "",
              "Select a hat to pressure-test. Each hat will go through the RED-GREEN-REFACTOR cycle",
              "to verify its instructions hold up under multi-pressure adversarial scenarios."
            ].join("\n")),
            textMsg("user", "Select a hat from the list above.")
          ]
        };
      }
    });
  }
});

// src/prompts/simple.ts
import { existsSync as existsSync9, readFileSync as readFileSync8, readdirSync as readdirSync7 } from "node:fs";
import { join as join11 } from "node:path";
function median(arr) {
  const sorted = [...arr].sort((a, b2) => a - b2);
  const mid = Math.floor(sorted.length / 2);
  return sorted.length % 2 !== 0 ? sorted[mid] : Math.round((sorted[mid - 1] + sorted[mid]) / 2);
}
var init_simple = __esm({
  "src/prompts/simple.ts"() {
    "use strict";
    init_prompts();
    init_completions();
    init_helpers2();
    init_state_tools();
    registerPrompt({
      name: "haiku:dashboard",
      title: "Dashboard",
      description: "Show active intents and their status overview",
      arguments: [],
      handler: async () => {
        let root;
        try {
          root = findHaikuRoot();
        } catch {
          return singleMessage("No .haiku/ directory found. Run /haiku:setup to initialize.");
        }
        const intentsDir = join11(root, "intents");
        if (!existsSync9(intentsDir)) {
          return singleMessage("No intents found. Use /haiku:new to create one.");
        }
        const slugs = readdirSync7(intentsDir, { withFileTypes: true }).filter((d) => d.isDirectory() && existsSync9(join11(intentsDir, d.name, "intent.md"))).map((d) => d.name);
        if (slugs.length === 0) {
          return singleMessage("No intents found. Use /haiku:new to create one.");
        }
        const lines = ["# H-AI-K-U Dashboard\n"];
        for (const slug of slugs) {
          const raw = readFileSync8(join11(intentsDir, slug, "intent.md"), "utf8");
          const { data } = parseFrontmatter(raw);
          const status = data.status || "unknown";
          const studio = data.studio || "\u2014";
          const activeStage2 = data.active_stage || "\u2014";
          const mode = data.mode || "continuous";
          const startedAt = data.started_at || "\u2014";
          lines.push(`## ${slug}`);
          lines.push(`- **Status:** ${status}`);
          lines.push(`- **Studio:** ${studio}`);
          lines.push(`- **Active Stage:** ${activeStage2}`);
          lines.push(`- **Mode:** ${mode}`);
          lines.push(`- **Started:** ${startedAt}`);
          const stagesDir = join11(intentsDir, slug, "stages");
          if (existsSync9(stagesDir)) {
            const stages = readdirSync7(stagesDir, { withFileTypes: true }).filter((d) => d.isDirectory()).map((d) => d.name);
            if (stages.length > 0) {
              lines.push("\n| Stage | Status | Phase |");
              lines.push("|-------|--------|-------|");
              for (const stage of stages) {
                const state = readJson2(join11(stagesDir, stage, "state.json"));
                const sStatus = state.status || "pending";
                const sPhase = state.phase || "\u2014";
                lines.push(`| ${stage} | ${sStatus} | ${sPhase} |`);
              }
            }
          }
          lines.push("");
        }
        return singleMessage(lines.join("\n"));
      }
    });
    registerPrompt({
      name: "haiku:backlog",
      title: "Backlog",
      description: "Parking lot for ideas not ready for planning \u2014 add, list, review, or promote",
      arguments: [
        {
          name: "action",
          description: "Subcommand: add, list, review, or promote",
          required: false
        },
        {
          name: "description",
          description: "Idea description (for add) or item ID (for promote)",
          required: false
        }
      ],
      handler: async (args2) => {
        const action = args2.action || "list";
        const desc = args2.description || "";
        let root;
        try {
          root = findHaikuRoot();
        } catch {
          return singleMessage("No .haiku/ directory found. Run /haiku:setup to initialize.");
        }
        const backlogDir = join11(root, "backlog");
        switch (action) {
          case "add": {
            return singleMessage(
              `## Add Backlog Item

Create a new backlog item at \`.haiku/backlog/{slug}.md\` with this structure:

\`\`\`yaml
---
id: {slug}
priority: medium
tags: []
created: {today's date YYYY-MM-DD}
