async function injectContext(input, pluginRoot) {
  const source = input.source ?? "startup";
  const currentBranch = getCurrentBranch();
  const repoRoot = getRepoRoot();
  const oldAiDlcDir = join11(repoRoot, ".ai-dlc");
  if (existsSync8(oldAiDlcDir)) {
    const haikuIntentsDir = join11(repoRoot, ".haiku", "intents");
    const oldEntries = readdirSync7(oldAiDlcDir).filter(
      (d) => existsSync8(join11(oldAiDlcDir, d, "intent.md"))
    );
    const needsMigration = oldEntries.some(
      (slug) => !existsSync8(join11(haikuIntentsDir, slug, "intent.md"))
    );
    if (needsMigration) {
      try {
        const { runMigrate: runMigrate2 } = await Promise.resolve().then(() => (init_migrate(), migrate_exports));
        await runMigrate2([]);
      } catch {
      }
    }
  }
  const defaultBranch = getDefaultBranch();
  if (currentBranch === defaultBranch) {
    const intentsDir = join11(repoRoot, ".haiku", "intents");
    if (existsSync8(intentsDir)) {
      for (const slug of readdirSync7(intentsDir)) {
        const intentFile = join11(intentsDir, slug, "intent.md");
        if (!existsSync8(intentFile)) continue;
        const reconcileStatus = readFrontmatterField(intentFile, "status");
        if (reconcileStatus !== "active") continue;
        const unitFiles = findUnitFiles(join11(intentsDir, slug));
        if (unitFiles.length === 0) continue;
        let allDone = true;
        for (const uf of unitFiles) {
          const unitStatus = readFrontmatterField(uf, "status");
          if (unitStatus !== "completed") {
            allDone = false;
            break;
          }
        }
        if (allDone) {
          setFrontmatterField2(intentFile, "status", "completed");
          checkIntentCriteria(join11(intentsDir, slug));
        }
      }
    }
  }
  const intentDir2 = findActiveIntent2();
  let iterationJson = "";
  if (intentDir2) {
    iterationJson = stateLoad(intentDir2, "iteration.json");
  }
  if (!iterationJson) {
    const intentsDir = join11(repoRoot, ".haiku", "intents");
    const filesystemIntents = [];
    if (existsSync8(intentsDir)) {
      for (const slug of readdirSync7(intentsDir)) {
        const intentFile = join11(intentsDir, slug, "intent.md");
        if (!existsSync8(intentFile)) continue;
        const status2 = readFrontmatterField(intentFile, "status");
        if (status2 !== "active") continue;
        const unitFiles = findUnitFiles(join11(intentsDir, slug));
        let completed = 0;
        for (const uf of unitFiles) {
          if (readFrontmatterField(uf, "status") === "completed") completed++;
        }
        const summary = unitFiles.length > 0 ? `${completed}/${unitFiles.length} completed` : "";
        filesystemIntents.push({ slug, summary });
      }
    }
    if (filesystemIntents.length > 0) {
      out3("## H\xB7AI\xB7K\xB7U: Resumable Intents Found");
      out3("");
      out3("### In Current Directory");
      out3("");
      for (const intent of filesystemIntents) {
        out3(`- **${intent.slug}**`);
        if (intent.summary) {
          out3(`  - Units: ${intent.summary}`);
        }
      }
      out3("");
      out3("**To resume:** `/haiku:resume <slug>` or `/haiku:resume` if only one");
      out3("");
      if (!existsSync8(join11(process.cwd(), ".haiku", "settings.yml"))) {
        out3("> **Tip:** Run `/haiku:setup` to configure providers and VCS settings. This enables automatic ticket sync during elaboration.");
        out3("");
      }
    } else {
      out3("## H\xB7AI\xB7K\xB7U Available");
      out3("");
      out3("No active H\xB7AI\xB7K\xB7U task. Run `/haiku:elaborate` to start a new task.");
      out3("");
      outputSetupHint();
      outputTaskRouting();
    }
    return;
  }
  if (!isValidJson(iterationJson)) {
    process.stderr.write("Warning: Invalid iteration.json format. Run /haiku:reset to clear state.\n");
    return;
  }
  let state = JSON.parse(iterationJson);
  if ("unitStates" in state) {
