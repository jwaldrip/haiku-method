        ];
        if (action.stage) contextParts.push(`Stage: ${action.stage}`);
        if (action.unit) contextParts.push(`Unit: ${action.unit}`);
        if (action.hat) contextParts.push(`Hat: ${action.hat}`);
        if (action.bolt) contextParts.push(`Bolt: ${action.bolt}`);
        const contextText = contextParts.join("\n");
        const instructions = buildRunInstructions(slug, studio, action, dir, intentBody);
        return {
          messages: [
            textMsg("user", contextText),
            textMsg("assistant", `I'll proceed with the "${action.action}" action for intent "${slug}".`),
            textMsg("user", instructions)
          ]
        };
      }
    });
