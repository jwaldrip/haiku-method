  <script>
    (function() {
      var sessionId = '${e}';
      var collectAnnotations = ${t?"true":"false"};

      window.showFeedbackForm = function() {
        document.getElementById('feedback-form').classList.remove('hidden');
        document.getElementById('decision-buttons').classList.add('hidden');
