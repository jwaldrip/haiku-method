// src/hooks/context-monitor.ts
import { existsSync as existsSync4, readFileSync as readFileSync3, appendFileSync } from "node:fs";
import { join as join7 } from "node:path";
async function contextMonitor(input, _pluginRoot) {
  const totalTokens = Number(input.total_tokens ?? 0);
  const maxTokens = Number(input.max_tokens ?? 0);
  if (totalTokens === 0 || maxTokens === 0) return;
  const remaining = Math.floor((maxTokens - totalTokens) * 100 / maxTokens);
  const sessionId = process.env.CLAUDE_SESSION_ID ?? "unknown";
  const debounceFile = join7("/tmp", `context-monitor-${sessionId}`);
  let debounceContent = "";
  if (existsSync4(debounceFile)) {
    debounceContent = readFileSync3(debounceFile, "utf8");
  }
  if (remaining <= 25) {
    if (!debounceContent.includes("25")) {
      appendFileSync(debounceFile, "25\n");
      process.stderr.write(
        `\u26A0\uFE0F CONTEXT CRITICAL (\u226425% remaining)

**You MUST:**
1. Commit all working changes NOW
2. Save state to \`.haiku/intents/{intent-slug}/state/\`
3. Complete current task or signal handoff
4. Do NOT start new tasks

Quality degrades severely at low context. Wrap up.
`
      );
      process.exit(2);
    }
  } else if (remaining <= 35) {
    if (!debounceContent.includes("35")) {
      appendFileSync(debounceFile, "35\n");
      process.stderr.write(
        `\u26A0\uFE0F CONTEXT WARNING (\u226435% remaining)

**Recommended:**
- Finish current task, avoid starting new ones
- Commit working changes frequently
- Consider saving state for session handoff
- Keep responses concise
`
      );
      process.exit(2);
    }
  }
}
var init_context_monitor = __esm({
  "src/hooks/context-monitor.ts"() {
    "use strict";
  }
});

// src/hooks/utils.ts
import { existsSync as existsSync5, readFileSync as readFileSync4, readdirSync as readdirSync4, statSync, writeFileSync as writeFileSync3, mkdirSync as mkdirSync2 } from "node:fs";
import { join as join8, dirname as dirname2 } from "node:path";
import { execSync } from "node:child_process";
function readFrontmatterField(filePath, field) {
  if (!existsSync5(filePath)) return "";
  const content = readFileSync4(filePath, "utf8");
  const match = content.match(new RegExp(`^${field}:\\s*(.+)$`, "m"));
  return match ? match[1].trim().replace(/^["']|["']$/g, "") : "";
}
function findActiveIntent2() {
  let repoRoot;
  try {
    repoRoot = execSync("git rev-parse --show-toplevel", { encoding: "utf8" }).trim();
  } catch {
    repoRoot = process.cwd();
  }
  const intentsDir = join8(repoRoot, ".haiku", "intents");
  if (!existsSync5(intentsDir)) return null;
  const dirs = readdirSync4(intentsDir);
  for (const d of dirs) {
    const intentFile = join8(intentsDir, d, "intent.md");
    if (!existsSync5(intentFile)) continue;
    const status = readFrontmatterField(intentFile, "status");
    if (status === "active") {
      return join8(intentsDir, d);
    }
  }
  return null;
}
function stateLoad(intentDir2, key) {
  const filePath = join8(intentDir2, "state", key);
  if (!existsSync5(filePath)) return "";
  return readFileSync4(filePath, "utf8");
}
function stateSave(intentDir2, key, content) {
  const stateDir = join8(intentDir2, "state");
  if (!existsSync5(stateDir)) mkdirSync2(stateDir, { recursive: true });
  writeFileSync3(join8(stateDir, key), content);
}
function isUnitBranch(branch) {
  if (!branch) return false;
  const parts = branch.split("/");
  return parts.length >= 3 && parts[0] === "haiku" && parts[2] !== "main";
}
function getCurrentBranch() {
  try {
    return execSync("git branch --show-current", { encoding: "utf8" }).trim();
  } catch {
    return "";
  }
}
function getRepoRoot() {
  try {
    return execSync("git rev-parse --show-toplevel", { encoding: "utf8" }).trim();
  } catch {
    return process.cwd();
  }
}
function isValidJson(s) {
  try {
    JSON.parse(s);
    return true;
  } catch {
    return false;
  }
}
function findUnitFiles(intentDir2) {
  const results = [];
  const stagesDir = join8(intentDir2, "stages");
  if (!existsSync5(stagesDir)) return results;
  for (const stage of readdirSync4(stagesDir)) {
    const unitsDir = join8(stagesDir, stage, "units");
    if (!existsSync5(unitsDir) || !statSync(unitsDir).isDirectory()) continue;
    for (const file of readdirSync4(unitsDir)) {
      if (file.startsWith("unit-") && file.endsWith(".md")) {
        results.push(join8(unitsDir, file));
      }
    }
  }
  return results;
}
function readFrontmatterArray(filePath, field) {
  if (!existsSync5(filePath)) return [];
  const content = readFileSync4(filePath, "utf8");
  const fmMatch = content.match(/^---\n([\s\S]*?)\n---/);
  if (!fmMatch) return [];
  const frontmatter = fmMatch[1];
  const lines = frontmatter.split("\n");
  let inField = false;
  let currentItem = {};
  const items = [];
  for (const line of lines) {
    if (line.match(new RegExp(`^${field}:`))) {
      if (line.match(/\[\s*\]/)) return [];
      inField = true;
      continue;
    }
    if (inField) {
      if (!line.startsWith(" ") && !line.startsWith("	") && line.trim() !== "") {
        break;
      }
      const itemStart = line.match(/^\s+-\s+(.*)/);
      if (itemStart) {
        if (Object.keys(currentItem).length > 0) {
          items.push(currentItem);
        }
        currentItem = {};
        const kv = itemStart[1].match(/^(\w+):\s*(.+)/);
        if (kv) {
          currentItem[kv[1]] = kv[2].replace(/^["']|["']$/g, "");
        }
      } else {
        const kv = line.match(/^\s+(\w+):\s*(.+)/);
        if (kv) {
          currentItem[kv[1]] = kv[2].replace(/^["']|["']$/g, "");
        }
      }
    }
  }
  if (Object.keys(currentItem).length > 0) {
    items.push(currentItem);
  }
  return items;
}
function setFrontmatterField2(filePath, field, value) {
  if (!existsSync5(filePath)) return;
  let content = readFileSync4(filePath, "utf8");
  const regex = new RegExp(`^(${field}:)\\s*.+$`, "m");
  if (regex.test(content)) {
    content = content.replace(regex, `$1 ${value}`);
  } else {
    content = content.replace(/^---$/m, `${field}: ${value}
---`);
  }
  writeFileSync3(filePath, content);
}
function checkAllCriteria(filePath, section) {
  if (!existsSync5(filePath)) return;
  let content = readFileSync4(filePath, "utf8");
  if (!section) {
    content = content.replace(/- \[ \]/g, "- [x]");
  } else {
    const lines = content.split("\n");
    let inSection = false;
    for (let i = 0; i < lines.length; i++) {
      if (lines[i].startsWith("## ")) {
        inSection = lines[i].includes(section);
      }
      if (inSection) {
        lines[i] = lines[i].replace(/- \[ \]/g, "- [x]");
      }
    }
    content = lines.join("\n");
  }
  writeFileSync3(filePath, content);
}
function checkIntentCriteria(intentDir2) {
  const intentFile = join8(intentDir2, "intent.md");
  if (existsSync5(intentFile)) {
    const content = readFileSync4(intentFile, "utf8");
    if (content.includes("## Success Criteria")) {
      checkAllCriteria(intentFile, "Success Criteria");
    } else if (content.includes("## Completion Criteria")) {
      checkAllCriteria(intentFile, "Completion Criteria");
    }
  }
  for (const f of [join8(intentDir2, "completion-criteria.md"), join8(intentDir2, "state", "completion-criteria.md")]) {
    if (existsSync5(f)) checkAllCriteria(f);
  }
}
var init_utils = __esm({
  "src/hooks/utils.ts"() {
    "use strict";
  }
});

// src/hooks/enforce-iteration.ts
import { basename as basename3 } from "node:path";
function out(s) {
  process.stdout.write(s + "\n");
}
async function enforceIteration(_input, _pluginRoot) {
  const currentBranch = getCurrentBranch();
  const onUnitBranch = isUnitBranch(currentBranch);
  const intentDir2 = findActiveIntent2();
  let iterationJson = "";
  if (intentDir2) {
    iterationJson = stateLoad(intentDir2, "iteration.json");
  }
  if (onUnitBranch) {
    out("## H\xB7AI\xB7K\xB7U: Unit Session Ending");
    out("");
    out("Ensure you committed changes and saved progress.");
    return;
  }
  if (!iterationJson) {
    return;
  }
  if (!isValidJson(iterationJson)) {
    return;
  }
  const state = JSON.parse(iterationJson);
  const status = state.status ?? "active";
  const currentIteration = Number(state.iteration ?? 1);
  const hat = state.hat ?? "builder";
  const maxIterations = Number(state.maxIterations ?? 0);
  const targetUnit = state.targetUnit ?? "";
  if (status === "complete" || status === "completed") {
    return;
  }
  if (maxIterations > 0 && currentIteration >= maxIterations) {
    out("");
    out("---");
    out("");
    out("## H\xB7AI\xB7K\xB7U: ITERATION LIMIT REACHED");
    out("");
    out(`**Iteration:** ${currentIteration} / ${maxIterations} (max)`);
    out(`**Hat:** ${hat}`);
    out("");
    out("The maximum iteration limit has been reached. This is a safety mechanism");
    out("to prevent infinite loops.");
    out("");
    out("**Options:**");
    out("1. Review progress and decide if work is complete");
    out("2. Increase limit: edit `.haiku/intents/{intent-slug}/state/iteration.json` and set maxIterations");
    out("3. Reset iteration count: `/haiku:reset` and start fresh");
    out("");
    out("Progress preserved in `.haiku/intents/{intent-slug}/state/`.");
    return;
  }
  const intentSlug = intentDir2 ? basename3(intentDir2) : "";
  let readyCount = 0;
  let inProgressCount = 0;
  let allComplete = false;
  if (intentSlug && intentDir2) {
    const unitFiles = findUnitFiles(intentDir2);
    let pending = 0;
    let completed = 0;
    let blocked = 0;
    for (const uf of unitFiles) {
      const unitStatus = readFrontmatterField(uf, "status") || "pending";
      switch (unitStatus) {
        case "completed":
          completed++;
          break;
        case "in_progress":
          inProgressCount++;
          break;
        case "blocked":
          blocked++;
          break;
        case "pending": {
          pending++;
          readyCount++;
          break;
        }
        default:
          pending++;
          break;
      }
    }
    if (readyCount === 0 && inProgressCount === 0 && pending === 0 && blocked === 0 && unitFiles.length > 0) {
      allComplete = true;
    }
    if (completed > 0 && completed === unitFiles.length) {
      allComplete = true;
    }
  }
  out("");
  out("---");
  out("");
  if (allComplete) {
    if (intentDir2) {
      const intentFile = `${intentDir2}/intent.md`;
      const intentStatus = readFrontmatterField(intentFile, "status");
      if (intentStatus === "active") {
        setFrontmatterField2(intentFile, "status", "completed");
        checkIntentCriteria(intentDir2);
        if (iterationJson) {
          const updatedState = { ...state, status: "completed" };
          stateSave(intentDir2, "iteration.json", JSON.stringify(updatedState));
        }
      }
    }
    out("## H\xB7AI\xB7K\xB7U: All Units Complete");
    out("");
    out("All units have been completed. Intent has been marked as completed.");
    out("");
  } else if (readyCount > 0 || inProgressCount > 0) {
    out("## H\xB7AI\xB7K\xB7U: Session Exhausted - Continue Execution");
    out("");
    out(`**Iteration:** ${currentIteration} | **Hat:** ${hat}`);
    out(`**Ready units:** ${readyCount} | **In progress:** ${inProgressCount}`);
    out("");
    out("### ACTION REQUIRED");
    out("");
    if (targetUnit) {
      out(`Call \`/haiku:execute ${intentSlug} ${targetUnit}\` to continue targeted execution.`);
    } else {
      out("Call `/haiku:execute` to continue the autonomous loop.");
    }
    out("");
    out("**Note:** Subagents have clean context. No `/clear` needed.");
    out("");
  } else {
    out("## H\xB7AI\xB7K\xB7U: BLOCKED - Human Intervention Required");
    out("");
    out(`**Iteration:** ${currentIteration} | **Hat:** ${hat}`);
    out("");
    out("No units are ready to work on. All remaining units are blocked.");
    out("");
    out("**User action required:**");
    out(`1. Review blockers: read \`.haiku/intents/${intentSlug}/state/blockers.md\``);
    out("2. Unblock units or resolve dependencies");
    out("3. Run `/haiku:execute` to resume");
    out("");
  }
  out(`Progress preserved in \`.haiku/intents/${intentSlug}/state/\`.`);
}
var init_enforce_iteration = __esm({
  "src/hooks/enforce-iteration.ts"() {
    "use strict";
    init_utils();
  }
});

