async function validateUnitType(input, pluginRoot) {
  const filePath = input.file_path || input.path || "";
  if (!filePath) return;
  const absPath = resolve5(process.cwd(), filePath);
  const haikuMatch = absPath.match(/\.haiku\/intents\/([^/]+)\/stages\/([^/]+)\/units\/([^/]+\.md)$/);
  if (!haikuMatch) return;
  const [, intentSlug, stageName, unitFile] = haikuMatch;
  if (!existsSync16(absPath)) return;
  const raw = readFileSync13(absPath, "utf8");
  const { data } = (0, import_gray_matter5.default)(raw);
  const unitType = data.type || "";
  if (!unitType) return;
  const intentFile = join21(process.cwd(), ".haiku", "intents", intentSlug, "intent.md");
  if (!existsSync16(intentFile)) return;
  const { data: intentFm } = (0, import_gray_matter5.default)(readFileSync13(intentFile, "utf8"));
  const studio = intentFm.studio || "";
  if (!studio) return;
  const stageFile = findStageFile(studio, stageName, pluginRoot);
  if (!stageFile) return;
  const { data: stageFm } = (0, import_gray_matter5.default)(readFileSync13(stageFile, "utf8"));
  const allowedTypes = stageFm.unit_types || [];
  if (allowedTypes.length === 0) return;
  if (!allowedTypes.includes(unitType)) {
    out4(`\u26A0\uFE0F UNIT TYPE VIOLATION: Unit '${basename5(unitFile, ".md")}' has type '${unitType}' but stage '${stageName}' only allows: ${allowedTypes.join(", ")}.`);
    out4(`This unit belongs in a different stage. Change its type to one of [${allowedTypes.join(", ")}] or move it to the appropriate stage.`);
  }
}
function findStageFile(studio, stage, pluginRoot) {
