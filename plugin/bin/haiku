    registerPrompt({
      name: "haiku:refine",
      title: "Refine",
      description: "Refine intent, unit, or upstream stage outputs mid-execution",
      arguments: [
        {
          name: "stage",
          description: "Target stage for upstream refinement (e.g., 'design')",
          required: false,
          completer: completeStage
        }
      ],
      handler: async (args2) => {
        const resolved = resolveIntent({});
        if ("error" in resolved) return resolved.error;
        const slug = resolved.slug;
        const dir = intentDir(slug);
        const intentRaw = readFileSync6(join9(dir, "intent.md"), "utf8");
        const { data: intentData, body: intentBody } = parseFrontmatter(intentRaw);
        const studio = intentData.studio || "ideation";
        const activeStage2 = intentData.active_stage || "";
        let currentPhase = "";
        if (activeStage2) {
          const stateJson = readJson2(join9(dir, "stages", activeStage2, "state.json"));
          currentPhase = stateJson.phase || "";
        }
        const contextParts = [
          `Intent: ${slug}`,
