    registerPrompt({
      name: "haiku:review",
      title: "Review",
      description: "Pre-delivery code review with multi-agent fix loop",
      arguments: [
        {
          name: "intent",
          description: "Intent slug (optional, for context)",
          required: false,
          completer: completeIntentSlug
        }
      ],
      handler: async (args2) => {
        let diffBase = "main";
        let fullDiff = "";
        let diffStat = "";
        let changedFiles = "";
        try {
          try {
            const upstreamResult = spawnSync("git", ["rev-parse", "--abbrev-ref", "@{upstream}"], { encoding: "utf8", stdio: "pipe" });
            const upstream = (upstreamResult.stdout || "").trim();
            if (upstreamResult.status === 0 && upstream) diffBase = upstream;
          } catch {
            try {
              const defaultResult = spawnSync("git", ["symbolic-ref", "refs/remotes/origin/HEAD"], { encoding: "utf8", stdio: "pipe" });
              const defaultBranch = (defaultResult.stdout || "").trim().replace(/^refs\/remotes\/origin\//, "");
              if (defaultResult.status === 0 && defaultBranch) diffBase = defaultBranch;
            } catch {
            }
          }
          const diffResult = spawnSync("git", ["diff", `${diffBase}...HEAD`], { encoding: "utf8", stdio: "pipe", maxBuffer: 10 * 1024 * 1024 });
          fullDiff = diffResult.status === 0 ? diffResult.stdout || "" : "";
          if (!fullDiff) {
            const fallback = spawnSync("git", ["diff", `${diffBase}..HEAD`], { encoding: "utf8", stdio: "pipe", maxBuffer: 10 * 1024 * 1024 });
            fullDiff = fallback.stdout || "";
          }
          const statResult = spawnSync("git", ["diff", "--stat", `${diffBase}...HEAD`], { encoding: "utf8", stdio: "pipe" });
          diffStat = statResult.status === 0 ? statResult.stdout || "" : "";
          if (!diffStat) {
            const fallback = spawnSync("git", ["diff", "--stat", `${diffBase}..HEAD`], { encoding: "utf8", stdio: "pipe" });
            diffStat = fallback.stdout || "";
          }
          const filesResult = spawnSync("git", ["diff", "--name-only", `${diffBase}...HEAD`], { encoding: "utf8", stdio: "pipe" });
          changedFiles = filesResult.status === 0 ? filesResult.stdout || "" : "";
          if (!changedFiles) {
            const fallback = spawnSync("git", ["diff", "--name-only", `${diffBase}..HEAD`], { encoding: "utf8", stdio: "pipe" });
            changedFiles = fallback.stdout || "";
          }
        } catch {
        }
        if (!fullDiff.trim()) {
          return singleMessage(`No changes to review against \`${diffBase}\`.`);
        }
        let reviewGuidelines = "";
        try {
          if (existsSync7("REVIEW.md")) {
            reviewGuidelines = readFileSync6("REVIEW.md", "utf8");
          }
        } catch {
        }
        let claudeMd = "";
        try {
          if (existsSync7("CLAUDE.md")) {
            claudeMd = readFileSync6("CLAUDE.md", "utf8");
          }
        } catch {
        }
        let reviewAgentsConfig = "{}";
        try {
          const root = findHaikuRoot();
          const settingsPath = join9(root, "settings.yml");
          if (existsSync7(settingsPath)) {
            const raw = readFileSync6(settingsPath, "utf8");
            const { data } = parseFrontmatter(`---
${raw}
---
`);
            if (data.review_agents) {
              reviewAgentsConfig = JSON.stringify(data.review_agents);
            }
          }
        } catch {
        }
        const MAX_DIFF_SIZE = 1e5;
        let diffContent = fullDiff;
        let truncated = false;
        if (fullDiff.length > MAX_DIFF_SIZE) {
          diffContent = fullDiff.slice(0, MAX_DIFF_SIZE);
          truncated = true;
        }
        const instructions = `## Pre-Delivery Code Review

**Diff base:** ${diffBase}
**Changed files:**
\`\`\`
${changedFiles}
\`\`\`

**Diff stats:**
\`\`\`
${diffStat}
\`\`\`

` + (reviewGuidelines ? `### Review Guidelines (REVIEW.md)

${reviewGuidelines.slice(0, 5e3)}${reviewGuidelines.length > 5e3 ? "\n...(truncated)" : ""}

` : "") + (claudeMd ? `### Project Instructions (CLAUDE.md)

${claudeMd.slice(0, 5e3)}${claudeMd.length > 5e3 ? "\n...(truncated)" : ""}

` : "") + `### Review Agents Config

${reviewAgentsConfig}

### Full Diff

\`\`\`diff
${diffContent}
\`\`\`
` + (truncated ? `
**Note:** Diff truncated at ${MAX_DIFF_SIZE} chars. Read individual files for full context.

` : "\n") + `### Instructions

1. Spawn specialized review agents **in parallel** (correctness, security, performance, architecture, test_quality)
2. Each agent gets the full diff, review guidelines, and a focused mandate
3. Collect findings as YAML; deduplicate by file+line keeping higher severity
4. Filter out LOW findings unless total < 5
5. For HIGH findings: fix directly, commit, re-review (up to 3 cycles)
6. Report: APPROVED (no HIGH remaining) or NEEDS ATTENTION (user decides)
7. Offer: "Push and create PR" or "Done"`;
        return {
          messages: [
            textMsg("user", `Review changes${args2.intent ? ` for intent ${args2.intent}` : ""}`),
            textMsg("assistant", "I'll run a multi-agent code review against the current diff."),
            textMsg("user", instructions)
          ]
        };
      }
    });
    registerPrompt({
      name: "haiku:reflect",
      title: "Reflect",
      description: "Analyze a completed H\xB7AI\xB7K\xB7U intent cycle and produce reflection artifacts",
      arguments: [
        {
          name: "intent",
          description: "Intent slug (auto-detected if omitted)",
          required: false,
          completer: completeIntentSlug
        }
      ],
      handler: async (args2) => {
        const resolved = resolveIntent(args2);
        if ("error" in resolved) return resolved.error;
        const slug = resolved.slug;
        const dir = intentDir(slug);
        const intentRaw = readFileSync6(join9(dir, "intent.md"), "utf8");
        const { data: intentData, body: intentBody } = parseFrontmatter(intentRaw);
        const studio = intentData.studio || "ideation";
        const stageSummaries = [];
        const stagesDir = join9(dir, "stages");
        if (existsSync7(stagesDir)) {
          for (const stageName of readdirSync5(stagesDir, { withFileTypes: true }).filter((d) => d.isDirectory()).map((d) => d.name)) {
            const stateJson = readJson2(join9(stagesDir, stageName, "state.json"));
            const unitsDir = join9(stagesDir, stageName, "units");
            let unitSummary = "(no units)";
            let totalBolts = 0;
            let completedCount = 0;
            let totalCount = 0;
            if (existsSync7(unitsDir)) {
              const unitFiles = readdirSync5(unitsDir).filter((f) => f.endsWith(".md"));
              totalCount = unitFiles.length;
              const unitDetails = [];
              for (const f of unitFiles) {
                const { data } = parseFrontmatter(readFileSync6(join9(unitsDir, f), "utf8"));
                const bolt = data.bolt || 0;
                totalBolts += bolt;
                if (data.status === "completed") completedCount++;
                unitDetails.push(`  - ${f.replace(".md", "")}: status=${data.status}, bolt=${bolt}, hat=${data.hat || ""}`);
              }
              unitSummary = unitDetails.join("\n");
            }
            stageSummaries.push(
              `### ${stageName}
- Status: ${stateJson.status || "pending"}
- Phase: ${stateJson.phase || "pending"}
- Started: ${stateJson.started_at || "N/A"}
- Completed: ${stateJson.completed_at || "N/A"}
- Units: ${completedCount}/${totalCount} completed
- Total bolts: ${totalBolts}
- Units:
${unitSummary}`
            );
          }
        }
        const metrics = `## Intent Metadata

- **Slug:** ${slug}
- **Studio:** ${studio}
- **Mode:** ${intentData.mode || "continuous"}
- **Status:** ${intentData.status}
- **Created:** ${intentData.created || "N/A"}
- **Completed:** ${intentData.completed_at || "N/A"}

## Intent Description

${intentBody}

## Per-Stage Summary

${stageSummaries.join("\n\n")}`;
        const instructions = `${metrics}

## Analysis Instructions

Perform a structured reflection analysis:

1. **Execution patterns** -- Which units went smoothly? Which required retries?
2. **Criteria satisfaction** -- How well were success criteria met?
3. **Process observations** -- What approaches worked? What was painful?
4. **Blocker analysis** -- Were blockers systemic or one-off?
5. **Session patterns** -- Analyze session transcripts for tool failures, retries, context loss

## Output

Write:
1. \`.haiku/intents/${slug}/reflection.md\` -- Full reflection artifact
2. \`.haiku/intents/${slug}/settings-recommendations.md\` -- Concrete settings changes

Present findings to user for validation. Then offer next steps:
- **Apply Settings** -- auto-apply recommendations
- **Iterate** -- create a new version with learnings pre-loaded
- **Close** -- capture learnings to .claude/memory/ and archive intent`;
        return {
          messages: [
            textMsg("user", `Reflect on intent ${slug}`),
            textMsg("assistant", "I'll analyze the execution cycle and produce reflection artifacts."),
            textMsg("user", instructions)
          ]
        };
      }
    });
  }
});

// src/prompts/complex.ts
import { existsSync as existsSync8, readFileSync as readFileSync7, readdirSync as readdirSync6 } from "node:fs";
import { join as join10 } from "node:path";
function loadActiveIntent() {
  const intents = findActiveIntents();
  return intents.length > 0 ? intents[0] : null;
}
function resolveStudio(intent) {
  return intent.data.studio || "software";
}
function listOperations(studio) {
  validateIdentifier(studio, "studio");
  const results = [];
  for (const base of studioSearchPaths()) {
    const opsDir = join10(base, studio, "operations");
    if (!existsSync8(opsDir)) continue;
    for (const f of readdirSync6(opsDir).filter((f2) => f2.endsWith(".md"))) {
      const raw = readFileSync7(join10(opsDir, f), "utf8");
      results.push({ name: f.replace(/\.md$/, ""), body: raw });
    }
    if (results.length > 0) break;
  }
  return results;
}
function loadSettings() {
  try {
    const root = findHaikuRoot();
    const file = join10(root, "settings.yml");
    if (!existsSync8(file)) return {};
    const raw = readFileSync7(file, "utf8");
    const { data } = parseFrontmatter(`---
${raw}
---
`);
    return data;
  } catch {
    return {};
  }
}
function loadUnitContent(slug, stage) {
  try {
    const dir = join10(intentDir(slug), "stages", stage, "units");
    if (!existsSync8(dir)) return [];
    return readdirSync6(dir).filter((f) => f.endsWith(".md")).map((f) => readFileSync7(join10(dir, f), "utf8"));
  } catch {
    return [];
  }
}
