{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://han.guru/schemas/providers/stack-operations.schema.json",
	"title": "Stack Operations Config",
	"description": "Operations layer configuration defining runtime, scheduled tasks, and reactive handlers",
	"type": "object",
	"properties": {
		"runtime": {
			"type": "string",
			"enum": ["node", "python", "go", "shell"],
			"description": "Operations runtime for scripts and automation. Auto-detected from project files if not set."
		},
		"scheduled": {
			"type": "array",
			"description": "Scheduled/cron tasks",
			"items": {
				"type": "object",
				"properties": {
					"name": {
						"type": "string",
						"description": "Task name"
					},
					"schedule": {
						"type": "string",
						"description": "Cron expression or schedule descriptor"
					},
					"command": {
						"type": "string",
						"description": "Command to execute"
					}
				},
				"required": ["name"],
				"additionalProperties": true
			}
		},
		"reactive": {
			"type": "array",
			"description": "Event-driven/reactive handlers",
			"items": {
				"type": "object",
				"properties": {
					"name": {
						"type": "string",
						"description": "Handler name"
					},
					"trigger": {
						"type": "string",
						"description": "Event trigger (e.g., 'webhook', 'queue', 'alert')"
					},
					"command": {
						"type": "string",
						"description": "Command to execute"
					}
				},
				"required": ["name"],
				"additionalProperties": true
			}
		}
	},
	"additionalProperties": true,
	"$comment": "additionalProperties is intentionally true for forward-compatibility. Unlike other stack schemas (which use false), the operations layer is an open-ended object that may gain new top-level keys (e.g., hooks, policies) without a schema update."
}
