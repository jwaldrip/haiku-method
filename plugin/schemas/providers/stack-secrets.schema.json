{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://haiku.dev/schemas/providers/stack-secrets.schema.json",
	"title": "Stack Secrets Provider Entry",
	"description": "Secrets management provider configuration for the stack secrets layer",
