{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://ai-dlc.dev/schemas/providers/stack-packaging.schema.json",
	"title": "Stack Packaging Provider Entry",
	"description": "Packaging and manifest provider configuration for the stack packaging layer",
	"type": "object",
	"properties": {
		"provider": {
			"type": "string",
			"enum": ["helm", "kustomize", "raw-manifests", "none"],
			"description": "Packaging/manifest provider"
		},
		"charts_dir": {
			"type": "string",
			"description": "Directory containing charts or manifests"
		}
	},
	"required": ["provider"],
	"additionalProperties": true
}
