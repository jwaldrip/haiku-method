{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://ai-dlc.dev/schemas/providers/stack-pipeline.schema.json",
	"title": "Stack Pipeline Provider Entry",
	"description": "CI/CD pipeline provider configuration for the stack pipeline layer",
	"type": "object",
	"properties": {
		"provider": {
			"type": "string",
			"enum": ["github-actions", "gitlab-ci", "jenkins", "circleci", "none"],
			"description": "CI/CD pipeline provider"
		},
		"workflows_dir": {
			"type": "string",
			"description": "Directory containing pipeline definitions"
		}
	},
	"required": ["provider"],
	"additionalProperties": true
}
