{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://haiku.dev/schemas/providers/stack-compute.schema.json",
	"title": "Stack Compute Provider Entry",
	"description": "Compute platform provider configuration for the stack compute layer",
	"type": "object",
	"properties": {
		"provider": {
			"type": "string",
			"enum": ["kubernetes", "ecs", "lambda", "docker-compose", "none"],
			"description": "Compute platform provider"
		},
		"managed_by": {
			"type": "string",
			"description": "Management tool or service (e.g., 'eks', 'gke', 'self-hosted')"
		},
		"registry": {
			"type": "string",
			"description": "Container registry URL or identifier"
		}
	},
	"required": ["provider"],
	"additionalProperties": true
}
