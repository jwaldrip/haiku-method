{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://ai-dlc.dev/schemas/providers/stack-alerting.schema.json",
	"title": "Stack Alerting Provider Entry",
	"description": "Alerting and on-call provider configuration for the stack alerting layer",
	"type": "object",
	"properties": {
		"provider": {
			"type": "string",
			"enum": ["pagerduty", "opsgenie", "datadog", "prometheus-alertmanager", "none"],
			"description": "Alerting/on-call provider"
		},
		"routing": {
			"type": "string",
			"description": "Alert routing policy or team identifier"
		}
	},
	"required": ["provider"],
	"additionalProperties": true
}
