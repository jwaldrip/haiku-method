{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://haiku.dev/schemas/providers/stack-infrastructure.schema.json",
	"title": "Stack Infrastructure Provider Entry",
	"description": "Infrastructure-as-code provider configuration for the stack infrastructure layer",
	"type": "object",
	"properties": {
		"provider": {
			"type": "string",
			"enum": ["terraform", "cloudformation", "pulumi", "none"],
			"description": "Infrastructure-as-code provider"
		},
		"scope": {
			"type": "string",
			"description": "Scope or directory of IaC definitions (e.g., 'infra/', 'terraform/')"
		},
		"state_backend": {
			"type": "string",
			"description": "State backend identifier (e.g., 's3', 'gcs', 'local')"
		}
	},
	"required": ["provider"],
	"additionalProperties": true
}
